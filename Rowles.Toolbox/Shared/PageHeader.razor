<div class="mb-3">
    @if (!string.IsNullOrEmpty(BackUrl))
    {
        <a href="@BackUrl" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">
            <i class="ti ti-arrow-left mr-0.5"></i> @(BackLabel ?? "Back")
        </a>
    }
    <div class="flex items-center justify-between mt-1">
        <h1>@Title</h1>
        @if (Actions is not null)
        {
            <div class="flex items-center gap-2">
                @Actions
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? BackUrl { get; set; }
    [Parameter] public string? BackLabel { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
