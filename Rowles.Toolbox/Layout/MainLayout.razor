@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

<div class="flex flex-col h-screen">
    <header class="flex items-center justify-between px-4 py-1.5 border-b border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
        <div class="flex items-center gap-2">
            <button type="button"
                    class="md:hidden px-2 py-0.5 border border-gray-300 dark:border-gray-600 rounded
                           hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer
                           bg-white dark:bg-gray-800"
                    title="Menu"
                    @onclick="ToggleNav">
                <i class="ti ti-menu-2"></i>
            </button>
            <a href="/" class="font-bold text-sm tracking-wide no-underline text-gray-900 dark:text-gray-100">Rowles.Toolbox</a>
        </div>
        <div class="relative flex items-center gap-3 text-xs">
            <button type="button"
                    class="px-2 py-0.5 border border-gray-300 dark:border-gray-600 rounded
                           hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer
                           bg-white dark:bg-gray-800"
                    title="Settings"
                    @onclick="ToggleSettingsMenu"
                    @onclick:stopPropagation="true">
                <i class="ti ti-settings"></i>
            </button>

            @if (_settingsOpen)
            {
                <div class="fixed inset-0 z-40" @onclick="CloseSettingsMenu"></div>
                <div class="absolute right-0 top-full mt-1 z-50 w-56 border border-gray-200 dark:border-gray-700 rounded bg-white dark:bg-gray-800 shadow-lg p-3 space-y-3">

                    @* Theme *@
                    <div>
                        <div class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-1">Theme</div>
                        <button onclick="toggleTheme()" type="button"
                                class="w-full flex items-center gap-2 px-2 py-1.5 rounded text-xs text-gray-700 dark:text-gray-300
                                       hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer transition-colors">
                            <i class="ti ti-sun-moon"></i> Toggle dark mode
                        </button>
                    </div>

                    <hr class="border-gray-200 dark:border-gray-700" />

                    @* Text size *@
                    <div>
                        <div class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-1">Text Size</div>
                        <div class="space-y-0.5">
                            @foreach (TextSizeOption option in _textSizeOptions)
                            {
                                <button type="button"
                                        class="@SizeButtonClass(option.Key)"
                                        @onclick="() => SetTextSize(option.Key)">
                                    <i class="@option.IconClass"></i> @option.Label
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
        @* Mobile drawer *@
        @if (_navOpen)
        {
            <div class="fixed inset-0 z-40 bg-black/40 md:hidden" @onclick="CloseNav"></div>
            <nav class="fixed inset-y-0 left-0 z-50 w-64 border-r border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 overflow-y-auto p-2 md:hidden">
                <div class="flex items-center justify-end mb-2">
                    <button type="button"
                            class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 cursor-pointer p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800"
                            @onclick="CloseNav">
                        <i class="ti ti-x text-sm"></i>
                    </button>
                </div>
                <NavMenu />
            </nav>
        }

        @* Desktop sidebar *@
        <nav class="hidden md:block w-48 shrink-0 border-r border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 overflow-y-auto p-2">
            <NavMenu />
        </nav>

        <main class="flex-1 overflow-y-auto p-4">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool _navOpen;
    private bool _settingsOpen;
    private string _currentTextSize = "small";

    private static readonly TextSizeOption[] _textSizeOptions =
    [
        new("small",  "Small",  "ti ti-letter-case text-xs"),
        new("medium", "Medium", "ti ti-letter-case text-sm"),
        new("large",  "Large",  "ti ti-letter-case text-base"),
    ];

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentTextSize = await JS.InvokeAsync<string>("getTextSize");
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _navOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleNav() => _navOpen = !_navOpen;
    private void CloseNav() => _navOpen = false;

    private void ToggleSettingsMenu()=> _settingsOpen = !_settingsOpen;

    private void CloseSettingsMenu() => _settingsOpen = false;

    private async Task SetTextSize(string size)
    {
        _currentTextSize = size;
        await JS.InvokeVoidAsync("setTextSize", size);
    }

    private string SizeButtonClass(string key) =>
        string.Equals(_currentTextSize, key, StringComparison.Ordinal)
            ? "w-full flex items-center gap-2 px-2 py-1.5 rounded text-xs font-semibold bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 cursor-default"
            : "w-full flex items-center gap-2 px-2 py-1.5 rounded text-xs text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer transition-colors";

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private sealed record TextSizeOption(string Key, string Label, string IconClass);
}
