@page "/tools/image/watermark-check"
@using System.Text.Json
@using Rowles.Toolbox.Core.Image
@inject IJSRuntime JS
@inject LocalStorageService Storage
@implements IAsyncDisposable

<PageTitle>Watermark Check - Rowles.Toolbox</PageTitle>

<PageHeader Title="Watermark Check" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-scan-eye mr-1"></i> Detect potential visible watermarks in images</span>
    </Actions>
</PageHeader>

<div class="space-y-4">
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-upload mr-1"></i> Upload Image</h3>
        <InputFile OnChange="OnFileSelected" accept="image/*"
                   class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900/30 dark:file:text-blue-400" />

        @if (_imageDataUrl is not null)
        {
            <div class="mt-3 flex items-center gap-3">
                <button class="bg-blue-600 text-white px-3 py-1 text-xs rounded hover:bg-blue-700 cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed"
                        @onclick="AnalyzeImage" disabled="@_isProcessing">
                    <i class="ti ti-scan mr-0.5"></i> @(_isProcessing ? "Analyzing…" : "Analyze")
                </button>
                <span class="text-xs text-gray-400">@(_imageWidth)×@(_imageHeight) · @WatermarkCheckCore.FormatBytes(_imageSize)</span>
            </div>
        }
    </div>

    <div class="text-xs text-gray-500 dark:text-gray-400 flex items-start gap-1">
        <i class="ti ti-info-circle mt-0.5 shrink-0"></i>
        <span>This tool uses image processing techniques to reveal potential visible watermarks. It cannot detect invisible/steganographic watermarks.</span>
    </div>

    @if (_imageDataUrl is not null && _hasResults)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-photo mr-1"></i> Original</h3>
                <img src="@_imageDataUrl" alt="Original" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-contrast-2 mr-1"></i> High-Contrast Enhanced</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Boosts contrast to reveal faint overlays</p>
                <img src="@_enhancedDataUrl" alt="High-contrast enhanced" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-border-style-2 mr-1"></i> Edge Detection (Sobel)</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Highlights edges that may indicate watermark text</p>
                <img src="@_edgeDataUrl" alt="Edge detection" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-color-filter mr-1"></i> Red Channel</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Watermarks often affect colour channels unevenly</p>
                <img src="@_redChannelDataUrl" alt="Red channel" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-color-filter mr-1"></i> Green Channel</h3>
                <img src="@_greenChannelDataUrl" alt="Green channel" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-color-filter mr-1"></i> Blue Channel</h3>
                <img src="@_blueChannelDataUrl" alt="Blue channel" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4 md:col-span-2 xl:col-span-2">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-chart-bar mr-1"></i> Brightness Histogram</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Watermarks may produce secondary peaks in the distribution</p>
                <img src="@_histogramDataUrl" alt="Brightness histogram" class="w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
            </div>

            @if (_hasAlpha)
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-layers-subtract mr-1"></i> Alpha Channel</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Transparency data shown as grayscale (white = opaque, black = transparent)</p>
                    <img src="@_alphaDataUrl" alt="Alpha channel" class="max-w-full h-auto rounded border border-gray-200 dark:border-gray-700" />
                </div>
            }
        </div>
    }
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/image/watermark-check" OnRestore="RestoreState" />

@code {
    private IJSObjectReference? _jsModule;
    private string? _imageDataUrl;
    private long _imageSize;
    private int _imageWidth;
    private int _imageHeight;
    private bool _isProcessing;
    private bool _hasResults;

    private string? _enhancedDataUrl;
    private string? _edgeDataUrl;
    private string? _redChannelDataUrl;
    private string? _greenChannelDataUrl;
    private string? _blueChannelDataUrl;
    private string? _histogramDataUrl;
    private bool _hasAlpha;
    private string? _alphaDataUrl;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Pages/Tools/Image/WatermarkCheck.razor.js");
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        IBrowserFile file = e.File;
        long maxSize = 20 * 1024 * 1024;
        using System.IO.Stream stream = file.OpenReadStream(maxSize);
        byte[] buffer = new byte[file.Size];
        int bytesRead = await stream.ReadAsync(buffer);
        string base64 = Convert.ToBase64String(buffer, 0, bytesRead);
        _imageDataUrl = WatermarkCheckCore.BuildDataUrl(file.ContentType, base64);
        _imageSize = file.Size;
        _imageWidth = 0;
        _imageHeight = 0;
        ClearResults();
    }

    private async Task AnalyzeImage()
    {
        if (_jsModule is null || _imageDataUrl is null) return;
        _isProcessing = true;
        StateHasChanged();

        JsonElement result = await _jsModule.InvokeAsync<JsonElement>("analyzeImage", _imageDataUrl);

        _imageWidth = result.GetProperty("width").GetInt32();
        _imageHeight = result.GetProperty("height").GetInt32();
        _enhancedDataUrl = result.GetProperty("enhancedDataUrl").GetString();
        _edgeDataUrl = result.GetProperty("edgeDataUrl").GetString();
        _redChannelDataUrl = result.GetProperty("redChannelDataUrl").GetString();
        _greenChannelDataUrl = result.GetProperty("greenChannelDataUrl").GetString();
        _blueChannelDataUrl = result.GetProperty("blueChannelDataUrl").GetString();
        _histogramDataUrl = result.GetProperty("histogramDataUrl").GetString();
        _hasAlpha = result.GetProperty("hasAlpha").GetBoolean();

        if (_hasAlpha)
        {
            _alphaDataUrl = result.GetProperty("alphaDataUrl").GetString();
        }

        _hasResults = true;
        _isProcessing = false;

        string label = $"{_imageWidth}×{_imageHeight} analyzed";
        await Storage.AddRecentAsync("watermark-check", label);
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    private void ClearResults()
    {
        _hasResults = false;
        _enhancedDataUrl = null;
        _edgeDataUrl = null;
        _redChannelDataUrl = null;
        _greenChannelDataUrl = null;
        _blueChannelDataUrl = null;
        _histogramDataUrl = null;
        _hasAlpha = false;
        _alphaDataUrl = null;
    }

    private async Task RestoreState(string json)
    {
        await Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            await _jsModule.DisposeAsync();
        }
    }
}
