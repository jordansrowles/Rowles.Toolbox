@page "/tools/dev/plantuml"
@using Rowles.Toolbox.Core.Developer
@inject IJSRuntime Js
@inject LocalStorageService Storage

<PageTitle>PlantUML Preview - Rowles.Toolbox</PageTitle>

<PageHeader Title="PlantUML Preview" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-plant mr-1"></i> Render PlantUML diagrams via the public server</span>
    </Actions>
</PageHeader>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    @* -------- Left pane: editor -------- *@
    <div class="space-y-3">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-code mr-1"></i> PlantUML Markup
            </h3>
            <textarea class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      rows="18"
                      placeholder="Enter PlantUML markup..."
                      @bind="_input"
                      @bind:event="oninput"
                      @bind:after="OnInputChanged"></textarea>

            <div class="flex flex-wrap gap-2 mt-3">
                <button class="px-3 py-1 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors cursor-pointer border-none"
                        @onclick="CopyCode">
                    <i class="ti ti-copy mr-1"></i> Copy Code
                </button>
                <button class="px-3 py-1 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled="@string.IsNullOrWhiteSpace(_diagramUrl)"
                        @onclick="CopyUrl">
                    <i class="ti ti-link mr-1"></i> Copy URL
                </button>
                <button class="px-3 py-1 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled="@string.IsNullOrWhiteSpace(_diagramUrl)"
                        @onclick="OpenInServer">
                    <i class="ti ti-external-link mr-1"></i> Open in PlantUML Server
                </button>
                <button class="px-3 py-1 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors cursor-pointer border-none"
                        @onclick="ClearInput">
                    <i class="ti ti-trash mr-1"></i> Clear
                </button>
            </div>

            @* Format selector *@
            <div class="flex items-center gap-3 mt-3">
                <span class="text-xs text-gray-500 font-medium">Format:</span>
                <label class="flex items-center gap-1.5 text-sm cursor-pointer">
                    <input type="radio" name="format" value="svg" checked="@(_outputFormat == "svg")" @onchange="@(() => SetFormat("svg"))" />
                    SVG
                </label>
                <label class="flex items-center gap-1.5 text-sm cursor-pointer">
                    <input type="radio" name="format" value="png" checked="@(_outputFormat == "png")" @onchange="@(() => SetFormat("png"))" />
                    PNG
                </label>
            </div>
        </div>

        @* Preset buttons *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-template mr-1"></i> Presets
            </h3>
            <div class="flex flex-wrap gap-2">
                @foreach (PlantUmlPreviewCore.DiagramPreset preset in PlantUmlPreviewCore.Presets)
                {
                    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors"
                            @onclick="() => LoadPreset(preset)">
                        <i class="ti ti-@preset.Icon mr-0.5"></i> @preset.Label
                    </button>
                }
            </div>
        </div>
    </div>

    @* -------- Right pane: preview -------- *@
    <div class="space-y-3">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <div class="flex justify-between items-center mb-3">
                <h3 class="text-sm font-semibold text-gray-500">
                    <i class="ti ti-eye mr-1"></i> Preview
                </h3>
                <span class="text-xs text-gray-400 uppercase">@_outputFormat</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_diagramUrl))
            {
                <div class="overflow-auto max-h-[600px] bg-white dark:bg-gray-900 rounded p-2">
                    <img src="@_diagramUrl" alt="PlantUML diagram preview" class="max-w-full h-auto" />
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-16 text-gray-400 text-sm">
                    <i class="ti ti-plant text-3xl mb-2"></i>
                    <span>Enter PlantUML markup or select a preset to render a diagram</span>
                </div>
            }
        </div>

        @* Clipboard feedback *@
        @if (_showCopiedFeedback)
        {
            <div class="p-2 text-xs text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded text-center">
                <i class="ti ti-check mr-1"></i> @_copiedLabel
            </div>
        }

        @* Info note *@
        <div class="p-2 text-xs text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded">
            <i class="ti ti-info-circle mr-1"></i> Diagrams are rendered via the public PlantUML server
        </div>
    </div>
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/dev/plantuml" OnRestore="RestoreState" />

@code {
    sealed record ToolState(string Input, string OutputFormat);

    private string _input = "";
    private string _diagramUrl = "";
    private string _outputFormat = "svg";
    private bool _showCopiedFeedback;
    private string _copiedLabel = "";
    private System.Threading.Timer? _debounceTimer;
    private RecentEntryPanel? _recentPanel;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/dev/plantuml");
            if (state is not null)
            {
                _input = state.Input;
                _outputFormat = state.OutputFormat;
                UpdateDiagramUrl();
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        ToolState state = new(_input, _outputFormat);
        await Storage.SaveStateAsync("tools/dev/plantuml", state);
    }

    private void RestoreState(string json)
    {
        ToolState? state = System.Text.Json.JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _input = state.Input;
            _outputFormat = state.OutputFormat;
            UpdateDiagramUrl();
        }
    }

    private void OnInputChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(
            _ => InvokeAsync(async () =>
            {
                UpdateDiagramUrl();
                await SaveState();
                StateHasChanged();
            }),
            null,
            TimeSpan.FromMilliseconds(400),
            System.Threading.Timeout.InfiniteTimeSpan);
    }

    private void UpdateDiagramUrl()
    {
        _diagramUrl = PlantUmlPreviewCore.BuildDiagramUrl(_input, _outputFormat);
    }

    private async Task LoadPreset(PlantUmlPreviewCore.DiagramPreset preset)
    {
        _input = preset.Code;
        _debounceTimer?.Dispose();
        UpdateDiagramUrl();
        ToolState state = new(_input, _outputFormat);
        await Storage.AddRecentAsync("tools/dev/plantuml", $"Preset: {preset.Label}", state);
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        await SaveState();
    }

    private async Task SetFormat(string format)
    {
        _outputFormat = format;
        UpdateDiagramUrl();
        await SaveState();
    }

    private async Task CopyCode()
    {
        if (string.IsNullOrWhiteSpace(_input))
            return;

        await Js.InvokeVoidAsync("navigator.clipboard.writeText", _input);
        await ShowCopiedFeedback("Copied PlantUML code to clipboard!");
    }

    private async Task CopyUrl()
    {
        if (string.IsNullOrWhiteSpace(_diagramUrl))
            return;

        await Js.InvokeVoidAsync("navigator.clipboard.writeText", _diagramUrl);
        await ShowCopiedFeedback("Copied diagram URL to clipboard!");
    }

    private async Task OpenInServer()
    {
        if (string.IsNullOrWhiteSpace(_diagramUrl))
            return;

        await Js.InvokeVoidAsync("eval", $"window.open('{_diagramUrl}', '_blank')");
    }

    private async Task ClearInput()
    {
        _input = "";
        _diagramUrl = "";
        _debounceTimer?.Dispose();
        await SaveState();
    }

    private async Task ShowCopiedFeedback(string label)
    {
        _copiedLabel = label;
        _showCopiedFeedback = true;
        StateHasChanged();

        await Task.Delay(2000);
        _showCopiedFeedback = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
