@page "/tools/dev/type-hierarchy"

@using Rowles.Toolbox.Core.Developer
@inject IJSRuntime Js
@inject LocalStorageService Storage

<PageTitle>Type Hierarchy Browser - Rowles.Toolbox</PageTitle>

<PageHeader Title="Type Hierarchy Browser" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-hierarchy-2 mr-1"></i> Browse .NET BCL type inheritance &amp; interfaces</span>
    </Actions>
</PageHeader>

@* Search *@
<div class="mb-4">
    <input type="text"
           placeholder="Search types by name, namespace, or interface..."
           class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500"
           @bind="_searchQuery"
           @bind:event="oninput"
           @bind:after="SaveState" />
</div>

@* Category filters *@
<div class="flex gap-2 mb-4 flex-wrap">
    @foreach (string cat in _allCategories)
    {
        string label = cat;
        <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_selectedCategory == cat ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
                @onclick="() => SetCategoryAndSave(cat)">
            <i class="ti ti-@(TypeHierarchyBrowserCore.GetCategoryIcon(cat)) mr-0.5"></i> @label
        </button>
    }
</div>

@{
    List<TypeHierarchyBrowserCore.TypeEntry> filtered = TypeHierarchyBrowserCore.GetFilteredTypes(TypeHierarchyBrowserCore.Types, _selectedCategory, _searchQuery);
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    @* ============ LEFT: Type list ============ *@
    <div class="lg:col-span-1 border border-gray-200 dark:border-gray-700 rounded p-3 max-h-[80vh] overflow-y-auto">
        <h3 class="text-xs font-semibold text-gray-500 mb-2">
            <i class="ti ti-list mr-1"></i> Types (@filtered.Count)
        </h3>
        @if (filtered.Count == 0)
        {
            <p class="text-xs text-gray-400 italic py-4">No types match your search.</p>
        }
        else
        {
            <div class="space-y-1">
                @foreach (TypeHierarchyBrowserCore.TypeEntry entry in filtered)
                {
                    bool isSelected = _selectedType is not null && _selectedType.FullName == entry.FullName;
                    <button class="w-full text-left px-3 py-2 text-xs rounded cursor-pointer border-none flex items-center gap-2 @(isSelected ? "bg-blue-600 text-white" : "bg-transparent text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")"
                            @onclick="() => _selectedType = entry">
                        <span class="@(isSelected ? "bg-blue-500" : TypeHierarchyBrowserCore.GetKindBadgeColor(entry.Kind)) px-1.5 py-0.5 rounded text-[10px] font-mono font-bold leading-none shrink-0">
                            @TypeHierarchyBrowserCore.GetKindAbbrev(entry.Kind)
                        </span>
                        <span class="font-medium truncate">@entry.ShortName</span>
                        <span class="ml-auto text-[10px] opacity-60 shrink-0">@entry.Category</span>
                    </button>
                }
            </div>
        }
    </div>

    @* ============ RIGHT: Detail panel ============ *@
    <div class="lg:col-span-2 space-y-4">
        @if (_selectedType is null)
        {
            <div class="border border-gray-200 dark:border-gray-700 rounded p-8 flex flex-col items-center justify-center text-gray-400">
                <i class="ti ti-hierarchy-2 text-4xl mb-2"></i>
                <p class="text-sm">Select a type to view its hierarchy</p>
            </div>
        }
        else
        {
            TypeHierarchyBrowserCore.TypeEntry sel = _selectedType;

            @* Header *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <div class="flex items-start justify-between gap-2">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="@(TypeHierarchyBrowserCore.GetKindBadgeColor(sel.Kind)) px-2 py-0.5 rounded text-xs font-mono font-bold">
                                @sel.Kind.ToString().ToLowerInvariant()
                            </span>
                            @foreach (string mod in sel.Modifiers)
                            {
                                <span class="bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded text-xs font-mono">
                                    @mod
                                </span>
                            }
                        </div>
                        <h2 class="text-lg font-bold font-mono text-gray-800 dark:text-gray-100">@sel.FullName</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Category: @sel.Category</p>
                    </div>
                    <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline cursor-pointer border-none bg-transparent shrink-0"
                            @onclick="() => CopyToClipboard(sel.FullName)">
                        <i class="ti ti-copy mr-0.5"></i> Copy Name
                    </button>
                </div>
            </div>

            @* Inheritance chain *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">
                    <i class="ti ti-git-merge mr-1"></i> Inheritance Chain
                </h3>
                @{
                    List<string> chain = sel.BaseTypeChain;
                }
                @if (chain.Count == 0)
                {
                    <p class="text-xs text-gray-400 italic">No base types (root type or interface).</p>
                }
                else
                {
                    <div class="space-y-0">
                        @for (int idx = 0; idx < chain.Count; idx++)
                        {
                            int level = idx;
                            string typeName = chain[idx];
                            bool isLast = idx == chain.Count - 1;
                            <div class="flex items-stretch">
                                @* Indentation guides *@
                                @for (int g = 0; g < level; g++)
                                {
                                    <div class="w-6 shrink-0 border-l-2 border-gray-300 dark:border-gray-600"></div>
                                }
                                <div class="flex items-center gap-1.5 py-1.5">
                                    @if (level > 0)
                                    {
                                        <span class="text-gray-400 text-xs mr-0.5">&#9492;&#9472;</span>
                                    }
                                    @if (isLast)
                                    {
                                        <span class="bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded text-xs font-mono font-bold">
                                            @typeName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded text-xs font-mono">
                                            @typeName
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Interfaces *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">
                    <i class="ti ti-puzzle mr-1"></i> Implemented Interfaces (@sel.Interfaces.Count)
                </h3>
                @if (sel.Interfaces.Count == 0)
                {
                    <p class="text-xs text-gray-400 italic">No interfaces implemented.</p>
                }
                else
                {
                    <div class="flex flex-wrap gap-1.5">
                        @foreach (string iface in sel.Interfaces)
                        {
                            <span class="bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 px-2 py-0.5 rounded text-xs font-mono">
                                @iface
                            </span>
                        }
                    </div>
                }
            </div>

            @* Quick info *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">
                    <i class="ti ti-info-circle mr-1"></i> Quick Info
                </h3>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-xs">
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-2">
                        <span class="text-gray-500 block mb-0.5">Kind</span>
                        <span class="font-mono font-bold text-gray-700 dark:text-gray-300">@sel.Kind</span>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-2">
                        <span class="text-gray-500 block mb-0.5">Depth</span>
                        <span class="font-mono font-bold text-gray-700 dark:text-gray-300">@(sel.BaseTypeChain.Count > 0 ? sel.BaseTypeChain.Count - 1 : 0) levels</span>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-2">
                        <span class="text-gray-500 block mb-0.5">Interfaces</span>
                        <span class="font-mono font-bold text-gray-700 dark:text-gray-300">@sel.Interfaces.Count</span>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-2">
                        <span class="text-gray-500 block mb-0.5">Modifiers</span>
                        <span class="font-mono font-bold text-gray-700 dark:text-gray-300">@(sel.Modifiers.Count > 0 ? string.Join(", ", sel.Modifiers) : "none")</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <div class="fixed bottom-4 right-4 bg-green-600 text-white text-xs px-3 py-1.5 rounded shadow-lg z-50">
        <i class="ti ti-check mr-1"></i> @_statusMessage
    </div>
}

@code {
    private RecentEntryPanel? _recentPanel;
    sealed record ToolState(string SearchQuery, string SelectedCategory);

    private string _searchQuery = string.Empty;
    private string _selectedCategory = "All";
    private TypeHierarchyBrowserCore.TypeEntry? _selectedType;
    private string? _statusMessage;

    private readonly string[] _allCategories = new[]
    {
        "All", "Primitives", "Collections", "Interfaces", "IO", "Text",
        "Threading", "Exceptions", "Spans", "Other"
    };

    private async Task CopyToClipboard(string copyText)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", copyText);
        _statusMessage = "Copied to clipboard";
        StateHasChanged();
        await Task.Delay(1500);
        _statusMessage = null;
        StateHasChanged();
    }

    private async Task SetCategoryAndSave(string category)
    {
        _selectedCategory = category;
        await SaveState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/dev/type-hierarchy");
            if (state is not null)
            {
                _searchQuery = state.SearchQuery;
                _selectedCategory = state.SelectedCategory;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/dev/type-hierarchy", new ToolState(_searchQuery, _selectedCategory));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _searchQuery = state.SearchQuery;
            _selectedCategory = state.SelectedCategory;
            StateHasChanged();
        }
    }
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/dev/type-hierarchy" OnRestore="RestoreState" />
