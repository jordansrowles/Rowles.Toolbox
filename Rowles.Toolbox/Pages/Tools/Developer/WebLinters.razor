@page "/tools/dev/web-linters"
@using Rowles.Toolbox.Core.Developer
@inject LocalStorageService Storage

<PageTitle>Web Linters - Rowles.Toolbox</PageTitle>

<PageHeader Title="Web Linters" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-bug mr-1"></i> Lint HTML, CSS &amp; JavaScript for common issues</span>
    </Actions>
</PageHeader>

@*  Tabs  *@
<div class="flex gap-2 mb-4 flex-wrap">
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "html" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='() => SwitchTab("html")'>
        <i class="ti ti-brand-html5 mr-0.5"></i> HTML
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "css" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='() => SwitchTab("css")'>
        <i class="ti ti-brand-css3 mr-0.5"></i> CSS
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "js" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='() => SwitchTab("js")'>
        <i class="ti ti-brand-javascript mr-0.5"></i> JavaScript
    </button>
</div>

@*  Input  *@
<div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4">
    <h3 class="text-sm font-semibold text-gray-500 mb-3">
        <i class="ti ti-code mr-1"></i> @(_activeTab == "html" ? "HTML" : _activeTab == "css" ? "CSS" : "JavaScript") Source
    </h3>
    <textarea class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              rows="14"
              placeholder="@WebLintersCore.GetPlaceholder(_activeTab)"
              @bind="_inputCode"
              @bind:event="oninput"
              @bind:after="SaveState"></textarea>

    <div class="flex gap-2 mt-3">
        <button class="px-3 py-1 text-sm bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors"
                @onclick="RunLint">
            <i class="ti ti-bug mr-1"></i> Lint
        </button>
        <button class="px-3 py-1 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
                @onclick="LoadSample">
            <i class="ti ti-file-code mr-1"></i> Load Sample
        </button>
        <button class="px-3 py-1 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
                @onclick="Clear">
            <i class="ti ti-trash mr-1"></i> Clear
        </button>
    </div>
</div>

@*  Results  *@
@if (_results.Count > 0)
{
    int errors = _results.Count(r => r.Severity == "error");
    int warnings = _results.Count(r => r.Severity == "warning");
    int infos = _results.Count(r => r.Severity == "info");

    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-list-check mr-1"></i> Results
            <span class="ml-2 text-xs font-normal">
                @if (errors > 0)
                {
                    <span class="text-red-600 dark:text-red-400 mr-2"><i class="ti ti-alert-circle mr-0.5"></i> @errors error@(errors != 1 ? "s" : "")</span>
                }
                @if (warnings > 0)
                {
                    <span class="text-amber-600 dark:text-amber-400 mr-2"><i class="ti ti-alert-triangle mr-0.5"></i> @warnings warning@(warnings != 1 ? "s" : "")</span>
                }
                @if (infos > 0)
                {
                    <span class="text-blue-600 dark:text-blue-400"><i class="ti ti-info-circle mr-0.5"></i> @infos info</span>
                }
            </span>
        </h3>

        <div class="space-y-2">
            @foreach (WebLintersCore.LintResult result in _results)
            {
                <div class="flex items-start gap-3 p-3 rounded border @WebLintersCore.GetResultBorderClass(result.Severity)">
                    @* Severity icon *@
                    <span class="mt-0.5 @WebLintersCore.GetSeverityColor(result.Severity)">
                        <i class="ti @WebLintersCore.GetSeverityIcon(result.Severity)"></i>
                    </span>

                    @* Line badge *@
                    <span class="px-2 py-0.5 text-xs font-mono rounded bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 whitespace-nowrap">
                        L@(result.Line)
                    </span>

                    @* Rule + message *@
                    <div class="flex-1 min-w-0">
                        <span class="text-xs font-mono font-semibold @WebLintersCore.GetSeverityColor(result.Severity)">@result.Rule</span>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-0.5">@result.Message</p>
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (_hasLinted)
{
    <div class="border border-green-200 dark:border-green-800 rounded p-4 text-center">
        <i class="ti ti-circle-check text-green-500 text-2xl"></i>
        <p class="text-sm text-green-700 dark:text-green-400 mt-1">No issues found — looking good!</p>
    </div>
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/dev/web-linters" OnRestore="RestoreState" />

@code {
    sealed record ToolState(string ActiveTab, string InputCode);

    private string _activeTab = "html";
    private string _inputCode = "";
    private List<WebLintersCore.LintResult> _results = new();
    private bool _hasLinted;
    private RecentEntryPanel? _recentPanel;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/dev/web-linters");
            if (state is not null)
            {
                _activeTab = state.ActiveTab;
                _inputCode = state.InputCode;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        ToolState state = new(_activeTab, _inputCode);
        await Storage.SaveStateAsync("tools/dev/web-linters", state);
    }

    private void RestoreState(string json)
    {
        ToolState? state = System.Text.Json.JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _activeTab = state.ActiveTab;
            _inputCode = state.InputCode;
        }
    }

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        _inputCode = "";
        _results.Clear();
        _hasLinted = false;
        await SaveState();
    }

    private async Task Clear()
    {
        _inputCode = "";
        _results.Clear();
        _hasLinted = false;
        await SaveState();
    }

    private async Task RunLint()
    {
        _results.Clear();
        _hasLinted = true;

        if (string.IsNullOrWhiteSpace(_inputCode))
            return;

        _results = _activeTab switch
        {
            "html" => WebLintersCore.LintHtml(_inputCode),
            "css" => WebLintersCore.LintCss(_inputCode),
            "js" => WebLintersCore.LintJs(_inputCode),
            _ => new()
        };

        _results = _results
            .OrderBy(r => r.Severity switch { "error" => 0, "warning" => 1, _ => 2 })
            .ThenBy(r => r.Line)
            .ToList();

        ToolState state = new(_activeTab, _inputCode);
        await Storage.AddRecentAsync("tools/dev/web-linters", $"Linted {_activeTab.ToUpper()}: {_results.Count} issues", state);
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    private async Task LoadSample()
    {
        _results.Clear();
        _hasLinted = false;

        _inputCode = _activeTab switch
        {
            "html" => WebLintersCore.SampleHtml,
            "css" => WebLintersCore.SampleCss,
            "js" => WebLintersCore.SampleJs,
            _ => ""
        };

        await SaveState();
    }
}
