@page "/tools/dev/culture"
@using System.Globalization
@using Rowles.Toolbox.Core.Developer
@inject LocalStorageService Storage

<PageTitle>Culture Formatter - Rowles.Toolbox</PageTitle>

<PageHeader Title="Culture Formatter" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-language mr-1"></i> Explore .NET CultureInfo number &amp; date formatting</span>
    </Actions>
</PageHeader>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    @* ----─ Input section ----─ *@
    <div class="space-y-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-forms mr-1"></i> Inputs</h3>

            <div class="space-y-3">
                <div>
                    <label class="block text-sm font-medium mb-1">Number</label>
                    <input type="number" step="any"
                           class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_numberInput"
                           @bind:event="oninput"
                           @bind:after="SaveState" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Date &amp; Time</label>
                    <input type="datetime-local"
                           class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dateInput"
                           @bind:event="oninput"
                           @bind:after="SaveState" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Currency Amount</label>
                    <input type="number" step="0.01"
                           class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_currencyInput"
                           @bind:event="oninput"
                           @bind:after="SaveState" />
                </div>
            </div>
        </div>

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-world mr-1"></i> Culture</h3>
            <select class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                    @bind="_selectedCulture"
                    @bind:event="onchange"
                    @bind:after="SaveState">
                @foreach (string cultureCode in CultureFormatterCore.CultureCodes)
                {
                    CultureInfo ci = CultureInfo.GetCultureInfo(cultureCode);
                    <option value="@cultureCode">@cultureCode — @ci.DisplayName</option>
                }
            </select>
        </div>

        @* ----─ Culture info panel ----─ *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-info-circle mr-1"></i> Culture Details</h3>
            @{
                CultureInfo info = SelectedCultureInfo;
                NumberFormatInfo nfi = info.NumberFormat;
                DateTimeFormatInfo dtfi = info.DateTimeFormat;
            }
            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Native Name</span>
                    <span class="font-medium">@info.NativeName</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">English Name</span>
                    <span class="font-medium">@info.EnglishName</span>
                </div>
                <hr class="border-gray-200 dark:border-gray-700" />
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Decimal Sep</span>
                    <span class="font-mono font-bold text-blue-600 dark:text-blue-400">@nfi.NumberDecimalSeparator</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Group Sep</span>
                    <span class="font-mono font-bold text-blue-600 dark:text-blue-400">@CultureFormatterCore.EscapeWhitespace(nfi.NumberGroupSeparator)</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Currency Symbol</span>
                    <span class="font-mono font-bold text-blue-600 dark:text-blue-400">@nfi.CurrencySymbol</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Percent Symbol</span>
                    <span class="font-mono font-bold text-blue-600 dark:text-blue-400">@nfi.PercentSymbol</span>
                </div>
                <hr class="border-gray-200 dark:border-gray-700" />
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Short Date</span>
                    <span class="font-mono text-xs">@dtfi.ShortDatePattern</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Long Date</span>
                    <span class="font-mono text-xs">@dtfi.LongDatePattern</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">Time</span>
                    <span class="font-mono text-xs">@dtfi.LongTimePattern</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-600 dark:text-gray-400">First Day</span>
                    <span class="font-medium">@dtfi.FirstDayOfWeek</span>
                </div>
            </div>
        </div>
    </div>

    @* ----─ Formatted output tables ----─ *@
    <div class="lg:col-span-2 space-y-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-hash mr-1"></i> Number Formats</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium">Specifier</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Name</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach ((string specifier, string name) in CultureFormatterCore.NumberFormats)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono text-blue-600 dark:text-blue-400 font-bold">@specifier</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@name</td>
                                <td class="p-2 font-mono">@FormatNumber(specifier, SelectedCultureInfo)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-calendar mr-1"></i> Date/Time Formats</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium">Specifier</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Name</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach ((string specifier, string name) in CultureFormatterCore.DateFormats)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono text-blue-600 dark:text-blue-400 font-bold">@specifier</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@name</td>
                                <td class="p-2 font-mono">@FormatDate(specifier, SelectedCultureInfo)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-coins mr-1"></i> Currency Formats</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium">Specifier</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Name</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach ((string specifier, string name) in CultureFormatterCore.CurrencyFormats)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono text-blue-600 dark:text-blue-400 font-bold">@specifier</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@name</td>
                                <td class="p-2 font-mono">@FormatCurrency(specifier, SelectedCultureInfo)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ----─ Side-by-side comparison ----─ *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-columns mr-1"></i> Side-by-Side Comparison</h3>

            <div class="grid grid-cols-2 gap-3 mb-4">
                <div>
                    <label class="block text-xs font-medium mb-1">Culture A</label>
                    <select class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            @bind="_compareCultureA"
                            @bind:event="onchange"
                            @bind:after="SaveState">
                        @foreach (string cultureCode in CultureFormatterCore.CultureCodes)
                        {
                            CultureInfo ci = CultureInfo.GetCultureInfo(cultureCode);
                            <option value="@cultureCode">@cultureCode — @ci.DisplayName</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1">Culture B</label>
                    <select class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            @bind="_compareCultureB"
                            @bind:event="onchange"
                            @bind:after="SaveState">
                        @foreach (string cultureCode in CultureFormatterCore.CultureCodes)
                        {
                            CultureInfo ci = CultureInfo.GetCultureInfo(cultureCode);
                            <option value="@cultureCode">@cultureCode — @ci.DisplayName</option>
                        }
                    </select>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium">Type</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Fmt</th>
                            <th class="text-left p-2 text-gray-500 font-medium">@_compareCultureA</th>
                            <th class="text-left p-2 text-gray-500 font-medium">@_compareCultureB</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            CultureInfo cultureA = CultureInfo.GetCultureInfo(_compareCultureA);
                            CultureInfo cultureB = CultureInfo.GetCultureInfo(_compareCultureB);
                        }
                        @foreach ((string specifier, string name) in CultureFormatterCore.ComparisonFormats)
                        {
                            string resultA = FormatForComparison(specifier, name, cultureA);
                            string resultB = FormatForComparison(specifier, name, cultureB);
                            bool isDifferent = !string.Equals(resultA, resultB, StringComparison.Ordinal);

                            <tr class="border-b border-gray-100 dark:border-gray-800 @(isDifferent ? "bg-yellow-50 dark:bg-yellow-900/20" : "")">
                                <td class="p-2 text-gray-600 dark:text-gray-400">@name</td>
                                <td class="p-2 font-mono text-blue-600 dark:text-blue-400 font-bold">@specifier</td>
                                <td class="p-2 font-mono">@resultA</td>
                                <td class="p-2 font-mono @(isDifferent ? "text-orange-600 dark:text-orange-400 font-semibold" : "")">@resultB</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private RecentEntryPanel? _recentPanel;
    sealed record ToolState(
        double NumberInput,
        DateTime DateInput,
        double CurrencyInput,
        string SelectedCulture,
        string CompareCultureA,
        string CompareCultureB
    );

    private double _numberInput = 1234567.89;
    private DateTime _dateInput = DateTime.Now;
    private double _currencyInput = 4299.50;
    private string _selectedCulture = "en-GB";
    private string _compareCultureA = "en-GB";
    private string _compareCultureB = "en-US";

    private CultureInfo SelectedCultureInfo => CultureInfo.GetCultureInfo(_selectedCulture);

    private string FormatNumber(string specifier, CultureInfo culture)
        => CultureFormatterCore.FormatNumber(specifier, culture, _numberInput);

    private string FormatDate(string specifier, CultureInfo culture)
        => CultureFormatterCore.FormatDate(specifier, culture, _dateInput);

    private string FormatCurrency(string specifier, CultureInfo culture)
        => CultureFormatterCore.FormatCurrency(specifier, culture, _currencyInput);

    private string FormatForComparison(string specifier, string name, CultureInfo culture)
        => CultureFormatterCore.FormatForComparison(specifier, name, culture, _numberInput, _dateInput, _currencyInput);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/dev/culture");
            if (state is not null)
            {
                _numberInput = state.NumberInput;
                _dateInput = state.DateInput;
                _currencyInput = state.CurrencyInput;
                _selectedCulture = state.SelectedCulture;
                _compareCultureA = state.CompareCultureA;
                _compareCultureB = state.CompareCultureB;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/dev/culture", new ToolState(
            _numberInput,
            _dateInput,
            _currencyInput,
            _selectedCulture,
            _compareCultureA,
            _compareCultureB
        ));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _numberInput = state.NumberInput;
            _dateInput = state.DateInput;
            _currencyInput = state.CurrencyInput;
            _selectedCulture = state.SelectedCulture;
            _compareCultureA = state.CompareCultureA;
            _compareCultureB = state.CompareCultureB;
            StateHasChanged();
        }
    }
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/dev/culture" OnRestore="RestoreState" />