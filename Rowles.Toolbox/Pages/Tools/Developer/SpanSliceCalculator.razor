@page "/tools/dev/span-slice"
@using Rowles.Toolbox.Core.Developer
@inject IJSRuntime Js
@inject LocalStorageService Storage

<PageTitle>Span Slice Calculator - Rowles.Toolbox</PageTitle>

<PageHeader Title="Span Slice Calculator" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-brackets mr-1"></i> Calculate and validate Span, Memory, Range &amp; ArraySegment slice bounds</span>
    </Actions>
</PageHeader>

<div class="space-y-4">

    @* -------- Input Controls -------- *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-adjustments mr-1"></i> Slice Parameters
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-xs text-gray-500 mb-1">Buffer Length</label>
                <input type="number"
                       min="0"
                       class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       @bind="_bufferLength"
                       @bind:event="oninput"
                       @bind:after="RecalculateAndSave" />
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">@SpanSliceCalculatorCore.GetStartLabel(_selectedMethod)</label>
                <input type="number"
                       class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       @bind="_startIndex"
                       @bind:event="oninput"
                       @bind:after="RecalculateAndSave" />
            </div>
            @if (_selectedMethod != SpanSliceCalculatorCore.SliceMethod.SpanSliceStart)
            {
                <div>
                    <label class="block text-xs text-gray-500 mb-1">@SpanSliceCalculatorCore.GetSecondParamLabel(_selectedMethod)</label>
                    <input type="number"
                           class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_count"
                           @bind:event="oninput"
                           @bind:after="RecalculateAndSave" />
                </div>
            }
            <div>
                <label class="block text-xs text-gray-500 mb-1">Slice Method</label>
                <select class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                        @bind="_selectedMethod"
                        @bind:after="Recalculate">
                    @foreach (SpanSliceCalculatorCore.SliceMethod method in Enum.GetValues<SpanSliceCalculatorCore.SliceMethod>())
                    {
                        <option value="@method">@SpanSliceCalculatorCore.GetMethodDisplayName(method)</option>
                    }
                </select>
            </div>
        </div>
        <p class="text-xs text-gray-400 mt-2 font-mono">
            <i class="ti ti-code mr-0.5"></i> @SpanSliceCalculatorCore.GetMethodSignature(_selectedMethod, _bufferLength, _startIndex, _count)
        </p>
    </div>

    @* -------- Visual Buffer Display -------- *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-layout-grid mr-1"></i> Buffer Visualization
            @if (_bufferLength > SpanSliceCalculatorCore.MaxDisplayCells)
            {
                <span class="text-xs text-amber-500 ml-2">
                    <i class="ti ti-info-circle mr-0.5"></i> Showing first @SpanSliceCalculatorCore.MaxDisplayCells of @_bufferLength cells
                </span>
            }
        </h3>

        @if (_bufferLength == 0 && _resolvedStart == 0 && _resolvedEnd == 0 && _isValid)
        {
            <div class="flex items-center justify-center py-6 text-gray-400 text-sm">
                <i class="ti ti-brackets mr-1"></i> Zero-length buffer (empty)
            </div>
        }
        else
        {
            int displayCount = GetDisplayCount();
            int extraCells = GetExtraCells();
            int totalCells = GetTotalCells();
            bool wasTruncated = _bufferLength > SpanSliceCalculatorCore.MaxDisplayCells;
            <div class="overflow-x-auto">
                @* Index row *@
                <div class="flex items-end gap-0 mb-0.5">
                    @for (int i = 0; i < totalCells; i++)
                    {
                        int idx = i;
                        <div class="flex-shrink-0 w-9 text-center text-[10px] font-mono @(idx >= _bufferLength ? "text-red-400" : "text-gray-400")">
                            @idx
                        </div>
                    }
                    @if (wasTruncated)
                    {
                        <div class="flex-shrink-0 w-9 text-center text-[10px] font-mono text-gray-400">
                            ...
                        </div>
                    }
                </div>
                @* Cell row *@
                <div class="flex items-center gap-0">
                    @for (int i = 0; i < totalCells; i++)
                    {
                        int idx = i;
                        string cellClass = SpanSliceCalculatorCore.GetCellClass(idx, _bufferLength, _isValid, _resolvedStart, _resolvedEnd);
                        <div class="flex-shrink-0 w-9 h-9 border border-gray-300 dark:border-gray-600 flex items-center justify-center text-xs font-mono @cellClass"
                             title="@SpanSliceCalculatorCore.GetCellTooltip(idx, _bufferLength, _isValid, _resolvedStart, _resolvedEnd)">
                            @if (idx < _bufferLength)
                            {
                                <span>@idx</span>
                            }
                            else
                            {
                                <i class="ti ti-x text-red-400 text-[10px]"></i>
                            }
                        </div>
                    }
                    @if (wasTruncated)
                    {
                        <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center text-xs font-mono text-gray-400">
                            ...
                        </div>
                    }
                </div>
                @* Legend *@
                <div class="flex items-center gap-4 mt-2 text-[10px] text-gray-500">
                    <span class="flex items-center gap-1">
                        <span class="inline-block w-3 h-3 bg-blue-100 dark:bg-blue-900 border border-blue-400 rounded-sm"></span> Selected slice
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="inline-block w-3 h-3 bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-sm"></span> Buffer (not selected)
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="inline-block w-3 h-3 bg-red-100 dark:bg-red-900/40 border border-red-400 rounded-sm"></span> Out of bounds
                    </span>
                </div>
            </div>
        }
    </div>

    @* -------- Validation Result -------- *@
    <div class="border rounded p-4 @(_isValid ? "border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-900/20" : "border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20")">
        <div class="flex items-start gap-3">
            @if (_isValid)
            {
                <i class="ti ti-circle-check text-green-500 text-xl mt-0.5"></i>
                <div>
                    <h3 class="text-sm font-semibold text-green-700 dark:text-green-400">Slice is valid</h3>
                    <div class="text-sm text-green-600 dark:text-green-300 mt-1 space-y-1">
                        <div>
                            <span class="text-gray-500 dark:text-gray-400">Range:</span>
                            <code class="ml-1 font-mono font-bold">[@_resolvedStart..@_resolvedEnd)</code>
                            <span class="text-xs text-gray-400 ml-1">(inclusive start, exclusive end)</span>
                        </div>
                        <div>
                            <span class="text-gray-500 dark:text-gray-400">Resulting length:</span>
                            <code class="ml-1 font-mono font-bold">@(_resolvedEnd - _resolvedStart)</code>
                        </div>
                        @if (_resolvedEnd - _resolvedStart == 0)
                        {
                            <div class="text-xs text-amber-600 dark:text-amber-400">
                                <i class="ti ti-info-circle mr-0.5"></i> Empty slice (zero elements)
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <i class="ti ti-circle-x text-red-500 text-xl mt-0.5"></i>
                <div>
                    <h3 class="text-sm font-semibold text-red-700 dark:text-red-400">@_exceptionType</h3>
                    <p class="text-sm text-red-600 dark:text-red-300 mt-1 font-mono">@_exceptionMessage</p>
                </div>
            }
        </div>
    </div>

    @* -------- Equivalent Expressions -------- *@
    @if (_isValid)
    {
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-transform mr-1"></i> Equivalent Expressions
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                @foreach (SpanSliceCalculatorCore.EquivalentExpression expr in _equivalentExpressions)
                {
                    <div class="flex items-center gap-2 p-2 bg-gray-50 dark:bg-gray-800 rounded text-sm group">
                        <code class="font-mono text-blue-600 dark:text-blue-400 flex-1 text-xs break-all">@expr.Code</code>
                        <button class="opacity-0 group-hover:opacity-100 transition-opacity text-gray-400 hover:text-blue-500 cursor-pointer border-none bg-transparent p-1"
                                @onclick="() => CopyToClipboard(expr.Code)"
                                title="Copy">
                            <i class="ti ti-copy text-xs"></i>
                        </button>
                        <span class="text-[10px] text-gray-400 whitespace-nowrap">@expr.Api</span>
                    </div>
                }
            </div>
        </div>
    }

    @* -------- Edge Cases Table -------- *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-alert-triangle mr-1"></i> Edge Case Analysis
            <span class="text-xs text-gray-400 font-normal ml-1">(for buffer length @_bufferLength)</span>
        </h3>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700">
                        <th class="text-left p-2 text-gray-500">Description</th>
                        <th class="text-left p-2 text-gray-500">Expression</th>
                        <th class="text-left p-2 text-gray-500">Result</th>
                        <th class="text-center p-2 text-gray-500">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (SpanSliceCalculatorCore.EdgeCaseRow row in _edgeCases)
                    {
                        <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                            <td class="p-2 text-gray-600 dark:text-gray-400">@row.Description</td>
                            <td class="p-2 font-mono text-xs text-blue-600 dark:text-blue-400">@row.Expression</td>
                            <td class="p-2 font-mono text-xs @(row.IsValid ? "text-green-600 dark:text-green-400" : "text-red-500 dark:text-red-400")">
                                @row.Result
                            </td>
                            <td class="p-2 text-center">
                                @if (row.IsValid)
                                {
                                    <i class="ti ti-circle-check text-green-500"></i>
                                }
                                else
                                {
                                    <i class="ti ti-circle-x text-red-500"></i>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* -------- Quick Reference (Collapsible) -------- *@
    <div class="border border-gray-200 dark:border-gray-700 rounded">
        <button class="w-full p-4 flex items-center justify-between cursor-pointer bg-transparent border-none text-left"
                @onclick="() => _referenceExpanded = !_referenceExpanded">
            <h3 class="text-sm font-semibold text-gray-500">
                <i class="ti ti-book mr-1"></i> Quick Reference: Span / Memory / Range API
            </h3>
            <i class="ti @(_referenceExpanded ? "ti-chevron-up" : "ti-chevron-down") text-gray-400"></i>
        </button>
        @if (_referenceExpanded)
        {
            <div class="px-4 pb-4 space-y-4">
                @* Span<T> *@
                <div>
                    <h4 class="text-xs font-semibold text-blue-500 mb-2 uppercase tracking-wide">
                        <i class="ti ti-brackets mr-0.5"></i> Span&lt;T&gt; / ReadOnlySpan&lt;T&gt;
                    </h4>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-3 text-xs font-mono space-y-1">
                        <div><span class="text-purple-500">Span</span>&lt;T&gt; Slice(<span class="text-blue-500">int</span> start)</div>
                        <div><span class="text-purple-500">Span</span>&lt;T&gt; Slice(<span class="text-blue-500">int</span> start, <span class="text-blue-500">int</span> length)</div>
                        <div class="text-gray-500 mt-2">Throws ArgumentOutOfRangeException when:</div>
                        <div class="text-gray-500 pl-3">- start &lt; 0</div>
                        <div class="text-gray-500 pl-3">- start &gt; span.Length</div>
                        <div class="text-gray-500 pl-3">- start + length &gt; span.Length</div>
                    </div>
                </div>

                @* Memory<T> *@
                <div>
                    <h4 class="text-xs font-semibold text-green-500 mb-2 uppercase tracking-wide">
                        <i class="ti ti-cpu mr-0.5"></i> Memory&lt;T&gt; / ReadOnlyMemory&lt;T&gt;
                    </h4>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-3 text-xs font-mono space-y-1">
                        <div><span class="text-purple-500">Memory</span>&lt;T&gt; Slice(<span class="text-blue-500">int</span> start)</div>
                        <div><span class="text-purple-500">Memory</span>&lt;T&gt; Slice(<span class="text-blue-500">int</span> start, <span class="text-blue-500">int</span> length)</div>
                        <div class="text-gray-500 mt-2">Same validation rules as Span&lt;T&gt;</div>
                    </div>
                </div>

                @* Range / Index *@
                <div>
                    <h4 class="text-xs font-semibold text-amber-500 mb-2 uppercase tracking-wide">
                        <i class="ti ti-arrows-horizontal mr-0.5"></i> Range / Index (C# 8+)
                    </h4>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-3 text-xs font-mono space-y-1">
                        <div>array[<span class="text-blue-500">start</span>..<span class="text-blue-500">end</span>]</div>
                        <div>array[<span class="text-blue-500">start</span>..] <span class="text-gray-500">// to end</span></div>
                        <div>array[..<span class="text-blue-500">end</span>] <span class="text-gray-500">// from start</span></div>
                        <div>array[^<span class="text-blue-500">n</span>..] <span class="text-gray-500">// last n elements</span></div>
                        <div class="text-gray-500 mt-2">start and end are inclusive-start, exclusive-end.</div>
                        <div class="text-gray-500">Throws ArgumentOutOfRangeException if out of bounds.</div>
                    </div>
                </div>

                @* ArraySegment *@
                <div>
                    <h4 class="text-xs font-semibold text-red-500 mb-2 uppercase tracking-wide">
                        <i class="ti ti-slice mr-0.5"></i> ArraySegment&lt;T&gt;
                    </h4>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-3 text-xs font-mono space-y-1">
                        <div><span class="text-blue-500">new</span> <span class="text-purple-500">ArraySegment</span>&lt;T&gt;(array, offset, count)</div>
                        <div class="text-gray-500 mt-2">Throws ArgumentOutOfRangeException when:</div>
                        <div class="text-gray-500 pl-3">- offset &lt; 0</div>
                        <div class="text-gray-500 pl-3">- count &lt; 0</div>
                        <div class="text-gray-500 pl-3">- offset + count &gt; array.Length</div>
                    </div>
                </div>

                @* String.Substring *@
                <div>
                    <h4 class="text-xs font-semibold text-cyan-500 mb-2 uppercase tracking-wide">
                        <i class="ti ti-typography mr-0.5"></i> String.Substring
                    </h4>
                    <div class="bg-gray-50 dark:bg-gray-800 rounded p-3 text-xs font-mono space-y-1">
                        <div><span class="text-blue-500">string</span> Substring(<span class="text-blue-500">int</span> startIndex)</div>
                        <div><span class="text-blue-500">string</span> Substring(<span class="text-blue-500">int</span> startIndex, <span class="text-blue-500">int</span> length)</div>
                        <div class="text-gray-500 mt-2">Throws ArgumentOutOfRangeException when:</div>
                        <div class="text-gray-500 pl-3">- startIndex &lt; 0</div>
                        <div class="text-gray-500 pl-3">- startIndex &gt; string.Length</div>
                        <div class="text-gray-500 pl-3">- startIndex + length &gt; string.Length</div>
                        <div class="text-gray-500 pl-3">- length &lt; 0</div>
                    </div>
                </div>
            </div>
        }
    </div>

</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/dev/span-slice" OnRestore="RestoreState" />

@code {
    private RecentEntryPanel? _recentPanel;
    sealed record ToolState(
        SpanSliceCalculatorCore.SliceMethod SelectedMethod,
        int BufferLength,
        int StartIndex,
        int Count
    );

    private SpanSliceCalculatorCore.SliceMethod _selectedMethod = SpanSliceCalculatorCore.SliceMethod.SpanSliceStartLength;
    private int _bufferLength = 10;
    private int _startIndex = 2;
    private int _count = 3;
    private bool _referenceExpanded;

    private bool _isValid = true;
    private int _resolvedStart;
    private int _resolvedEnd;
    private string _exceptionType = string.Empty;
    private string _exceptionMessage = string.Empty;

    private List<SpanSliceCalculatorCore.EquivalentExpression> _equivalentExpressions = [];
    private List<SpanSliceCalculatorCore.EdgeCaseRow> _edgeCases = [];

    protected override void OnInitialized() => Recalculate();

    private void Recalculate()
    {
        SpanSliceCalculatorCore.ValidationResult result = SpanSliceCalculatorCore.ValidateSlice(
            _selectedMethod, _bufferLength, _startIndex, _count);
        _isValid = result.IsValid;
        _resolvedStart = result.ResolvedStart;
        _resolvedEnd = result.ResolvedEnd;
        _exceptionType = result.ExceptionType;
        _exceptionMessage = result.ExceptionMessage;

        _equivalentExpressions = SpanSliceCalculatorCore.BuildEquivalentExpressions(
            _bufferLength, _resolvedStart, _resolvedEnd, _isValid);
        _edgeCases = SpanSliceCalculatorCore.BuildEdgeCases(_bufferLength);
    }

    private async Task CopyToClipboard(string content)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", content);
    }

    private int GetDisplayCount() => Math.Min(_bufferLength, SpanSliceCalculatorCore.MaxDisplayCells);

    private int GetExtraCells()
    {
        int overflowEnd = _isValid ? _resolvedEnd : Math.Max(_resolvedEnd, _bufferLength);
        int extra = overflowEnd > _bufferLength ? Math.Min(overflowEnd - _bufferLength, 8) : 0;
        int total = GetDisplayCount() + extra;
        if (total > SpanSliceCalculatorCore.MaxDisplayCells + 8)
        {
            extra = SpanSliceCalculatorCore.MaxDisplayCells + 8 - GetDisplayCount();
        }
        return extra;
    }

    private int GetTotalCells() => GetDisplayCount() + GetExtraCells();

    private async Task RecalculateAndSave()
    {
        Recalculate();
        await SaveState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/dev/span-slice");
            if (state is not null)
            {
                _selectedMethod = state.SelectedMethod;
                _bufferLength = state.BufferLength;
                _startIndex = state.StartIndex;
                _count = state.Count;
                Recalculate();
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/dev/span-slice", new ToolState(
            _selectedMethod,
            _bufferLength,
            _startIndex,
            _count
        ));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _selectedMethod = state.SelectedMethod;
            _bufferLength = state.BufferLength;
            _startIndex = state.StartIndex;
            _count = state.Count;
            Recalculate();
            StateHasChanged();
        }
    }
}
