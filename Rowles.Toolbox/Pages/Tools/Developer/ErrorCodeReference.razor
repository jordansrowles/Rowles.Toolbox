@page "/tools/dev/error-codes"
@using Rowles.Toolbox.Core.Developer
@inject LocalStorageService Storage

<PageTitle>Error Code Reference - Rowles.Toolbox</PageTitle>

<PageHeader Title="Error Code Reference" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-bug mr-1"></i> Searchable reference for HTTP, gRPC, Win32 &amp; HRESULT codes</span>
    </Actions>
</PageHeader>

@* ----─ Global search ----─ *@
<div class="mb-4">
    <input type="text"
           placeholder="Search all error codes by number, name, or description…"
           class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500"
           @oninput="OnSearchInput" />
</div>

@* ----─ Tabs ----─ *@
<div class="flex gap-2 mb-4 flex-wrap">
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "http" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "http"; await SaveState(); }'>
        <i class="ti ti-world mr-0.5"></i> HTTP
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "grpc" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "grpc"; await SaveState(); }'>
        <i class="ti ti-api mr-0.5"></i> gRPC
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "win32" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "win32"; await SaveState(); }'>
        <i class="ti ti-brand-windows mr-0.5"></i> Win32
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "hresult" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "hresult"; await SaveState(); }'>
        <i class="ti ti-hexagon mr-0.5"></i> HRESULT
    </button>
</div>

@{
    bool isSearching = !string.IsNullOrWhiteSpace(_searchQuery);
}

@* ----─ HTTP tab ----─ *@
@if (_activeTab == "http" || isSearching)
{
    List<ErrorCodeReferenceCore.ErrorCode> filteredHttp = isSearching
        ? ErrorCodeReferenceCore.HttpCodes.Where(c => ErrorCodeReferenceCore.MatchesSearch(c, _searchQuery)).ToList()
        : ErrorCodeReferenceCore.HttpCodes;

    if (filteredHttp.Count > 0)
    {
        if (isSearching)
        {
            <h2 class="text-sm font-semibold text-gray-500 mb-2"><i class="ti ti-world mr-1"></i> HTTP Status Codes</h2>
        }
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium w-24">Code</th>
                            <th class="text-left p-2 text-gray-500 font-medium w-48">Name</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Description</th>
                            <th class="text-left p-2 text-gray-500 font-medium w-28">Category</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ErrorCodeReferenceCore.ErrorCode entry in filteredHttp)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono font-bold @ErrorCodeReferenceCore.GetHttpCodeColor(entry.Category)">@entry.Code</td>
                                <td class="p-2 font-medium text-gray-700 dark:text-gray-300">@entry.Name</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@entry.Description</td>
                                <td class="p-2">
                                    <span class="px-2 py-0.5 rounded-full text-xs font-medium @ErrorCodeReferenceCore.GetHttpBadgeColor(entry.Category)">
                                        @entry.Category
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 text-xs text-gray-400">@filteredHttp.Count code(s)</div>
        </div>
    }
}

@* ----─ gRPC tab ----─ *@
@if (_activeTab == "grpc" || isSearching)
{
    List<ErrorCodeReferenceCore.GrpcCode> filteredGrpc = isSearching
        ? ErrorCodeReferenceCore.GrpcCodes.Where(c => ErrorCodeReferenceCore.MatchesGrpcSearch(c, _searchQuery)).ToList()
        : ErrorCodeReferenceCore.GrpcCodes;

    if (filteredGrpc.Count > 0)
    {
        if (isSearching)
        {
            <h2 class="text-sm font-semibold text-gray-500 mb-2"><i class="ti ti-api mr-1"></i> gRPC Status Codes</h2>
        }
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium w-20">Code</th>
                            <th class="text-left p-2 text-gray-500 font-medium w-44">Name</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Description</th>
                            <th class="text-left p-2 text-gray-500 font-medium w-32">HTTP Equivalent</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ErrorCodeReferenceCore.GrpcCode entry in filteredGrpc)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono font-bold text-purple-600 dark:text-purple-400">@entry.Code</td>
                                <td class="p-2 font-medium text-gray-700 dark:text-gray-300">@entry.Name</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@entry.Description</td>
                                <td class="p-2 font-mono text-xs text-gray-500 dark:text-gray-400">@entry.HttpEquivalent</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 text-xs text-gray-400">@filteredGrpc.Count code(s)</div>
        </div>
    }
}

@* ----─ Win32 tab ----─ *@
@if (_activeTab == "win32" || isSearching)
{
    List<ErrorCodeReferenceCore.ErrorCode> filteredWin32 = isSearching
        ? ErrorCodeReferenceCore.Win32Codes.Where(c => ErrorCodeReferenceCore.MatchesSearch(c, _searchQuery)).ToList()
