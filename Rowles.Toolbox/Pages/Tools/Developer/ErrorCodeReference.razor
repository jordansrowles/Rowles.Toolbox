        if (isSearching)
        {
            <h2 class="text-sm font-semibold text-gray-500 mb-2"><i class="ti ti-brand-windows mr-1"></i> Win32 Error Codes</h2>
        }
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium w-20">Code</th>
                            <th class="text-left p-2 text-gray-500 font-medium w-56">Constant</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ErrorCodeReferenceCore.ErrorCode entry in filteredWin32)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono font-bold text-amber-600 dark:text-amber-400">@entry.Code</td>
                                <td class="p-2 font-mono text-sm text-gray-700 dark:text-gray-300">@entry.Name</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@entry.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 text-xs text-gray-400">@filteredWin32.Count code(s)</div>
        </div>
    }
}

@* ----─ HRESULT tab ----─ *@
@if (_activeTab == "hresult" || isSearching)
{
    List<ErrorCodeReferenceCore.ErrorCode> filteredHresult = isSearching
        ? ErrorCodeReferenceCore.HresultCodes.Where(c => ErrorCodeReferenceCore.MatchesSearch(c, _searchQuery)).ToList()
        : ErrorCodeReferenceCore.HresultCodes;

    if (filteredHresult.Count > 0)
    {
        if (isSearching)
        {
            <h2 class="text-sm font-semibold text-gray-500 mb-2"><i class="ti ti-hexagon mr-1"></i> HRESULT Values</h2>
        }
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left p-2 text-gray-500 font-medium w-32">Value</th>
                            <th class="text-left p-2 text-gray-500 font-medium w-52">Constant</th>
                            <th class="text-left p-2 text-gray-500 font-medium">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ErrorCodeReferenceCore.ErrorCode entry in filteredHresult)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <td class="p-2 font-mono font-bold text-rose-600 dark:text-rose-400">@entry.Code</td>
                                <td class="p-2 font-mono text-sm text-gray-700 dark:text-gray-300">@entry.Name</td>
                                <td class="p-2 text-gray-600 dark:text-gray-400">@entry.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 text-xs text-gray-400">@filteredHresult.Count code(s)</div>
        </div>
    }
}

@if (isSearching)
{
    int totalResults = ErrorCodeReferenceCore.HttpCodes.Count(c => ErrorCodeReferenceCore.MatchesSearch(c, _searchQuery))
        + ErrorCodeReferenceCore.GrpcCodes.Count(c => ErrorCodeReferenceCore.MatchesGrpcSearch(c, _searchQuery))
        + ErrorCodeReferenceCore.Win32Codes.Count(c => ErrorCodeReferenceCore.MatchesSearch(c, _searchQuery))
        + ErrorCodeReferenceCore.HresultCodes.Count(c => ErrorCodeReferenceCore.MatchesSearch(c, _searchQuery));

    if (totalResults == 0)
    {
        <div class="border border-gray-200 dark:border-gray-700 rounded p-8 text-center">
            <i class="ti ti-search-off text-3xl text-gray-400 mb-2"></i>
            <p class="text-sm text-gray-500">No error codes match "<strong>@_searchQuery</strong>"</p>
        </div>
    }
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/dev/error-codes" OnRestore="RestoreState" />

@code {
    sealed record ToolState(string ActiveTab, string SearchQuery);

    private string _activeTab = "http";
    private string _searchQuery = string.Empty;
    private RecentEntryPanel? _recentPanel;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/dev/error-codes");
            if (state is not null)
            {
                _activeTab = state.ActiveTab;
                _searchQuery = state.SearchQuery;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        ToolState state = new(_activeTab, _searchQuery);
        await Storage.SaveStateAsync("tools/dev/error-codes", state);
    }

    private void RestoreState(string json)
    {
        ToolState? state = System.Text.Json.JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _activeTab = state.ActiveTab;
            _searchQuery = state.SearchQuery;
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
        await SaveState();
    }
}