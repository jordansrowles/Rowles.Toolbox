@page "/tools/text/escape"
@using System.Text
@using System.Text.RegularExpressions
@using System.Web
@using System.Text.Json
@inject IJSRuntime JS
@inject LocalStorageService Storage

<PageTitle>String Escape/Unescape - Rowles.Toolbox</PageTitle>

<PageHeader Title="String Escape/Unescape" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-code mr-1"></i> Escape &amp; unescape strings for different contexts</span>
    </Actions>
</PageHeader>

<div class="flex flex-wrap items-center gap-3 mb-4">
    <label class="text-xs font-medium text-gray-500">Mode:</label>
    <select class="text-xs border border-gray-300 dark:border-gray-600 rounded px-2 py-1 bg-white dark:bg-gray-800 focus:outline-none focus:ring-1 focus:ring-blue-500"
            @bind="_selectedMode"
            @bind:after="SaveState">
        <option value="Json">JSON</option>
        <option value="XmlHtml">XML / HTML</option>
        <option value="CSharp">C# String</option>
        <option value="Regex">Regex</option>
        <option value="Url">URL</option>
    </select>

    <button class="bg-blue-600 text-white px-3 py-1.5 text-xs font-medium rounded hover:bg-blue-700 transition-colors inline-flex items-center gap-1 cursor-pointer border-none"
            @onclick="Escape">
        <i class="ti ti-arrow-right"></i> Escape
    </button>
    <button class="bg-blue-600 text-white px-3 py-1.5 text-xs font-medium rounded hover:bg-blue-700 transition-colors inline-flex items-center gap-1 cursor-pointer border-none"
            @onclick="Unescape">
        <i class="ti ti-arrow-left"></i> Unescape
    </button>
    <button class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-medium rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors inline-flex items-center gap-1 cursor-pointer border-none"
            @onclick="CopyOutput">
        <i class="ti ti-copy"></i> @(_copied ? "Copied!" : "Copy")
    </button>
    <button class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-medium rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors inline-flex items-center gap-1 cursor-pointer border-none"
            @onclick="Clear">
        <i class="ti ti-trash"></i> Clear
    </button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 p-3 rounded text-xs mb-3">
        <i class="ti ti-alert-circle mr-1"></i> @_error
    </div>
}

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
        <label class="block text-sm font-medium mb-1">Input</label>
        <textarea class="w-full h-64 p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono resize-y focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Paste or type your string here…"
                  @bind="_input"
                  @bind:event="oninput"
                  @bind:after="SaveState"></textarea>
    </div>
    <div>
        <div class="flex items-center justify-between mb-1">
            <label class="block text-sm font-medium">Output</label>
            @if (!string.IsNullOrEmpty(_output))
            {
                <span class="text-xs text-gray-400">@_output.Length.ToString("N0") chars</span>
            }
        </div>
        <textarea class="w-full h-64 p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono resize-y focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  readonly
                  @bind="_output"></textarea>
    </div>
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/text/escape" OnRestore="RestoreState" />

@code {
    private string _input = string.Empty;
    private string _output = string.Empty;
    private string _selectedMode = "Json";
    private string? _error;
    private bool _copied;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(string Input, string SelectedMode);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/text/escape");
            if (state is not null)
            {
                _input = state.Input;
                _selectedMode = state.SelectedMode;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/text/escape", new ToolState(_input, _selectedMode));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _input = state.Input;
            _selectedMode = state.SelectedMode;
            _output = string.Empty;
            _error = null;
            StateHasChanged();
        }
    }

    private async Task Escape()
    {
        _error = null;
        _copied = false;

        if (string.IsNullOrEmpty(_input))
        {
            _error = "Input is empty.";
            return;
        }

        try
        {
            _output = Core.Text.StringEscapeCore.Escape(_input, _selectedMode);

            string label = _input.Length > 50 ? _input[..50] + "..." : _input;
            await Storage.AddRecentAsync("tools/text/escape", label, new ToolState(_input, _selectedMode));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = $"Escape failed: {ex.Message}";
        }
    }

    private async Task Unescape()
    {
        _error = null;
        _copied = false;

        if (string.IsNullOrEmpty(_input))
        {
            _error = "Input is empty.";
            return;
        }

        try
        {
            _output = Core.Text.StringEscapeCore.Unescape(_input, _selectedMode);

            string label = _input.Length > 50 ? _input[..50] + "..." : _input;
            await Storage.AddRecentAsync("tools/text/escape", label, new ToolState(_input, _selectedMode));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = $"Unescape failed: {ex.Message}";
        }
    }

    private async Task CopyOutput()
    {
        if (!string.IsNullOrEmpty(_output))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _output);
            _copied = true;
            StateHasChanged();
            await Task.Delay(1500);
            _copied = false;
            StateHasChanged();
        }
    }

    private void Clear()
    {
        _input = string.Empty;
        _output = string.Empty;
        _error = null;
        _copied = false;
    }
}