@page "/tools/text/counter"
@inject LocalStorageService Storage

<PageTitle>Text Counter - Rowles.Toolbox</PageTitle>

<PageHeader Title="Text Counter" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-calculator mr-1"></i> Character, word &amp; sentence statistics</span>
    </Actions>
</PageHeader>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2">
        <label class="block text-sm font-medium mb-1">Input Text</label>
        <textarea class="w-full h-64 p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono resize-y focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Type or paste your text here…"
                  @bind="_inputText"
                  @bind:event="oninput"
                  @bind:after="SaveState"></textarea>

        <div class="mt-3 flex items-center gap-3">
            <label class="flex items-center gap-1 text-sm">
                <input type="checkbox" class="rounded" @bind="_filterEnabled" @bind:after="SaveState" />
                Count specific character
            </label>
            @if (_filterEnabled)
            {
                <input type="text" maxlength="1" class="w-12 p-1 border border-gray-300 dark:border-gray-600 rounded text-center text-sm bg-white dark:bg-gray-800"
                       placeholder="a"
                       @bind="_filterChar"
                       @bind:event="oninput"
                       @bind:after="SaveState" />
                <span class="text-sm text-gray-500">
                    Occurrences: <strong class="text-blue-600 dark:text-blue-400">@FilteredCharCount</strong>
                </span>
            }
        </div>
    </div>

    <div class="space-y-3">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-list-numbers mr-1"></i> Statistics</h3>
            <div class="space-y-2">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400"><i class="ti ti-letter-case mr-1 text-gray-400"></i> Characters (with spaces)</span>
                    <span class="font-bold">@Characters.ToString("N0")</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400"><i class="ti ti-letter-case-lower mr-1 text-gray-400"></i> Characters (no spaces)</span>
                    <span class="font-bold">@CharactersNoSpaces.ToString("N0")</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400"><i class="ti ti-vocabulary mr-1 text-gray-400"></i> Words</span>
                    <span class="font-bold">@Words.ToString("N0")</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400"><i class="ti ti-dots mr-1 text-gray-400"></i> Sentences</span>
                    <span class="font-bold">@Sentences.ToString("N0")</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400"><i class="ti ti-align-left mr-1 text-gray-400"></i> Paragraphs</span>
                    <span class="font-bold">@Paragraphs.ToString("N0")</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-600 dark:text-gray-400"><i class="ti ti-line-height mr-1 text-gray-400"></i> Lines</span>
                    <span class="font-bold">@Lines.ToString("N0")</span>
                </div>
            </div>
        </div>

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-2"><i class="ti ti-clock mr-1"></i> Reading Time</h3>
            <p class="text-lg font-bold text-blue-600 dark:text-blue-400">@ReadingTime</p>
            <p class="text-xs text-gray-400">Based on 200 words per minute</p>
        </div>
    </div>
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/text/counter" OnRestore="RestoreState" />

@code {
    private string _inputText = string.Empty;
    private bool _filterEnabled;
    private string _filterChar = string.Empty;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(string InputText, bool FilterEnabled, string FilterChar);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/text/counter");
            if (state is not null)
            {
                _inputText = state.InputText;
                _filterEnabled = state.FilterEnabled;
                _filterChar = state.FilterChar;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/text/counter", new ToolState(_inputText, _filterEnabled, _filterChar));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _inputText = state.InputText;
            _filterEnabled = state.FilterEnabled;
            _filterChar = state.FilterChar;
            StateHasChanged();
        }
    }

    private int Characters => Core.Text.TextCounterCore.CountCharacters(_inputText);
    private int CharactersNoSpaces => Core.Text.TextCounterCore.CountCharactersNoSpaces(_inputText);
    private int Words => Core.Text.TextCounterCore.CountWords(_inputText);
    private int Sentences => Core.Text.TextCounterCore.CountSentences(_inputText);
    private int Paragraphs => Core.Text.TextCounterCore.CountParagraphs(_inputText);
    private int Lines => Core.Text.TextCounterCore.CountLines(_inputText);
    private string ReadingTime => Core.Text.TextCounterCore.CalculateReadingTime(Words);
    private int FilteredCharCount => Core.Text.TextCounterCore.CountFilteredChar(_inputText, _filterChar);
}