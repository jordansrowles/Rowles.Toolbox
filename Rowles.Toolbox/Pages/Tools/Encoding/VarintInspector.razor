@page "/tools/encoding/varint"
@using Rowles.Toolbox.Core.Encoding
@inject IJSRuntime JS
@inject LocalStorageService Storage

<PageTitle>Varint Inspector - Rowles.Toolbox</PageTitle>

<PageHeader Title="Varint Inspector" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-binary mr-1"></i> Encode/decode protobuf-style variable-length integers</span>
    </Actions>
</PageHeader>

@* Mode and encoding toggles *@
<div class="flex flex-wrap items-center gap-3 mb-4">
    <div class="inline-flex rounded-md overflow-hidden border border-gray-300 dark:border-gray-600">
        <button type="button"
                class="@(_mode == "encode" ? "bg-blue-600 text-white" : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700") px-3 py-1.5 text-xs font-medium border-none cursor-pointer"
                @onclick="SetEncodeMode">
            <i class="ti ti-arrow-right mr-0.5"></i> Encode
        </button>
        <button type="button"
                class="@(_mode == "decode" ? "bg-blue-600 text-white" : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700") px-3 py-1.5 text-xs font-medium border-none cursor-pointer"
                @onclick="SetDecodeMode">
            <i class="ti ti-arrow-left mr-0.5"></i> Decode
        </button>
    </div>
    <label class="flex items-center gap-1.5 cursor-pointer select-none">
        <input type="checkbox"
               class="rounded border-gray-300 dark:border-gray-600"
               @bind="_useZigZag"
               @bind:after="OnZigZagChanged" />
        <span class="text-xs">ZigZag signed (sint32/sint64)</span>
    </label>
</div>

@* Input field *@
<div class="mb-4">
    @if (_mode == "encode")
    {
        <label class="block text-sm font-medium mb-1">
            @(_useZigZag ? "Signed Integer (long)" : "Unsigned Integer (ulong)")
        </label>
        <input type="text"
               class="w-full max-w-md p-2 text-sm font-mono border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="@(_useZigZag ? "Enter a signed integer (e.g. -1, 300)" : "Enter an unsigned integer (e.g. 300)")"
               @bind="_inputText"
               @bind:event="oninput"
               @bind:after="OnInputChanged" />
    }
    else
    {
        <label class="block text-sm font-medium mb-1">Hex Bytes (space-separated)</label>
        <input type="text"
               class="w-full max-w-md p-2 text-sm font-mono border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="e.g. AC 02"
               @bind="_inputText"
               @bind:event="oninput"
               @bind:after="OnInputChanged" />
    }
</div>

@* Quick examples *@
<div class="flex flex-wrap items-center gap-1.5 mb-4">
    <span class="text-xs text-gray-500 mr-1"><i class="ti ti-sparkles mr-0.5"></i> Examples:</span>
    <button type="button" class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer font-mono"
            @onclick="LoadVal0">0</button>
    <button type="button" class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer font-mono"
            @onclick="LoadVal1">1</button>
    <button type="button" class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer font-mono"
            @onclick="LoadVal127">127</button>
    <button type="button" class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer font-mono"
            @onclick="LoadVal128">128</button>
    <button type="button" class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer font-mono"
            @onclick="LoadVal300">300</button>
    <button type="button" class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer font-mono"
            @onclick="LoadVal16384">16384</button>
    <button type="button" class="px-2 py-1 text-xs bg-amber-50 dark:bg-amber-900/20 border border-amber-300 dark:border-amber-700 rounded hover:bg-amber-100 dark:hover:bg-amber-900/40 cursor-pointer font-mono"
            @onclick="LoadValNeg1ZigZag">-1 (zigzag)</button>
</div>

@* Action buttons *@
<div class="flex flex-wrap items-center gap-2 mb-4">
    <button type="button" class="bg-blue-600 text-white px-3 py-1.5 text-xs rounded hover:bg-blue-700 cursor-pointer border-none"
            @onclick="ProcessInput">
        <i class="ti ti-player-play mr-0.5"></i> Process
    </button>
    @if (_hasResult)
    {
        <button type="button" class="px-3 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
                @onclick="CopyHex">
            <i class="ti ti-copy mr-0.5"></i> Copy Hex
        </button>
        <button type="button" class="px-3 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
                @onclick="CopyValue">
            <i class="ti ti-copy mr-0.5"></i> Copy Value
        </button>
    }
    <button type="button" class="px-3 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
            @onclick="Clear">
        <i class="ti ti-eraser mr-0.5"></i> Clear
    </button>
</div>

@* Error display *@
@if (!string.IsNullOrEmpty(_error))
{
    <div class="mb-4 p-2 text-sm bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 border border-red-300 dark:border-red-700 rounded">
        <i class="ti ti-alert-triangle mr-0.5"></i> @_error
    </div>
}

@* Results *@
@if (_hasResult)
{
    @* Summary cards *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-3">
            <h3 class="text-xs font-semibold text-gray-500 mb-1.5">
                <i class="ti ti-number mr-1"></i> Decoded Value
            </h3>
            <div class="flex items-center gap-2">
                <span class="text-lg font-mono font-bold">@_displayValue</span>
                <button type="button"
                        class="px-1.5 py-0.5 text-[10px] border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
                        @onclick="CopyValue">
                    <i class="ti ti-copy"></i>
                </button>
            </div>
            @if (_useZigZag)
            {
                <div class="text-xs text-gray-500 mt-1">
                    ZigZag mapped unsigned: <span class="font-mono font-semibold">@_zigZagMapped</span>
                </div>
            }
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded p-3">
            <h3 class="text-xs font-semibold text-gray-500 mb-1.5">
                <i class="ti ti-binary mr-1"></i> Varint Hex
            </h3>
            <div class="flex items-center gap-2">
                <span class="text-lg font-mono font-bold tracking-wider">@_hexOutput</span>
                <button type="button"
                        class="px-1.5 py-0.5 text-[10px] border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
                        @onclick="CopyHex">
                    <i class="ti ti-copy"></i>
                </button>
            </div>
            <div class="text-xs text-gray-500 mt-1">
                @_varintByteCount byte@(_varintByteCount != 1 ? "s" : "")
            </div>
        </div>
    </div>

    @* Byte breakdown table *@
    <div class="border border-gray-200 dark:border-gray-700 rounded overflow-hidden mb-4">
        <h3 class="text-xs font-semibold text-gray-500 px-3 py-2 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
            <i class="ti ti-table mr-1"></i> Byte Breakdown
        </h3>
        <div class="overflow-x-auto">
            <table class="w-full text-xs">
                <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-left text-gray-500">
                        <th class="px-3 py-1.5 font-medium">Byte #</th>
                        <th class="px-3 py-1.5 font-medium">Hex</th>
                        <th class="px-3 py-1.5 font-medium">Binary (MSB | 7 data bits)</th>
                        <th class="px-3 py-1.5 font-medium">MSB</th>
                        <th class="px-3 py-1.5 font-medium">Data Bits</th>
                        <th class="px-3 py-1.5 font-medium">Running Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (VarintInspectorCore.VarintByteInfo info in _byteInfos)
                    {
                        <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/30">
                            <td class="px-3 py-1.5 font-mono">@info.ByteIndex</td>
                            <td class="px-3 py-1.5 font-mono">0x@(info.RawValue.ToString("X2"))</td>
                            <td class="px-3 py-1.5 font-mono">
                                <span class="@(info.HasContinuation ? "text-red-500 font-bold" : "text-green-500 font-bold")">@(info.HasContinuation ? "1" : "0")</span><span class="text-gray-400 mx-px">|</span>@FormatBinary7(info.SevenBitPayload)
                            </td>
                            <td class="px-3 py-1.5">
                                @if (info.HasContinuation)
                                {
                                    <span class="text-red-500 font-medium">1 (more)</span>
                                }
                                else
                                {
                                    <span class="text-green-500 font-medium">0 (last)</span>
                                }
                            </td>
                            <td class="px-3 py-1.5 font-mono text-blue-600 dark:text-blue-400">@FormatBinary7(info.SevenBitPayload)</td>
                            <td class="px-3 py-1.5 font-mono font-semibold">@info.RunningTotal</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Seven bit group reassembly visualization *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-3 mb-4">
        <h3 class="text-xs font-semibold text-gray-500 mb-2">
            <i class="ti ti-arrows-join mr-1"></i> 7-bit Group Reassembly (little-endian)
        </h3>
        <div class="space-y-1 text-xs font-mono">
            @for (int idx = _byteInfos.Count - 1; idx >= 0; idx--)
            {
                VarintInspectorCore.VarintByteInfo currentByte = _byteInfos[idx];
                <div class="flex items-center gap-2">
                    <span class="text-gray-500 w-16 text-right shrink-0">Byte @currentByte.ByteIndex:</span>
                    <span class="text-blue-600 dark:text-blue-400">@FormatBinary7(currentByte.SevenBitPayload)</span>
                    <span class="text-gray-400 text-[10px]">(@currentByte.SevenBitPayload)</span>
                </div>
            }
        </div>
        <div class="mt-2 pt-2 border-t border-gray-200 dark:border-gray-700 text-xs font-mono flex flex-wrap items-center gap-1.5">
            <span class="text-gray-500">Combined:</span>
            <span class="font-bold text-blue-600 dark:text-blue-400">@GetConcatenatedBits()</span>
            <span class="text-gray-400">=</span>
            <span class="font-bold">@_rawUnsignedValue</span>
            @if (_useZigZag)
            {
                <span class="text-gray-400">(unsigned)</span>
                <span class="text-gray-400">→</span>
                <span class="font-bold text-amber-600 dark:text-amber-400">@_signedValue</span>
                <span class="text-gray-400">(signed)</span>
            }
        </div>
    </div>

    @* ZigZag encoding details *@
    @if (_useZigZag)
    {
        <div class="border border-amber-200 dark:border-amber-700 rounded p-3 mb-4 bg-amber-50/50 dark:bg-amber-900/10">
            <h3 class="text-xs font-semibold text-amber-700 dark:text-amber-400 mb-2">
                <i class="ti ti-arrows-shuffle mr-1"></i> ZigZag Encoding Details
            </h3>
            <div class="text-xs space-y-1.5">
                <div>
                    <span class="text-gray-600 dark:text-gray-400">Encode formula:</span>
                    <code class="font-mono ml-1 px-1.5 py-0.5 bg-amber-100 dark:bg-amber-900/30 rounded text-amber-800 dark:text-amber-300">(n &lt;&lt; 1) ^ (n &gt;&gt; 63)</code>
                </div>
                <div>
                    <span class="text-gray-600 dark:text-gray-400">Decode formula:</span>
                    <code class="font-mono ml-1 px-1.5 py-0.5 bg-amber-100 dark:bg-amber-900/30 rounded text-amber-800 dark:text-amber-300">(n &gt;&gt;&gt; 1) ^ -(n &amp; 1)</code>
                </div>
                <div class="pt-1.5 border-t border-amber-200 dark:border-amber-800 space-y-0.5">
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">Signed value:</span>
                        <span class="font-mono font-bold ml-1">@_signedValue</span>
                    </div>
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">ZigZag mapped (unsigned):</span>
                        <span class="font-mono font-bold ml-1">@_zigZagMapped</span>
                    </div>
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">Mapping:</span>
                        <span class="font-mono ml-1">@_signedValue → @_zigZagMapped → varint [@_hexOutput]</span>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Size comparison table *@
    <div class="border border-gray-200 dark:border-gray-700 rounded overflow-hidden">
        <h3 class="text-xs font-semibold text-gray-500 px-3 py-2 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
            <i class="ti ti-ruler-measure mr-1"></i> Size Comparison
        </h3>
        <table class="w-full text-xs">
            <thead>
                <tr class="border-b border-gray-200 dark:border-gray-700 text-left text-gray-500">
                    <th class="px-3 py-1.5 font-medium">Encoding</th>
                    <th class="px-3 py-1.5 font-medium">Bytes</th>
                    <th class="px-3 py-1.5 font-medium">Bits</th>
                    <th class="px-3 py-1.5 font-medium">vs fixed64</th>
                </tr>
            </thead>
            <tbody>
                <tr class="border-b border-gray-100 dark:border-gray-800">
                    <td class="px-3 py-1.5 font-medium">Varint (LEB128)</td>
                    <td class="px-3 py-1.5 font-mono font-bold text-blue-600 dark:text-blue-400">@_varintByteCount</td>
                    <td class="px-3 py-1.5 font-mono">@(_varintByteCount * 8)</td>
                    <td class="px-3 py-1.5 font-mono">@FormatSavings(_varintByteCount, 8)</td>
                </tr>
                <tr class="border-b border-gray-100 dark:border-gray-800">
                    <td class="px-3 py-1.5 font-medium">Fixed 32-bit (int)</td>
                    <td class="px-3 py-1.5 font-mono">4</td>
                    <td class="px-3 py-1.5 font-mono">32</td>
                    <td class="px-3 py-1.5 font-mono">@FormatSavings(4, 8)</td>
                </tr>
                <tr>
                    <td class="px-3 py-1.5 font-medium">Fixed 64-bit (long)</td>
                    <td class="px-3 py-1.5 font-mono">8</td>
                    <td class="px-3 py-1.5 font-mono">64</td>
                    <td class="px-3 py-1.5 font-mono text-gray-400">baseline</td>
                </tr>
            </tbody>
        </table>
    </div>
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/encoding/varint" OnRestore="RestoreState" />

@code {
    string _mode = "encode";
    bool _useZigZag;
    string _inputText = string.Empty;
    string? _error;
    bool _hasResult;
    RecentEntryPanel? _recentPanel;

    sealed record ToolState(string InputText, string Mode, bool UseZigZag);

    List<VarintInspectorCore.VarintByteInfo> _byteInfos = new();
    string _hexOutput = string.Empty;
    string _displayValue = string.Empty;
    ulong _rawUnsignedValue;
    long _signedValue;
    ulong _zigZagMapped;
    int _varintByteCount;

    void SetEncodeMode()
    {
        _mode = "encode";
        Clear();
    }

    void SetDecodeMode()
    {
        _mode = "decode";
        Clear();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/encoding/varint");
            if (state is not null)
            {
                _inputText = state.InputText;
                _mode = state.Mode;
                _useZigZag = state.UseZigZag;
                StateHasChanged();
            }
        }
    }

    async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/encoding/varint", new ToolState(_inputText, _mode, _useZigZag));
    }

    async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _inputText = state.InputText;
            _mode = state.Mode;
            _useZigZag = state.UseZigZag;
            StateHasChanged();
        }
    }

    async Task OnInputChanged()
    {
        ProcessInput();
        await SaveState();
    }

    async Task OnZigZagChanged()
    {
        ProcessInput();
        await SaveState();
    }

    void ProcessInput()
    {
        _error = null;
        _hasResult = false;
        _byteInfos = new();
        _hexOutput = string.Empty;
        _displayValue = string.Empty;

        if (string.IsNullOrWhiteSpace(_inputText))
            return;

        if (_mode == "encode")
            EncodeFromDecimal();
        else
            DecodeFromHex();
    }

    void EncodeFromDecimal()
    {
        ulong valueToEncode;

        if (_useZigZag)
        {
            if (!long.TryParse(_inputText.Trim(), out long signedVal))
            {
                _error = "Invalid signed integer. Accepted range: -9223372036854775808 to 9223372036854775807.";
                return;
            }
            _signedValue = signedVal;
            valueToEncode = VarintInspectorCore.ZigZagEncode(signedVal);
            _zigZagMapped = valueToEncode;
        }
        else
        {
            if (!ulong.TryParse(_inputText.Trim(), out ulong unsignedVal))
            {
                _error = "Invalid unsigned integer. Accepted range: 0 to 18446744073709551615.";
                return;
            }
            valueToEncode = unsignedVal;
        }

        _rawUnsignedValue = valueToEncode;
        List<byte> encoded = VarintInspectorCore.EncodeVarintBytes(valueToEncode);
        _byteInfos = VarintInspectorCore.BuildByteInfoList(encoded);
        _hexOutput = string.Join(" ", encoded.Select(static b => b.ToString("X2")));
        _varintByteCount = encoded.Count;
        _displayValue = _useZigZag ? _signedValue.ToString() : valueToEncode.ToString();
        _hasResult = true;
    }

    void DecodeFromHex()
    {
        (List<byte>? bytes, string? parseError) = VarintInspectorCore.ParseHexInput(_inputText);
        if (parseError is not null)
        {
            _error = parseError;
            return;
        }
        if (bytes is null) return;

        ulong decoded = VarintInspectorCore.DecodeVarint(bytes);

        _rawUnsignedValue = decoded;
        _byteInfos = VarintInspectorCore.BuildByteInfoList(bytes);
        _hexOutput = string.Join(" ", bytes.Select(static b => b.ToString("X2")));
        _varintByteCount = bytes.Count;

        if (_useZigZag)
        {
            _signedValue = VarintInspectorCore.ZigZagDecode(decoded);
            _zigZagMapped = decoded;
            _displayValue = _signedValue.ToString();
        }
        else
        {
            _displayValue = decoded.ToString();
        }

        _hasResult = true;
    }

    string GetConcatenatedBits() => VarintInspectorCore.GetConcatenatedBits(_byteInfos);

    static string FormatBinary7(byte value) => VarintInspectorCore.FormatBinary7(value);

    static string FormatSavings(int encodingBytes, int baseline) => VarintInspectorCore.FormatSavings(encodingBytes, baseline);

    async Task LoadExample(string value, bool zigzag)
    {
        _useZigZag = zigzag;
        _mode = "encode";
        _inputText = value;
        ProcessInput();
        await SaveState();
        if (_hasResult)
        {
            await Storage.AddRecentAsync("tools/encoding/varint", $"Varint: {value}", new ToolState(_inputText, _mode, _useZigZag));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
    }

    async Task LoadVal0() => await LoadExample("0", false);
    async Task LoadVal1() => await LoadExample("1", false);
    async Task LoadVal127() => await LoadExample("127", false);
    async Task LoadVal128() => await LoadExample("128", false);
    async Task LoadVal300() => await LoadExample("300", false);
    async Task LoadVal16384() => await LoadExample("16384", false);
    async Task LoadValNeg1ZigZag() => await LoadExample("-1", true);

    async Task CopyToClipboard(string content)
    {
        if (!string.IsNullOrEmpty(content))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
    }

    async Task CopyHex() => await CopyToClipboard(_hexOutput);
    async Task CopyValue() => await CopyToClipboard(_displayValue);

    void Clear()
    {
        _inputText = string.Empty;
        _error = null;
        _hasResult = false;
        _byteInfos = new();
        _hexOutput = string.Empty;
        _displayValue = string.Empty;
        _rawUnsignedValue = 0;
        _signedValue = 0;
        _zigZagMapped = 0;
        _varintByteCount = 0;
    }
}
