@page "/tools/encoding/jwt"
@using Rowles.Toolbox.Core.Encoding
@inject IJSRuntime JS
@inject LocalStorageService Storage

<PageTitle>JWT Decoder - Rowles.Toolbox</PageTitle>

<PageHeader Title="JWT Decoder" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-key mr-1"></i> Decode &amp; inspect JSON Web Tokens</span>
    </Actions>
</PageHeader>

<div>
    <label class="block text-sm font-medium mb-1">JWT Token</label>
    <textarea class="w-full h-32 p-2 text-sm font-mono border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 resize-y focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              @bind="_jwtInput" @bind:event="oninput" @bind:after="SaveState"
              placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.dozjgNryP4J3jVmNHl0w5N_XgL0n3I9PlFUP0THsR8U"></textarea>
</div>

<div class="flex flex-wrap items-center gap-2 mt-3">
    <button type="button" class="bg-blue-600 text-white px-3 py-1.5 text-xs rounded hover:bg-blue-700 cursor-pointer border-none"
            @onclick="DecodeJwt">
        <i class="ti ti-lock-open mr-0.5"></i> Decode
    </button>
    <button type="button" class="px-3 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
            @onclick="Clear">
        <i class="ti ti-eraser mr-0.5"></i> Clear
    </button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="mt-3 p-2 text-sm bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 border border-red-300 dark:border-red-700 rounded">
        <i class="ti ti-alert-triangle mr-0.5"></i> @_error
    </div>
}

@if (!string.IsNullOrEmpty(_headerJson))
{
    <div class="mt-4 space-y-4">
        @* Header *@
        <div>
            <div class="flex items-center justify-between mb-1">
                <h3 class="text-sm font-semibold text-blue-600 dark:text-blue-400">
                    <i class="ti ti-code mr-0.5"></i> Header
                </h3>
                <button type="button" class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer"
                        @onclick="() => CopyToClipboard(_headerJson!)">
                    <i class="ti ti-copy mr-0.5"></i> Copy
                </button>
            </div>
            <pre class="p-3 text-sm font-mono bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded overflow-x-auto whitespace-pre-wrap">@_headerJson</pre>
        </div>

        @* Payload *@
        <div>
            <div class="flex items-center justify-between mb-1">
                <h3 class="text-sm font-semibold text-green-600 dark:text-green-400">
                    <i class="ti ti-code mr-0.5"></i> Payload
                </h3>
                <button type="button" class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer"
                        @onclick="() => CopyToClipboard(_payloadJson!)">
                    <i class="ti ti-copy mr-0.5"></i> Copy
                </button>
            </div>
            <pre class="p-3 text-sm font-mono bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded overflow-x-auto whitespace-pre-wrap">@_payloadJson</pre>

            @if (_expiryTime.HasValue)
            {
                <div class="mt-2 flex items-center gap-2 text-xs">
                    <span class="text-gray-500"><i class="ti ti-clock mr-0.5"></i> Expires:</span>
                    <span>@_expiryTime.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                    @if (_isExpired)
                    {
                        <span class="px-1.5 py-0.5 rounded bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 font-medium">Expired</span>
                    }
                    else
                    {
                        <span class="px-1.5 py-0.5 rounded bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 font-medium">Valid</span>
                    }
                </div>
            }
            @if (_issuedAt.HasValue)
            {
                <div class="mt-1 flex items-center gap-2 text-xs">
                    <span class="text-gray-500"><i class="ti ti-calendar mr-0.5"></i> Issued at:</span>
                    <span>@_issuedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                </div>
            }
        </div>

        @* Signature *@
        <div>
            <h3 class="text-sm font-semibold text-red-600 dark:text-red-400 mb-1">
                <i class="ti ti-lock mr-0.5"></i> Signature
            </h3>
            <pre class="p-3 text-sm font-mono bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded overflow-x-auto break-all">@_signatureRaw</pre>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                <i class="ti ti-info-circle mr-0.5"></i> Signature verification is not performed (client-side only).
            </p>
        </div>
    </div>
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/encoding/jwt" OnRestore="RestoreState" />

@code {
    private string _jwtInput = string.Empty;
    private string? _headerJson;
    private string? _payloadJson;
    private string? _signatureRaw;
    private string? _error;
    private DateTimeOffset? _expiryTime;
    private DateTimeOffset? _issuedAt;
    private bool _isExpired;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(string JwtInput);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/encoding/jwt");
            if (state is not null)
            {
                _jwtInput = state.JwtInput;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/encoding/jwt", new ToolState(_jwtInput));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _jwtInput = state.JwtInput;
            StateHasChanged();
        }
    }

    private async Task DecodeJwt()
    {
        _error = null;
        _headerJson = null;
        _payloadJson = null;
        _signatureRaw = null;
        _expiryTime = null;
        _issuedAt = null;
        _isExpired = false;

        string token = _jwtInput.Trim();
        if (string.IsNullOrEmpty(token)) return;

        string[] parts = token.Split('.');
        if (parts.Length != 3)
        {
            _error = "Invalid JWT: expected 3 parts separated by dots (header.payload.signature).";
            return;
        }

        try
        {
            _headerJson = JwtDecoderCore.PrettyPrintJson(JwtDecoderCore.Base64UrlDecodeToString(parts[0]));
        }
        catch
        {
            _error = "Invalid JWT: header is not valid Base64url-encoded JSON.";
            return;
        }

        try
        {
            string payloadJson = JwtDecoderCore.Base64UrlDecodeToString(parts[1]);
            _payloadJson = JwtDecoderCore.PrettyPrintJson(payloadJson);
            (DateTimeOffset? expiry, DateTimeOffset? issuedAt, bool isExpired) = JwtDecoderCore.ParseClaims(payloadJson);
            _expiryTime = expiry;
            _issuedAt = issuedAt;
            _isExpired = isExpired;
        }
        catch
        {
            _error = "Invalid JWT: payload is not valid Base64url-encoded JSON.";
            return;
        }

        _signatureRaw = parts[2];
    }

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private void Clear()
    {
        _jwtInput = string.Empty;
        _headerJson = null;
        _payloadJson = null;
        _signatureRaw = null;
        _error = null;
        _expiryTime = null;
        _issuedAt = null;
        _isExpired = false;
    }
}