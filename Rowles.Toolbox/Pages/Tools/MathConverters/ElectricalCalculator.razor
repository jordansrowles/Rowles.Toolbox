@page "/tools/math/electrical"
@namespace Rowles.Toolbox.Pages.Tools.MathConverters
@using Rowles.Toolbox.Core.MathConverters
@inject IJSRuntime JS
@inject LocalStorageService Storage
@using System.Globalization

<PageTitle>Electrical Calculator - Rowles.Toolbox</PageTitle>

<PageHeader Title="Electrical Calculator" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-bolt mr-1"></i> Ohm's Law, resistance, capacitance, inductance</span>
    </Actions>
</PageHeader>

<div class="space-y-4">

    @* Tab buttons *@
    <div class="flex flex-wrap gap-2">
        @foreach (ElectricalCalculatorCore.CalcTab tab in Enum.GetValues<ElectricalCalculatorCore.CalcTab>())
        {
            <button type="button" class="@TabCss(tab)" @onclick="() => _activeTab = tab">
                <i class="ti @TabIcon(tab) mr-1"></i> @TabLabel(tab)
            </button>
        }
    </div>

    @switch (_activeTab)
    {
        @* ============================================================ *@
        @* TAB 1: Ohm's Law                                             *@
        @* ============================================================ *@
        case ElectricalCalculatorCore.CalcTab.OhmsLaw:
            @* Inputs *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">
                    <i class="ti ti-bolt mr-1"></i> Enter any 2 values
                </h3>
                <p class="text-xs text-gray-400 mb-3">Supports SI prefixes: p, n, u, m, k, M, G (e.g. 4.7k = 4700)</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium mb-1">Voltage (V)</label>
                        <div class="flex items-center gap-2">
                            <input type="text" inputmode="decimal" placeholder="e.g. 12 or 5k"
                                   class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                   @bind="_ohmV" @bind:event="oninput" @bind:after="SaveState" />
                            <span class="text-xs text-gray-400 w-6 shrink-0">V</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">Current (I)</label>
                        <div class="flex items-center gap-2">
                            <input type="text" inputmode="decimal" placeholder="e.g. 0.5 or 500m"
                                   class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                   @bind="_ohmI" @bind:event="oninput" @bind:after="SaveState" />
                            <span class="text-xs text-gray-400 w-6 shrink-0">A</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">Resistance (R)</label>
                        <div class="flex items-center gap-2">
                            <input type="text" inputmode="decimal" placeholder="e.g. 4.7k or 1M"
                                   class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                   @bind="_ohmR" @bind:event="oninput" @bind:after="SaveState" />
                            <span class="text-xs text-gray-400 w-6 shrink-0">&Omega;</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">Power (P)</label>
                        <div class="flex items-center gap-2">
                            <input type="text" inputmode="decimal" placeholder="e.g. 0.25 or 100m"
                                   class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                   @bind="_ohmP" @bind:event="oninput" @bind:after="SaveState" />
                            <span class="text-xs text-gray-400 w-6 shrink-0">W</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100 dark:border-gray-800">
                    <span class="text-xs @(OhmFilledCount() == 2 ? "text-green-500 font-semibold" : "text-gray-400")">
                        @OhmFilledCount() / 2 values entered
                    </span>
                    <div class="flex gap-2">
                        <button type="button"
                                class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                                @onclick="ClearOhm">
                            <i class="ti ti-refresh mr-1"></i>Clear
                        </button>
                        <button type="button"
                                class="px-3 py-1.5 text-xs font-medium rounded transition-colors @(OhmFilledCount() == 2 ? "bg-blue-600 hover:bg-blue-700 text-white cursor-pointer" : "bg-blue-300 dark:bg-blue-900/50 text-white cursor-not-allowed")"
                                disabled="@(OhmFilledCount() != 2)"
                                @onclick="SolveOhm">
                            <i class="ti ti-calculator mr-1"></i>Calculate
                        </button>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_ohmError))
            {
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded p-3 flex items-start gap-2">
                    <i class="ti ti-alert-circle text-red-500 mt-0.5 shrink-0"></i>
                    <span class="text-sm text-red-700 dark:text-red-400">@_ohmError</span>
                </div>
            }

            @if (_ohmSolved)
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4 mb-4 space-y-3">
                    <div class="flex items-center justify-between">
                        <h3 class="text-sm font-semibold text-gray-500">
                            <i class="ti ti-circle-check text-green-500 mr-1"></i> Results
                        </h3>
                        <button type="button"
                                class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                                @onclick="CopyOhm">
                            <i class="ti @(_copiedTab == ElectricalCalculatorCore.CalcTab.OhmsLaw ? "ti-check text-green-500" : "ti-clipboard") mr-1"></i>
                            @(_copiedTab == ElectricalCalculatorCore.CalcTab.OhmsLaw ? "Copied" : "Copy")
                        </button>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                        <div class="bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800 rounded-lg p-3 text-center">
                            <div class="text-xs font-medium text-amber-600 dark:text-amber-400 uppercase tracking-wide mb-1">Voltage</div>
                            <div class="text-lg font-bold font-mono text-amber-700 dark:text-amber-300">@FormatSI(_resV, "V")</div>
                        </div>
                        <div class="bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-800 rounded-lg p-3 text-center">
                            <div class="text-xs font-medium text-blue-600 dark:text-blue-400 uppercase tracking-wide mb-1">Current</div>
                            <div class="text-lg font-bold font-mono text-blue-700 dark:text-blue-300">@FormatSI(_resI, "A")</div>
                        </div>
                        <div class="bg-green-50 dark:bg-green-900/10 border border-green-200 dark:border-green-800 rounded-lg p-3 text-center">
                            <div class="text-xs font-medium text-green-600 dark:text-green-400 uppercase tracking-wide mb-1">Resistance</div>
                            <div class="text-lg font-bold font-mono text-green-700 dark:text-green-300">@FormatSI(_resR, "\u03A9")</div>
                        </div>
                        <div class="bg-red-50 dark:bg-red-900/10 border border-red-200 dark:border-red-800 rounded-lg p-3 text-center">
                            <div class="text-xs font-medium text-red-600 dark:text-red-400 uppercase tracking-wide mb-1">Power</div>
                            <div class="text-lg font-bold font-mono text-red-700 dark:text-red-300">@FormatSI(_resP, "W")</div>
                        </div>
                    </div>
                    @if (_ohmFormulas.Count > 0)
                    {
                        <div class="pt-2 border-t border-gray-100 dark:border-gray-800">
                            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Formulas Used</h4>
                            <div class="flex flex-wrap gap-2">
                                @foreach (string formula in _ohmFormulas)
                                {
                                    <span class="text-xs font-mono bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-1 rounded">@formula</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @* Ohm's Law reference wheel *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">
                    <i class="ti ti-circle mr-1"></i> Ohm's Law Reference Wheel
                </h3>
                <div class="grid grid-cols-2 gap-px max-w-md mx-auto bg-gray-200 dark:bg-gray-700 rounded-lg overflow-hidden">
                    <div class="bg-amber-50 dark:bg-amber-900/10 p-3 text-center">
                        <div class="text-amber-600 dark:text-amber-400 font-bold text-sm mb-1">V (Voltage)</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-0.5 font-mono">
                            <div>I &times; R</div>
                            <div>P / I</div>
                            <div>&radic;(P &times; R)</div>
                        </div>
                    </div>
                    <div class="bg-blue-50 dark:bg-blue-900/10 p-3 text-center">
                        <div class="text-blue-600 dark:text-blue-400 font-bold text-sm mb-1">I (Current)</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-0.5 font-mono">
                            <div>V / R</div>
                            <div>P / V</div>
                            <div>&radic;(P / R)</div>
                        </div>
                    </div>
                    <div class="bg-green-50 dark:bg-green-900/10 p-3 text-center">
                        <div class="text-green-600 dark:text-green-400 font-bold text-sm mb-1">R (Resistance)</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-0.5 font-mono">
                            <div>V / I</div>
                            <div>V&sup2; / P</div>
                            <div>P / I&sup2;</div>
                        </div>
                    </div>
                    <div class="bg-red-50 dark:bg-red-900/10 p-3 text-center">
                        <div class="text-red-600 dark:text-red-400 font-bold text-sm mb-1">P (Power)</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-0.5 font-mono">
                            <div>V &times; I</div>
                            <div>I&sup2; &times; R</div>
                            <div>V&sup2; / R</div>
                        </div>
                    </div>
                </div>
            </div>
            break;

        @* ============================================================ *@
        @* TAB 2: Resistor Calculator                                   *@
        @* ============================================================ *@
        case ElectricalCalculatorCore.CalcTab.Resistor:
            <div class="flex items-center justify-between mb-2">
                <p class="text-xs text-gray-400">Supports SI prefixes: p, n, u, m, k, M, G</p>
                <div class="flex gap-2">
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="ClearResistor">
                        <i class="ti ti-refresh mr-1"></i>Clear
                    </button>
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="CopyResistor">
                        <i class="ti @(_copiedTab == ElectricalCalculatorCore.CalcTab.Resistor ? "ti-check text-green-500" : "ti-clipboard") mr-1"></i>
                        @(_copiedTab == ElectricalCalculatorCore.CalcTab.Resistor ? "Copied" : "Copy")
                    </button>
                </div>
            </div>

            @* Series and Parallel side by side *@
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @* Series resistance *@
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3">
                        <i class="ti ti-line mr-1"></i> Series Resistance
                    </h3>
                    <p class="text-xs text-gray-400 mb-2">R<sub>total</sub> = R<sub>1</sub> + R<sub>2</sub> + ...</p>
                    <div class="space-y-2">
                        @for (int i = 0; i < _seriesR.Count; i++)
                        {
                            int idx = i;
                            <div class="flex items-center gap-2">
                                <span class="text-xs text-gray-400 w-6 shrink-0">R@(idx + 1)</span>
                                <input type="text" inputmode="decimal" placeholder="e.g. 4.7k"
                                       class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       value="@_seriesR[idx]"
                                       @oninput="e => SetListValue(_seriesR, idx, e)" />
                                <span class="text-xs text-gray-400 w-6 shrink-0">&Omega;</span>
                                @if (_seriesR.Count > 2)
                                {
                                    <button type="button" class="text-red-400 hover:text-red-600 text-sm" @onclick="() => RemoveFromList(_seriesR, idx)">
                                        <i class="ti ti-x"></i>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    @if (_seriesR.Count < 10)
                    {
                        <button type="button"
                                class="mt-2 text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                                @onclick="() => AddToList(_seriesR)">
                            <i class="ti ti-plus mr-1"></i>Add Resistor
                        </button>
                    }
                    @if (ValidItemCount(_seriesR) >= 2)
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-800 text-center">
                            <span class="text-xs text-gray-400">Total:</span>
                            <span class="text-sm font-bold font-mono text-green-600 dark:text-green-400 ml-1">@FormatSI(ComputeSum(_seriesR), "\u03A9")</span>
                        </div>
                    }
                </div>

                @* Parallel resistance *@
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3">
                        <i class="ti ti-git-fork mr-1"></i> Parallel Resistance
                    </h3>
                    <p class="text-xs text-gray-400 mb-2">1/R<sub>total</sub> = 1/R<sub>1</sub> + 1/R<sub>2</sub> + ...</p>
                    <div class="space-y-2">
                        @for (int i = 0; i < _parallelR.Count; i++)
                        {
                            int idx = i;
                            <div class="flex items-center gap-2">
                                <span class="text-xs text-gray-400 w-6 shrink-0">R@(idx + 1)</span>
                                <input type="text" inputmode="decimal" placeholder="e.g. 10k"
                                       class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       value="@_parallelR[idx]"
                                       @oninput="e => SetListValue(_parallelR, idx, e)" />
                                <span class="text-xs text-gray-400 w-6 shrink-0">&Omega;</span>
                                @if (_parallelR.Count > 2)
                                {
                                    <button type="button" class="text-red-400 hover:text-red-600 text-sm" @onclick="() => RemoveFromList(_parallelR, idx)">
                                        <i class="ti ti-x"></i>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    @if (_parallelR.Count < 10)
                    {
                        <button type="button"
                                class="mt-2 text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                                @onclick="() => AddToList(_parallelR)">
                            <i class="ti ti-plus mr-1"></i>Add Resistor
                        </button>
                    }
                    @if (ValidItemCount(_parallelR) >= 2)
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-800 text-center">
                            <span class="text-xs text-gray-400">Total:</span>
                            <span class="text-sm font-bold font-mono text-green-600 dark:text-green-400 ml-1">@FormatSI(ComputeReciprocalSum(_parallelR), "\u03A9")</span>
                        </div>
                    }
                </div>
            </div>

            @* Colour code decoder *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">
                    <i class="ti ti-palette mr-1"></i> Resistor Colour Code Decoder
                </h3>

                @* Band count toggle *@
                <div class="flex items-center gap-2 mb-4">
                    <span class="text-xs text-gray-500">Band count:</span>
                    <button type="button"
                            class="px-3 py-1 text-xs rounded font-medium transition-colors @(_ccBandCount == 4 ? "bg-blue-600 text-white" : "bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700") cursor-pointer"
                            @onclick="() => SetBandCount(4)">
                        4-Band
                    </button>
                    <button type="button"
                            class="px-3 py-1 text-xs rounded font-medium transition-colors @(_ccBandCount == 5 ? "bg-blue-600 text-white" : "bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700") cursor-pointer"
                            @onclick="() => SetBandCount(5)">
                        5-Band
                    </button>
                </div>

                @* Visual resistor body with bands *@
                <div class="flex items-center justify-center my-4">
                    <div class="w-10 h-1.5 bg-gray-400 dark:bg-gray-500 rounded-l"></div>
                    <div class="bg-amber-200 dark:bg-amber-800/30 rounded px-4 py-1.5 flex items-center gap-1.5">
                        @for (int b = 0; b < _ccBandCount - 1; b++)
                        {
                            int band = b;
                            <div class="w-4 h-10 rounded-sm border border-black/20 dark:border-white/20"
                                 style="background-color: @GetBandHex(band)"></div>
                        }
                        <div class="w-6"></div>
                        <div class="w-4 h-10 rounded-sm border border-black/20 dark:border-white/20"
                             style="background-color: @GetBandHex(_ccBandCount - 1)"></div>
                    </div>
                    <div class="w-10 h-1.5 bg-gray-400 dark:bg-gray-500 rounded-r"></div>
                </div>

                @* Band selectors *@
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                    <div>
                        <label class="block text-xs font-medium mb-1">Band 1 (1st digit)</label>
                        <select @bind="_ccD1"
                                class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            @for (int d = 0; d < ElectricalCalculatorCore.DigitBands.Length; d++)
                            {
                                int digit = d;
                                <option value="@digit">@ElectricalCalculatorCore.DigitBands[digit].Name (@digit)</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">Band 2 (2nd digit)</label>
                        <select @bind="_ccD2"
                                class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            @for (int d = 0; d < ElectricalCalculatorCore.DigitBands.Length; d++)
                            {
                                int digit = d;
                                <option value="@digit">@ElectricalCalculatorCore.DigitBands[digit].Name (@digit)</option>
                            }
                        </select>
                    </div>
                    @if (_ccBandCount == 5)
                    {
                        <div>
                            <label class="block text-xs font-medium mb-1">Band 3 (3rd digit)</label>
                            <select @bind="_ccD3"
                                    class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                @for (int d = 0; d < ElectricalCalculatorCore.DigitBands.Length; d++)
                                {
                                    int digit = d;
                                    <option value="@digit">@ElectricalCalculatorCore.DigitBands[digit].Name (@digit)</option>
                                }
                            </select>
                        </div>
                    }
                    <div>
                        <label class="block text-xs font-medium mb-1">Multiplier</label>
                        <select @bind="_ccMult"
                                class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            @for (int m = 0; m < ElectricalCalculatorCore.MultBands.Length; m++)
                            {
                                int mult = m;
                                <option value="@mult">@ElectricalCalculatorCore.MultBands[mult].Name (&times;@FormatMult(ElectricalCalculatorCore.MultBands[mult].Factor))</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">Tolerance</label>
                        <select @bind="_ccTol"
                                class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            @for (int t = 0; t < ElectricalCalculatorCore.TolBands.Length; t++)
                            {
                                int tol = t;
                                <option value="@tol">@ElectricalCalculatorCore.TolBands[tol].Name (&plusmn;@ElectricalCalculatorCore.TolBands[tol].Percent%)</option>
                            }
                        </select>
                    </div>
                </div>

                @* Colour code result *@
                <div class="mt-4 pt-3 border-t border-gray-100 dark:border-gray-800 text-center space-y-1">
                    <div class="text-2xl font-bold font-mono text-blue-600 dark:text-blue-400">@FormatSI(ColourCodeResistance(), "\u03A9")</div>
                    <div class="text-sm text-gray-500">&plusmn;@ColourCodeTolerance()%</div>
                    <div class="text-xs text-gray-400">
                        Range: @FormatSI(ColourCodeResistance() * (1.0 - ColourCodeTolerance() / 100.0), "\u03A9")
                        to @FormatSI(ColourCodeResistance() * (1.0 + ColourCodeTolerance() / 100.0), "\u03A9")
                    </div>
                </div>
            </div>
            break;

        @* ============================================================ *@
        @* TAB 3: Capacitance                                           *@
        @* ============================================================ *@
        case ElectricalCalculatorCore.CalcTab.Capacitance:
            <div class="flex items-center justify-between mb-2">
                <p class="text-xs text-gray-400">Supports SI prefixes: p, n, u, m, k, M, G</p>
                <div class="flex gap-2">
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="ClearCapacitance">
                        <i class="ti ti-refresh mr-1"></i>Clear
                    </button>
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="CopyCapacitance">
                        <i class="ti @(_copiedTab == ElectricalCalculatorCore.CalcTab.Capacitance ? "ti-check text-green-500" : "ti-clipboard") mr-1"></i>
                        @(_copiedTab == ElectricalCalculatorCore.CalcTab.Capacitance ? "Copied" : "Copy")
                    </button>
                </div>
            </div>

            @* Series and Parallel *@
