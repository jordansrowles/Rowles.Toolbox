                                <input type="text" inputmode="decimal" placeholder="e.g. 1k"
                                       class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       @bind="_ixF" @bind:event="oninput" @bind:after="SaveState" />
                                <span class="text-xs text-gray-400 w-6 shrink-0">Hz</span>
                            </div>
                        </div>
                    </div>
                    @if (ComputeIndReactance() > 0)
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-800 text-center">
                            <span class="text-xs text-gray-400">X<sub>L</sub>:</span>
                            <span class="text-sm font-bold font-mono text-green-600 dark:text-green-400 ml-1">@FormatSI(ComputeIndReactance(), "\u03A9")</span>
                        </div>
                    }
                </div>

                @* Resonant frequency *@
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3">
                        <i class="ti ti-activity mr-1"></i> Resonant Frequency
                    </h3>
                    <p class="text-xs text-gray-400 mb-3">f = 1 / (2&pi;&radic;(LC))</p>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-xs font-medium mb-1">Inductance (L)</label>
                            <div class="flex items-center gap-2">
                                <input type="text" inputmode="decimal" placeholder="e.g. 10m"
                                       class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       @bind="_rfL" @bind:event="oninput" @bind:after="SaveState" />
                                <span class="text-xs text-gray-400 w-6 shrink-0">H</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-medium mb-1">Capacitance (C)</label>
                            <div class="flex items-center gap-2">
                                <input type="text" inputmode="decimal" placeholder="e.g. 100n"
                                       class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       @bind="_rfC" @bind:event="oninput" @bind:after="SaveState" />
                                <span class="text-xs text-gray-400 w-6 shrink-0">F</span>
                            </div>
                        </div>
                    </div>
                    @if (ComputeResonantFreq() > 0)
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-800 text-center">
                            <span class="text-xs text-gray-400">f<sub>0</sub>:</span>
                            <span class="text-sm font-bold font-mono text-green-600 dark:text-green-400 ml-1">@FormatSI(ComputeResonantFreq(), "Hz")</span>
                        </div>
                    }
                </div>
            </div>
            break;
    }
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/math/electrical" OnRestore="RestoreState" />

@code {
    RecentEntryPanel? _recentPanel;

    sealed record ToolState(
        string ActiveTab,
        string OhmV, string OhmI, string OhmR, string OhmP,
        string RcR, string RcC, string CeC, string CeV, string CxC, string CxF,
        string RlR, string RlL, string IeL, string IeI, string IxL, string IxF,
        string RfL, string RfC);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/math/electrical");
            if (state is not null) { ApplyElecState(state); StateHasChanged(); }
        }
    }

    async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/math/electrical", new ToolState(
            _activeTab.ToString(),
            _ohmV, _ohmI, _ohmR, _ohmP,
            _rcR, _rcC, _ceC, _ceV, _cxC, _cxF,
            _rlR, _rlL, _ieL, _ieI, _ixL, _ixF,
            _rfL, _rfC));
    }

    async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null) { ApplyElecState(state); StateHasChanged(); }
    }

    void ApplyElecState(ToolState state)
    {
        if (Enum.TryParse<ElectricalCalculatorCore.CalcTab>(state.ActiveTab, out ElectricalCalculatorCore.CalcTab tab))
            _activeTab = tab;
        _ohmV = state.OhmV; _ohmI = state.OhmI; _ohmR = state.OhmR; _ohmP = state.OhmP;
        _rcR = state.RcR; _rcC = state.RcC; _ceC = state.CeC; _ceV = state.CeV;
        _cxC = state.CxC; _cxF = state.CxF;
        _rlR = state.RlR; _rlL = state.RlL; _ieL = state.IeL; _ieI = state.IeI;
        _ixL = state.IxL; _ixF = state.IxF; _rfL = state.RfL; _rfC = state.RfC;
    }

    ElectricalCalculatorCore.CalcTab _activeTab = ElectricalCalculatorCore.CalcTab.OhmsLaw;
    ElectricalCalculatorCore.CalcTab? _copiedTab;

    @* Ohm's Law state *@
    string _ohmV = string.Empty;
    string _ohmI = string.Empty;
    string _ohmR = string.Empty;
    string _ohmP = string.Empty;
    double _resV;
    double _resI;
    double _resR;
    double _resP;
    List<string> _ohmFormulas = new();
    string _ohmError = string.Empty;
    bool _ohmSolved;

    @* Resistor state *@
    List<string> _seriesR = new() { string.Empty, string.Empty };
    List<string> _parallelR = new() { string.Empty, string.Empty };
    int _ccBandCount = 4;
    int _ccD1 = 1;
    int _ccD2 = 0;
    int _ccD3 = 0;
    int _ccMult = 2;
    int _ccTol = 6;

    @* Capacitance state *@
    List<string> _seriesC = new() { string.Empty, string.Empty };
    List<string> _parallelC = new() { string.Empty, string.Empty };
    string _rcR = string.Empty;
    string _rcC = string.Empty;
    string _ceC = string.Empty;
    string _ceV = string.Empty;
    string _cxC = string.Empty;
    string _cxF = string.Empty;

    @* Inductance state *@
    List<string> _seriesL = new() { string.Empty, string.Empty };
    List<string> _parallelL = new() { string.Empty, string.Empty };
    string _rlR = string.Empty;
    string _rlL = string.Empty;
    string _ieL = string.Empty;
    string _ieI = string.Empty;
    string _ixL = string.Empty;
    string _ixF = string.Empty;
    string _rfL = string.Empty;
    string _rfC = string.Empty;

    @* Delegate wrappers for extracted static methods *@
    static bool TryParseSI(string raw, out double result) => ElectricalCalculatorCore.TryParseSI(raw, out result);
    static string FormatSI(double value, string unit) => ElectricalCalculatorCore.FormatSI(value, unit);
    static string FormatMult(double f) => ElectricalCalculatorCore.FormatMult(f);
    static string TabIcon(ElectricalCalculatorCore.CalcTab tab) => ElectricalCalculatorCore.TabIcon(tab);
    static string TabLabel(ElectricalCalculatorCore.CalcTab tab) => ElectricalCalculatorCore.TabLabel(tab);
    static double ComputeSum(List<string> items) => ElectricalCalculatorCore.ComputeSum(items);
    static double ComputeReciprocalSum(List<string> items) => ElectricalCalculatorCore.ComputeReciprocalSum(items);
    static int ValidItemCount(List<string> items) => ElectricalCalculatorCore.ValidItemCount(items);

    @* Tab helpers *@
    string TabCss(ElectricalCalculatorCore.CalcTab tab)
    {
        string baseClass = "px-3 py-1.5 text-sm rounded font-medium transition-colors cursor-pointer";
        return tab == _activeTab
            ? baseClass + " bg-blue-600 text-white"
            : baseClass + " bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700";
    }

    @* Ohm's Law *@
    int OhmFilledCount()
    {
        int c = 0;
        if (TryParseSI(_ohmV, out _)) c++;
        if (TryParseSI(_ohmI, out _)) c++;
        if (TryParseSI(_ohmR, out _)) c++;
        if (TryParseSI(_ohmP, out _)) c++;
        return c;
    }

    void SolveOhm()
    {
        _ohmFormulas.Clear();
        _ohmError = string.Empty;
        _ohmSolved = false;

        bool hasV = TryParseSI(_ohmV, out double v);
        bool hasI = TryParseSI(_ohmI, out double iVal);
        bool hasR = TryParseSI(_ohmR, out double r);
        bool hasP = TryParseSI(_ohmP, out double p);
        int count = (hasV ? 1 : 0) + (hasI ? 1 : 0) + (hasR ? 1 : 0) + (hasP ? 1 : 0);

        if (count != 2)
        {
            _ohmError = "Enter exactly 2 values to calculate the other 2.";
            return;
        }

        if (hasV && hasI)
        {
            r = v / iVal;
            p = v * iVal;
            _ohmFormulas.Add("R = V / I");
            _ohmFormulas.Add("P = V \u00D7 I");
        }
        else if (hasV && hasR)
        {
            iVal = v / r;
            p = v * v / r;
            _ohmFormulas.Add("I = V / R");
            _ohmFormulas.Add("P = V\u00B2 / R");
        }
        else if (hasV && hasP)
        {
            iVal = p / v;
            r = v * v / p;
            _ohmFormulas.Add("I = P / V");
            _ohmFormulas.Add("R = V\u00B2 / P");
        }
        else if (hasI && hasR)
        {
            v = iVal * r;
            p = iVal * iVal * r;
            _ohmFormulas.Add("V = I \u00D7 R");
            _ohmFormulas.Add("P = I\u00B2 \u00D7 R");
        }
        else if (hasI && hasP)
        {
            v = p / iVal;
            r = p / (iVal * iVal);
            _ohmFormulas.Add("V = P / I");
            _ohmFormulas.Add("R = P / I\u00B2");
        }
        else if (hasR && hasP)
        {
            v = Math.Sqrt(p * r);
            iVal = Math.Sqrt(p / r);
            _ohmFormulas.Add("V = \u221A(P \u00D7 R)");
            _ohmFormulas.Add("I = \u221A(P / R)");
        }

        if (double.IsNaN(v) || double.IsNaN(iVal) || double.IsNaN(r) || double.IsNaN(p) ||
            double.IsInfinity(v) || double.IsInfinity(iVal) || double.IsInfinity(r) || double.IsInfinity(p))
        {
            _ohmError = "Result is undefined. Check for division by zero or invalid inputs.";
            return;
        }

        _resV = v;
        _resI = iVal;
        _resR = r;
        _resP = p;
        _ohmSolved = true;
    }

    async Task AddOhmRecentEntry()
    {
        string label = "V=" + FormatSI(_resV, "V") + " I=" + FormatSI(_resI, "A");
        await Storage.AddRecentAsync("tools/math/electrical", label, new ToolState(
            _activeTab.ToString(), _ohmV, _ohmI, _ohmR, _ohmP,
            _rcR, _rcC, _ceC, _ceV, _cxC, _cxF,
            _rlR, _rlL, _ieL, _ieI, _ixL, _ixF, _rfL, _rfC));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    void ClearOhm()
    {
        _ohmV = _ohmI = _ohmR = _ohmP = string.Empty;
        _ohmSolved = false;
        _ohmError = string.Empty;
        _ohmFormulas.Clear();
    }

    async Task CopyOhm()
    {
        string output = "V = " + FormatSI(_resV, "V") + ", I = " + FormatSI(_resI, "A") +
                         ", R = " + FormatSI(_resR, "\u03A9") + ", P = " + FormatSI(_resP, "W");
        await CopyToClipboard(output, ElectricalCalculatorCore.CalcTab.OhmsLaw);
        await AddOhmRecentEntry();
    }

    @* List helpers *@
    void AddToList(List<string> list)
    {
        if (list.Count < 10) list.Add(string.Empty);
    }

    void RemoveFromList(List<string> list, int index)
    {
        if (list.Count > 2 && index >= 0 && index < list.Count) list.RemoveAt(index);
    }

    void SetListValue(List<string> list, int index, ChangeEventArgs e)
    {
        list[index] = e.Value?.ToString() ?? string.Empty;
    }

    @* Colour code *@
    double ColourCodeResistance()
    {
        double baseVal;
        if (_ccBandCount == 5)
            baseVal = _ccD1 * 100 + _ccD2 * 10 + _ccD3;
        else
            baseVal = _ccD1 * 10 + _ccD2;
        return baseVal * ElectricalCalculatorCore.MultBands[_ccMult].Factor;
    }

    double ColourCodeTolerance() => ElectricalCalculatorCore.TolBands[_ccTol].Percent;

    string GetBandHex(int position)
    {
        if (_ccBandCount == 4)
        {
            return position switch
            {
                0 => ElectricalCalculatorCore.DigitBands[_ccD1].Hex,
                1 => ElectricalCalculatorCore.DigitBands[_ccD2].Hex,
                2 => ElectricalCalculatorCore.MultBands[_ccMult].Hex,
                3 => ElectricalCalculatorCore.TolBands[_ccTol].Hex,
                _ => "#000000"
            };
        }
        return position switch
        {
            0 => ElectricalCalculatorCore.DigitBands[_ccD1].Hex,
            1 => ElectricalCalculatorCore.DigitBands[_ccD2].Hex,
            2 => ElectricalCalculatorCore.DigitBands[_ccD3].Hex,
            3 => ElectricalCalculatorCore.MultBands[_ccMult].Hex,
            4 => ElectricalCalculatorCore.TolBands[_ccTol].Hex,
            _ => "#000000"
        };
    }

    void SetBandCount(int count) { _ccBandCount = count; }

    @* RC / RL / Energy / Reactance computations *@
    double ComputeRcTau()
    {
        if (TryParseSI(_rcR, out double r) && TryParseSI(_rcC, out double c) && r > 0 && c > 0)
            return r * c;
        return 0;
    }

    double ComputeCapEnergy()
    {
        if (TryParseSI(_ceC, out double c) && TryParseSI(_ceV, out double v) && c > 0)
            return 0.5 * c * v * v;
        return 0;
    }

    double ComputeCapReactance()
    {
        if (TryParseSI(_cxC, out double c) && TryParseSI(_cxF, out double f) && c > 0 && f > 0)
            return 1.0 / (2.0 * Math.PI * f * c);
        return 0;
    }

    double ComputeRlTau()
    {
        if (TryParseSI(_rlL, out double l) && TryParseSI(_rlR, out double r) && r > 0 && l > 0)
            return l / r;
        return 0;
    }

    double ComputeIndEnergy()
    {
        if (TryParseSI(_ieL, out double l) && TryParseSI(_ieI, out double iVal) && l > 0)
            return 0.5 * l * iVal * iVal;
        return 0;
    }

    double ComputeIndReactance()
    {
        if (TryParseSI(_ixL, out double l) && TryParseSI(_ixF, out double f) && l > 0 && f > 0)
            return 2.0 * Math.PI * f * l;
        return 0;
    }

    double ComputeResonantFreq()
    {
        if (TryParseSI(_rfL, out double l) && TryParseSI(_rfC, out double c) && l > 0 && c > 0)
            return 1.0 / (2.0 * Math.PI * Math.Sqrt(l * c));
        return 0;
    }

    @* Clear methods *@
    void ClearResistor()
    {
        _seriesR = new List<string> { string.Empty, string.Empty };
        _parallelR = new List<string> { string.Empty, string.Empty };
        _ccBandCount = 4;
        _ccD1 = 1;
        _ccD2 = 0;
        _ccD3 = 0;
        _ccMult = 2;
        _ccTol = 6;
    }

    void ClearCapacitance()
    {
        _seriesC = new List<string> { string.Empty, string.Empty };
        _parallelC = new List<string> { string.Empty, string.Empty };
        _rcR = _rcC = _ceC = _ceV = _cxC = _cxF = string.Empty;
    }

    void ClearInductance()
    {
        _seriesL = new List<string> { string.Empty, string.Empty };
        _parallelL = new List<string> { string.Empty, string.Empty };
        _rlR = _rlL = _ieL = _ieI = _ixL = _ixF = _rfL = _rfC = string.Empty;
    }

    @* Copy helpers *@
    async Task CopyToClipboard(string content, ElectricalCalculatorCore.CalcTab tab)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
        _copiedTab = tab;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedTab = null;
        StateHasChanged();
    }

    async Task CopyResistor()
    {
        string output = "Series: " + FormatSI(ComputeSum(_seriesR), "\u03A9") +
                         ", Parallel: " + FormatSI(ComputeReciprocalSum(_parallelR), "\u03A9") +
                         ", Colour Code: " + FormatSI(ColourCodeResistance(), "\u03A9") +
                         " \u00B1" + ColourCodeTolerance().ToString(CultureInfo.InvariantCulture) + "%";
        await CopyToClipboard(output, ElectricalCalculatorCore.CalcTab.Resistor);
        await AddTabRecentEntry("Resistor");
    }

    async Task CopyCapacitance()
    {
        string output = "Series: " + FormatSI(ComputeReciprocalSum(_seriesC), "F") +
                         ", Parallel: " + FormatSI(ComputeSum(_parallelC), "F");
        double tau = ComputeRcTau();
        if (tau > 0) output += ", RC \u03C4 = " + FormatSI(tau, "s");
        double energy = ComputeCapEnergy();
        if (energy > 0) output += ", E = " + FormatSI(energy, "J");
        double xc = ComputeCapReactance();
        if (xc > 0) output += ", Xc = " + FormatSI(xc, "\u03A9");
        await CopyToClipboard(output, ElectricalCalculatorCore.CalcTab.Capacitance);
        await AddTabRecentEntry("Capacitance");
    }

    async Task CopyInductance()
    {
        string output = "Series: " + FormatSI(ComputeSum(_seriesL), "H") +
                         ", Parallel: " + FormatSI(ComputeReciprocalSum(_parallelL), "H");
        double tau = ComputeRlTau();
        if (tau > 0) output += ", RL \u03C4 = " + FormatSI(tau, "s");
        double energy = ComputeIndEnergy();
        if (energy > 0) output += ", E = " + FormatSI(energy, "J");
        double xl = ComputeIndReactance();
        if (xl > 0) output += ", XL = " + FormatSI(xl, "\u03A9");
        double fr = ComputeResonantFreq();
        if (fr > 0) output += ", f\u2080 = " + FormatSI(fr, "Hz");
        await CopyToClipboard(output, ElectricalCalculatorCore.CalcTab.Inductance);
        await AddTabRecentEntry("Inductance");
    }

    async Task AddTabRecentEntry(string tabLabel)
    {
        await Storage.AddRecentAsync("tools/math/electrical", tabLabel, new ToolState(
            _activeTab.ToString(), _ohmV, _ohmI, _ohmR, _ohmP,
            _rcR, _rcC, _ceC, _ceV, _cxC, _cxF,
            _rlR, _rlL, _ieL, _ieI, _ixL, _ixF, _rfL, _rfC));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }
}
