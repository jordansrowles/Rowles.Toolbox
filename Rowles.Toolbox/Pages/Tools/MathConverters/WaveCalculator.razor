@page "/tools/math/waves"
@namespace Rowles.Toolbox.Pages.Tools.MathConverters
@using Rowles.Toolbox.Core.MathConverters
@using System.Globalization
@inject IJSRuntime JS
@inject LocalStorageService Storage

<PageTitle>Wave Calculator - Rowles.Toolbox</PageTitle>

<PageHeader Title="Wave Calculator" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400">
            <i class="ti ti-wave-sine mr-1"></i> Frequency, wavelength, period, and wave properties
        </span>
    </Actions>
</PageHeader>

<div class="space-y-4">

    @* Quick examples and medium presets *@
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-bookmark mr-1"></i> Quick Examples
            </h3>
            <div class="flex flex-wrap gap-2">
                @foreach (WaveCalculatorCore.WaveExample ex in WaveCalculatorCore.QuickExamples)
                {
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="() => ApplyExample(ex)">
                        <i class="ti ti-wave-sine mr-0.5"></i> @ex.Label
                    </button>
                }
            </div>
        </div>

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-settings mr-1"></i> Medium Preset
            </h3>
            <select class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                    @onchange="OnMediumChange">
                <option value="custom">Custom velocity</option>
                <option value="light">Light in vacuum (3 x 10&#x2078; m/s)</option>
                <option value="air">Sound in air (343 m/s)</option>
                <option value="water">Sound in water (1480 m/s)</option>
                <option value="steel">Sound in steel (5960 m/s)</option>
            </select>
            <p class="text-xs text-gray-400 mt-1">
                <i class="ti ti-info-circle mr-0.5"></i>
                Selecting a preset locks the velocity field
            </p>
        </div>

    </div>

    @* Core Wave Equation *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-gray-500">
                <i class="ti ti-math-function mr-1"></i> Core Wave Equation: v = f x lambda
            </h3>
            <span class="text-xs text-gray-400">
                Enter any 2 of 3 to solve for the third
            </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-3">
                @* Solve mode selector *@
                <div>
                    <label class="block text-xs font-medium mb-1">Solve for</label>
                    <select class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            @onchange="OnSolveModeChange">
                        <option value="wavelength">Wavelength (enter v and f)</option>
                        <option value="frequency">Frequency (enter v and lambda)</option>
                        <option value="velocity">Velocity (enter f and lambda)</option>
                    </select>
                </div>

                @* Velocity *@
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Velocity (v)
                        <span class="font-normal text-gray-400">m/s</span>
                        @if (_solveMode == "velocity")
                        {
                            <span class="ml-1 text-blue-500 font-semibold">(calculated)</span>
                        }
                        @if (_mediumPreset != "custom")
                        {
                            <span class="ml-1 text-green-500 font-semibold">(preset)</span>
                        }
                    </label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:opacity-50"
                           disabled="@(_solveMode == "velocity" || _mediumPreset != "custom")"
                           @bind="_velocity" @bind:event="oninput" @bind:after="SaveState" />
                </div>

                @* Frequency *@
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Frequency (f)
                        <span class="font-normal text-gray-400">Hz</span>
                        @if (_solveMode == "frequency")
                        {
                            <span class="ml-1 text-blue-500 font-semibold">(calculated)</span>
                        }
                    </label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:opacity-50"
                           disabled="@(_solveMode == "frequency")"
                           @bind="_frequency" @bind:event="oninput" @bind:after="SaveState" />
                </div>

                @* Wavelength *@
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Wavelength (lambda)
                        <span class="font-normal text-gray-400">m</span>
                        @if (_solveMode == "wavelength")
                        {
                            <span class="ml-1 text-blue-500 font-semibold">(calculated)</span>
                        }
                    </label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:opacity-50"
                           disabled="@(_solveMode == "wavelength")"
                           @bind="_wavelength" @bind:event="oninput" @bind:after="SaveState" />
                </div>

                <button type="button"
                        class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                        @onclick="CalculateWave">
                    <i class="ti ti-calculator mr-1"></i> Calculate
                </button>
            </div>

            @* Derived results *@
            <div class="space-y-2">
                <h3 class="text-sm font-semibold text-gray-500 mb-2">
                    <i class="ti ti-list-details mr-1"></i> Derived Properties
                </h3>

                @if (_waveCalculated)
                {
                    <div class="grid grid-cols-2 gap-2">
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">Velocity (v)</p>
                            <p class="text-lg font-bold text-blue-600 dark:text-blue-400 font-mono">@FormatSI(_velocity)</p>
                            <p class="text-xs text-gray-400">m/s</p>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">Frequency (f)</p>
                            <p class="text-lg font-bold text-blue-600 dark:text-blue-400 font-mono">@FormatSI(_frequency)</p>
                            <p class="text-xs text-gray-400">Hz</p>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">Wavelength (lambda)</p>
                            <p class="text-lg font-bold text-blue-600 dark:text-blue-400 font-mono">@FormatSI(_wavelength)</p>
                            <p class="text-xs text-gray-400">m</p>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">Period (T = 1/f)</p>
                            <p class="text-lg font-bold text-green-600 dark:text-green-400 font-mono">@FormatSI(CalcPeriod)</p>
                            <p class="text-xs text-gray-400">s</p>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">Angular freq (omega = 2 pi f)</p>
                            <p class="text-lg font-bold text-purple-600 dark:text-purple-400 font-mono">@FormatSI(CalcOmega)</p>
                            <p class="text-xs text-gray-400">rad/s</p>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">Wave number (k = 2 pi / lambda)</p>
                            <p class="text-lg font-bold text-purple-600 dark:text-purple-400 font-mono">@FormatSI(CalcWaveNumber)</p>
                            <p class="text-xs text-gray-400">rad/m</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 mt-2">
                        <button type="button"
                                class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                                @onclick="CopyWaveResults">
                            <i class="ti ti-copy mr-1"></i> Copy Results
                        </button>
                        <span class="text-xs text-gray-400 font-mono">
                            v = f x lambda | T = 1/f | omega = 2 pi f | k = 2 pi / lambda
                        </span>
                    </div>
                }
                else
                {
                    <p class="text-xs text-gray-400 italic pt-2">Enter values and click Calculate to see derived properties.</p>
                }
            </div>
        </div>
    </div>

    @* Wave Visualization *@
    @if (_waveCalculated && _frequency > 0 && _wavelength > 0)
    {
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-wave-sine mr-1"></i> Wave Visualization
            </h3>

            <div class="mb-3">
                <div class="flex items-center justify-between mb-1">
                    <label class="text-xs font-medium">Amplitude</label>
                    <span class="text-xs font-bold text-blue-500">@F(_amplitude)</span>
                </div>
                <input type="range" min="0.1" max="2.0" step="0.1"
                       class="w-full accent-blue-500"
                       @bind="_amplitude" @bind:event="oninput" @bind:after="SaveState" />
            </div>

            <svg viewBox="0 0 500 200" class="w-1/2 h-auto bg-gray-50 dark:bg-gray-900 rounded" xmlns="http://www.w3.org/2000/svg"
                 aria-label="Sine wave visualization">

                @* Grid lines *@
                <line x1="40" y1="100" x2="480" y2="100" stroke="#9ca3af" stroke-width="0.5" stroke-dasharray="4,2" />
                <line x1="40" y1="30" x2="480" y2="30" stroke="#e5e7eb" stroke-width="0.5" stroke-dasharray="2,4" />
                <line x1="40" y1="170" x2="480" y2="170" stroke="#e5e7eb" stroke-width="0.5" stroke-dasharray="2,4" />

                @* Axes *@
                <line x1="40" y1="10" x2="40" y2="190" stroke="#6b7280" stroke-width="1" />
                <line x1="40" y1="100" x2="485" y2="100" stroke="#6b7280" stroke-width="1" />

                @* Sine wave path *@
                <polyline points="@SineWavePoints"
                          fill="none" stroke="#3b82f6" stroke-width="2"
                          stroke-linejoin="round" stroke-linecap="round" />

                @* Amplitude annotation *@
                <line x1="45" y1="100" x2="45" y2="@SvgWaveY(_amplitude)" stroke="#ef4444" stroke-width="1.5" />
                <line x1="41" y1="@SvgWaveY(_amplitude)" x2="49" y2="@SvgWaveY(_amplitude)" stroke="#ef4444" stroke-width="1.5" />
                <line x1="41" y1="100" x2="49" y2="100" stroke="#ef4444" stroke-width="1.5" />
                @((MarkupString)$"<text x=\"20\" y=\"{SvgWaveY(_amplitude * 0.5):F0}\" fill=\"#ef4444\" font-size=\"9\" text-anchor=\"middle\" font-weight=\"bold\">A</text>")

                @* Wavelength annotation *@
                @((MarkupString)WavelengthAnnotationSvg())

                @* Labels *@
                <text x="485" y="96" fill="#6b7280" font-size="8" text-anchor="end">x</text>
                <text x="46" y="18" fill="#6b7280" font-size="8" text-anchor="start">y</text>
            </svg>

            <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-xs text-gray-400">
                <span>Showing 2 full wavelengths</span>
                <span>Amplitude: @F(_amplitude)</span>
                <span>lambda = @FormatSI(_wavelength) m</span>
            </div>
        </div>
    }

    @* Electromagnetic Spectrum Reference *@
    @if (_waveCalculated && _mediumPreset == "light")
    {
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-rainbow mr-1"></i> Electromagnetic Spectrum
            </h3>

            <div class="space-y-2">
                @foreach (WaveCalculatorCore.EmBand band in WaveCalculatorCore.EmBands)
                {
                    bool isActive = IsInBand(band);
                    <div class="flex items-center gap-2 px-2 py-1.5 rounded text-xs @(isActive ? "bg-blue-50 dark:bg-blue-950 border border-blue-300 dark:border-blue-700 font-semibold" : "")">
                        <span class="w-4 h-4 rounded-full flex-shrink-0" style="background: @band.Colour;"></span>
                        <span class="w-28 flex-shrink-0 @(isActive ? "text-blue-700 dark:text-blue-300" : "text-gray-600 dark:text-gray-400")">@band.Name</span>
                        <span class="flex-1 text-gray-500 font-mono">@band.RangeLabel</span>
                        @if (isActive)
                        {
                            <span class="text-blue-600 dark:text-blue-400">
                                <i class="ti ti-arrow-left mr-0.5"></i> Current
                            </span>
                        }
                    </div>
                }
            </div>

            @if (_wavelength > 380e-9 && _wavelength < 780e-9)
            {
                <div class="mt-3 flex items-center gap-2">
                    <span class="text-xs text-gray-500">Approximate visible colour:</span>
                    <span class="w-8 h-8 rounded border border-gray-300 dark:border-gray-600"
                          style="background: @WavelengthToHexColour(_wavelength);"></span>
                    <span class="text-xs font-mono text-gray-600 dark:text-gray-400">@WavelengthToHexColour(_wavelength)</span>
                </div>
            }
        </div>
    }

    @* Doppler Effect Calculator *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-arrows-left-right mr-1"></i> Doppler Effect Calculator
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-3">
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Source Frequency (f)
                        <span class="font-normal text-gray-400">Hz</span>
                    </label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dopplerSourceFreq" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Medium Velocity (v)
                        <span class="font-normal text-gray-400">m/s</span>
                    </label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dopplerMediumVel" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Observer Velocity (vo)
                        <span class="font-normal text-gray-400">m/s, positive = toward source</span>
                    </label>
                    <input type="number" step="any"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dopplerObserverVel" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1">
                        Source Velocity (vs)
                        <span class="font-normal text-gray-400">m/s, positive = toward observer</span>
                    </label>
                    <input type="number" step="any"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dopplerSourceVel" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <button type="button"
                        class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                        @onclick="CalculateDoppler">
                    <i class="ti ti-calculator mr-1"></i> Calculate Doppler
                </button>
            </div>

            <div class="space-y-2">
                <div class="bg-gray-50 dark:bg-gray-900 rounded p-3 mb-2">
                    <p class="text-xs text-gray-400 mb-1 font-mono">Formula: f' = f x (v + vo) / (v - vs)</p>
                    <p class="text-xs text-gray-400">(Sign convention: vs positive when source moves toward observer)</p>
                </div>

                @if (_dopplerCalculated)
                {
                    <div class="grid grid-cols-1 gap-2">
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">
                                <i class="ti ti-arrow-narrow-right mr-0.5"></i> Approaching (source toward observer)
                            </p>
                            <p class="text-xl font-bold text-green-600 dark:text-green-400 font-mono">
                                @FormatSI(_dopplerApproaching) <span class="text-xs font-normal text-gray-500">Hz</span>
                            </p>
                            <p class="text-xs text-gray-400 mt-0.5">
                                Shift: +@F(_dopplerApproaching - _dopplerSourceFreq) Hz (@F((_dopplerApproaching / _dopplerSourceFreq - 1.0) * 100.0)%)
                            </p>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                            <p class="text-xs text-gray-400 mb-0.5">
                                <i class="ti ti-arrow-narrow-left mr-0.5"></i> Receding (source away from observer)
                            </p>
                            <p class="text-xl font-bold text-red-600 dark:text-red-400 font-mono">
                                @FormatSI(_dopplerReceding) <span class="text-xs font-normal text-gray-500">Hz</span>
                            </p>
                            <p class="text-xs text-gray-400 mt-0.5">
                                Shift: @F(_dopplerReceding - _dopplerSourceFreq) Hz (@F((_dopplerReceding / _dopplerSourceFreq - 1.0) * 100.0)%)
                            </p>
                        </div>
                    </div>

                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="CopyDopplerResults">
                        <i class="ti ti-copy mr-1"></i> Copy Doppler Results
                    </button>
                }
                else
                {
                    <p class="text-xs text-gray-400 italic">Enter values and click Calculate Doppler.</p>
                }
            </div>
        </div>
    </div>

    @* Standing Waves and Harmonics *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-music mr-1"></i> Standing Waves / Harmonics
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
            <div class="space-y-3">
                <div>
                    <label class="block text-xs font-medium mb-1">Input Mode</label>
                    <select class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            @onchange="OnHarmonicModeChange">
                        <option value="fundamental">Fundamental Frequency</option>
                        <option value="stringlen">String Length + Wave Speed</option>
                    </select>
                </div>

                @if (_harmonicMode == "fundamental")
                {
                    <div>
                        <label class="block text-xs font-medium mb-1">
                            Fundamental Frequency (f1)
                            <span class="font-normal text-gray-400">Hz</span>
                        </label>
                        <input type="number" step="any" min="0"
                               class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               @bind="_fundamentalFreq" @bind:event="oninput" @bind:after="SaveState" />
                    </div>
                }
                else
                {
                    <div>
                        <label class="block text-xs font-medium mb-1">
                            String Length (L)
                            <span class="font-normal text-gray-400">m</span>
                        </label>
                        <input type="number" step="any" min="0"
                               class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               @bind="_stringLength" @bind:event="oninput" @bind:after="SaveState" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">
                            Wave Speed (v)
                            <span class="font-normal text-gray-400">m/s</span>
                        </label>
                        <input type="number" step="any" min="0"
                               class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               @bind="_stringWaveSpeed" @bind:event="oninput" @bind:after="SaveState" />
                    </div>
                }

                <button type="button"
                        class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                        @onclick="CalculateHarmonics">
                    <i class="ti ti-calculator mr-1"></i> Calculate Harmonics
                </button>
            </div>

            @if (_harmonicsCalculated && _harmonicFreqs.Length > 0)
            {
                <div>
                    <h3 class="text-sm font-semibold text-gray-500 mb-2">
                        <i class="ti ti-list-numbers mr-1"></i> First 8 Harmonics
                    </h3>
                    <div class="space-y-1">
                        @for (int idx = 0; idx < _harmonicFreqs.Length; idx++)
                        {
                            int n = idx + 1;
                            double freq = _harmonicFreqs[idx];
                            <div class="flex items-center gap-2 text-xs">
                                <span class="w-8 h-6 flex-shrink-0 inline-flex items-center justify-center rounded font-mono font-bold bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                                    n=@n
                                </span>
                                <span class="flex-1 font-mono text-gray-700 dark:text-gray-300">
                                    @FormatSI(freq) Hz
                                </span>
                                <span class="text-gray-400">
                                    @(n == 1 ? "fundamental" : n == 2 ? "2nd harmonic" : n == 3 ? "3rd harmonic" : $"{n}th harmonic")
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* Harmonic SVG visualizations *@
        @if (_harmonicsCalculated && _harmonicFreqs.Length > 0)
        {
            <div class="border-t border-gray-100 dark:border-gray-800 pt-3">
                <h3 class="text-sm font-semibold text-gray-500 mb-2">
                    <i class="ti ti-wave-sine mr-1"></i> Standing Wave Patterns (nodes and antinodes)
                </h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    @for (int idx = 0; idx < _harmonicFreqs.Length; idx++)
                    {
                        int harmonicN = idx + 1;
                        <div class="bg-gray-50 dark:bg-gray-900 rounded p-2">
                            <p class="text-xs font-semibold text-gray-500 mb-1 text-center">n = @harmonicN</p>
                            <svg viewBox="0 0 120 50" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg"
                                 aria-label="@($"Standing wave harmonic {harmonicN}")">
                                @* Fixed endpoints *@
                                <line x1="10" y1="25" x2="110" y2="25" stroke="#d1d5db" stroke-width="0.5" stroke-dasharray="2,2" />
                                <circle cx="10" cy="25" r="2.5" fill="#ef4444" />
                                <circle cx="110" cy="25" r="2.5" fill="#ef4444" />

                                @* Standing wave curve *@
                                @((MarkupString)StandingWaveSvgPath(harmonicN))

                                @* Node dots *@
                                @for (int nodeIdx = 1; nodeIdx < harmonicN; nodeIdx++)
                                {
                                    double nodeX = 10.0 + (100.0 * nodeIdx / harmonicN);
                                    <circle cx="@nodeX.ToString("F1", CultureInfo.InvariantCulture)" cy="25" r="2" fill="#ef4444" />
                                }
                            </svg>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* Decibel Calculator *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-volume mr-1"></i> Decibel Calculator
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @* Power ratio to dB *@
            <div class="space-y-3">
                <h3 class="text-sm font-semibold text-gray-500">
                    Power Ratio
                </h3>
                <p class="text-xs text-gray-400 font-mono">dB = 10 x log10(P2 / P1)</p>
                <div>
                    <label class="block text-xs font-medium mb-1">P2 / P1 ratio</label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_powerRatio" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                    <p class="text-xs text-gray-400 mb-0.5">Result</p>
                    <p class="text-lg font-bold text-blue-600 dark:text-blue-400 font-mono">
                        @F(CalcPowerDb) <span class="text-xs font-normal text-gray-500">dB</span>
                    </p>
                </div>

                <h3 class="text-sm font-semibold text-gray-500 pt-2">
                    dB to Power Ratio
                </h3>
                <div>
                    <label class="block text-xs font-medium mb-1">dB value</label>
                    <input type="number" step="any"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dbToPowerInput" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                    <p class="text-xs text-gray-400 mb-0.5">P2 / P1</p>
                    <p class="text-lg font-bold text-green-600 dark:text-green-400 font-mono">
                        @FormatSI(CalcDbToPowerRatio)
                    </p>
                </div>
            </div>

            @* Amplitude ratio to dB *@
            <div class="space-y-3">
                <h3 class="text-sm font-semibold text-gray-500">
                    Amplitude Ratio
                </h3>
                <p class="text-xs text-gray-400 font-mono">dB = 20 x log10(A2 / A1)</p>
                <div>
                    <label class="block text-xs font-medium mb-1">A2 / A1 ratio</label>
                    <input type="number" step="any" min="0"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_amplitudeRatio" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                    <p class="text-xs text-gray-400 mb-0.5">Result</p>
                    <p class="text-lg font-bold text-blue-600 dark:text-blue-400 font-mono">
                        @F(CalcAmplitudeDb) <span class="text-xs font-normal text-gray-500">dB</span>
                    </p>
                </div>

                <h3 class="text-sm font-semibold text-gray-500 pt-2">
                    dB to Amplitude Ratio
                </h3>
                <div>
                    <label class="block text-xs font-medium mb-1">dB value</label>
                    <input type="number" step="any"
                           class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           @bind="_dbToAmplitudeInput" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div class="bg-gray-50 dark:bg-gray-900 rounded p-3">
                    <p class="text-xs text-gray-400 mb-0.5">A2 / A1</p>
                    <p class="text-lg font-bold text-green-600 dark:text-green-400 font-mono">
                        @FormatSI(CalcDbToAmplitudeRatio)
                    </p>
                </div>

                <div class="border-t border-gray-100 dark:border-gray-800 pt-3 mt-2">
                    <h3 class="text-sm font-semibold text-gray-500 mb-2">
                        <i class="ti ti-info-circle mr-1"></i> Common Reference Levels
                    </h3>
                    <div class="space-y-1 text-xs text-gray-500">
                        <div class="flex justify-between">
                            <span class="font-semibold">dB SPL</span>
                            <span class="font-mono">ref 20 uPa (threshold of hearing)</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="font-semibold">dBm</span>
                            <span class="font-mono">ref 1 mW (telecommunications)</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="font-semibold">dBW</span>
                            <span class="font-mono">ref 1 W (power systems)</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="font-semibold">dBV</span>
                            <span class="font-mono">ref 1 V (voltage measurements)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3 flex items-center gap-2">
            <button type="button"
                    class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                    @onclick="CopyDecibelResults">
                <i class="ti ti-copy mr-1"></i> Copy dB Results
            </button>
        </div>
    </div>

</div>

@* Disclaimer *@
<p class="text-xs text-gray-400 text-center italic mt-4">
    <i class="ti ti-info-circle mr-1"></i> All calculations assume ideal conditions. EM spectrum bands are approximate boundaries.
</p>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/math/waves" OnRestore="RestoreState" />

@code {

    // ================================================================
    // Delegate wrappers for extracted static methods
    // ================================================================

    static string F(double val) => WaveCalculatorCore.F(val);
    static string FormatSI(double val) => WaveCalculatorCore.FormatSI(val);
    static string StandingWaveSvgPath(int harmonicNumber) => WaveCalculatorCore.StandingWaveSvgPath(harmonicNumber);
    static string WavelengthToHexColour(double wavelengthM) => WaveCalculatorCore.WavelengthToHexColour(wavelengthM);

    // ================================================================
    // Persistence
    // ================================================================

    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(
        string SolveMode, string MediumPreset,
        double Velocity, double Frequency, double Wavelength, double Amplitude,
        double DopplerSourceFreq, double DopplerMediumVel, double DopplerObserverVel, double DopplerSourceVel,
        string HarmonicMode, double FundamentalFreq, double StringLength, double StringWaveSpeed,
        double PowerRatio, double AmplitudeRatio, double DbToPowerInput, double DbToAmplitudeInput);

    const string ToolKey = "tools/math/waves";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>(ToolKey);
            if (state is not null)
            {
                _solveMode = state.SolveMode;
                _mediumPreset = state.MediumPreset;
                _velocity = state.Velocity;
                _frequency = state.Frequency;
                _wavelength = state.Wavelength;
                _amplitude = state.Amplitude;
                _dopplerSourceFreq = state.DopplerSourceFreq;
                _dopplerMediumVel = state.DopplerMediumVel;
                _dopplerObserverVel = state.DopplerObserverVel;
                _dopplerSourceVel = state.DopplerSourceVel;
                _harmonicMode = state.HarmonicMode;
                _fundamentalFreq = state.FundamentalFreq;
                _stringLength = state.StringLength;
                _stringWaveSpeed = state.StringWaveSpeed;
                _powerRatio = state.PowerRatio;
                _amplitudeRatio = state.AmplitudeRatio;
                _dbToPowerInput = state.DbToPowerInput;
                _dbToAmplitudeInput = state.DbToAmplitudeInput;
                StateHasChanged();
            }
        }
    }

    async Task SaveState()
    {
        await Storage.SaveStateAsync(ToolKey, new ToolState(
            _solveMode, _mediumPreset,
            _velocity, _frequency, _wavelength, _amplitude,
            _dopplerSourceFreq, _dopplerMediumVel, _dopplerObserverVel, _dopplerSourceVel,
            _harmonicMode, _fundamentalFreq, _stringLength, _stringWaveSpeed,
            _powerRatio, _amplitudeRatio, _dbToPowerInput, _dbToAmplitudeInput));
    }

    async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _solveMode = state.SolveMode;
            _mediumPreset = state.MediumPreset;
            _velocity = state.Velocity;
            _frequency = state.Frequency;
            _wavelength = state.Wavelength;
            _amplitude = state.Amplitude;
            _dopplerSourceFreq = state.DopplerSourceFreq;
            _dopplerMediumVel = state.DopplerMediumVel;
            _dopplerObserverVel = state.DopplerObserverVel;
            _dopplerSourceVel = state.DopplerSourceVel;
            _harmonicMode = state.HarmonicMode;
            _fundamentalFreq = state.FundamentalFreq;
            _stringLength = state.StringLength;
            _stringWaveSpeed = state.StringWaveSpeed;
            _powerRatio = state.PowerRatio;
            _amplitudeRatio = state.AmplitudeRatio;
            _dbToPowerInput = state.DbToPowerInput;
            _dbToAmplitudeInput = state.DbToAmplitudeInput;
            StateHasChanged();
        }
    }

    // ================================================================
    // Core wave state
    // ================================================================

    string _solveMode = "wavelength";
    string _mediumPreset = "custom";
    double _velocity = 343.0;
    double _frequency = 440.0;
    double _wavelength = 0.78;
    double _amplitude = 1.0;
    bool _waveCalculated = false;

    // ================================================================
    // Doppler state
    // ================================================================

    double _dopplerSourceFreq = 440.0;
    double _dopplerMediumVel = 343.0;
    double _dopplerObserverVel = 0.0;
    double _dopplerSourceVel = 30.0;
    bool _dopplerCalculated = false;
    double _dopplerApproaching = 0.0;
    double _dopplerReceding = 0.0;

    // ================================================================
    // Harmonics state
    // ================================================================

    string _harmonicMode = "fundamental";
    double _fundamentalFreq = 261.6;
    double _stringLength = 0.65;
    double _stringWaveSpeed = 343.0;
    bool _harmonicsCalculated = false;
    double[] _harmonicFreqs = Array.Empty<double>();

    // ================================================================
    // Decibel state
    // ================================================================

    double _powerRatio = 2.0;
    double _amplitudeRatio = 2.0;
    double _dbToPowerInput = 3.0;
    double _dbToAmplitudeInput = 6.0;

    // ================================================================
    // Derived wave properties
    // ================================================================

    double CalcPeriod => _frequency > 0 ? 1.0 / _frequency : 0.0;
    double CalcOmega => 2.0 * Math.PI * _frequency;
    double CalcWaveNumber => _wavelength > 0 ? 2.0 * Math.PI / _wavelength : 0.0;

    // ================================================================
    // Decibel calculations
    // ================================================================

    double CalcPowerDb => _powerRatio > 0 ? 10.0 * Math.Log10(_powerRatio) : 0.0;
    double CalcAmplitudeDb => _amplitudeRatio > 0 ? 20.0 * Math.Log10(_amplitudeRatio) : 0.0;
    double CalcDbToPowerRatio => Math.Pow(10.0, _dbToPowerInput / 10.0);
    double CalcDbToAmplitudeRatio => Math.Pow(10.0, _dbToAmplitudeInput / 20.0);

    // ================================================================
    // Event handlers
    // ================================================================

    async Task OnMediumChange(ChangeEventArgs e)
    {
        string val = e.Value?.ToString() ?? "custom";
        _mediumPreset = val;

        _velocity = val switch
        {
            "light" => 3e8,
            "air"   => 343.0,
            "water" => 1480.0,
            "steel" => 5960.0,
            _       => _velocity
        };

        if (val != "custom" && _solveMode == "velocity")
        {
            _solveMode = "wavelength";
        }
        await SaveState();
    }

    async Task OnSolveModeChange(ChangeEventArgs e)
    {
        string val = e.Value?.ToString() ?? "wavelength";
        if (val == "velocity" && _mediumPreset != "custom")
        {
            return;
        }
        _solveMode = val;
        await SaveState();
    }

    async Task OnHarmonicModeChange(ChangeEventArgs e)
    {
        _harmonicMode = e.Value?.ToString() ?? "fundamental";
        await SaveState();
    }

    async Task ApplyExample(WaveCalculatorCore.WaveExample ex)
    {
        _mediumPreset = ex.Medium;
        _velocity = ex.Velocity;
        _frequency = ex.Frequency;
        _wavelength = ex.Wavelength;
        _solveMode = ex.SolveFor;
        _waveCalculated = true;
        await SaveState();
        await Storage.AddRecentAsync(ToolKey, ex.Label, new ToolState(
            _solveMode, _mediumPreset,
            _velocity, _frequency, _wavelength, _amplitude,
            _dopplerSourceFreq, _dopplerMediumVel, _dopplerObserverVel, _dopplerSourceVel,
            _harmonicMode, _fundamentalFreq, _stringLength, _stringWaveSpeed,
            _powerRatio, _amplitudeRatio, _dbToPowerInput, _dbToAmplitudeInput));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    // ================================================================
    // Core wave calculation
    // ================================================================

    void CalculateWave()
    {
        if (_solveMode == "wavelength" && _velocity > 0 && _frequency > 0)
        {
            _wavelength = _velocity / _frequency;
        }
        else if (_solveMode == "frequency" && _velocity > 0 && _wavelength > 0)
        {
            _frequency = _velocity / _wavelength;
        }
        else if (_solveMode == "velocity" && _frequency > 0 && _wavelength > 0)
        {
            _velocity = _frequency * _wavelength;
        }

        _waveCalculated = true;
    }

    // ================================================================
    // Doppler calculation
    // ================================================================

    void CalculateDoppler()
    {
        double f = _dopplerSourceFreq;
        double v = _dopplerMediumVel;
        double vo = Math.Abs(_dopplerObserverVel);
        double vs = Math.Abs(_dopplerSourceVel);

        double denomApproach = v - vs;
        double denomRecede = v + vs;

        if (denomApproach > 0)
        {
            _dopplerApproaching = f * (v + vo) / denomApproach;
        }
        else
        {
            _dopplerApproaching = double.PositiveInfinity;
        }

        if (denomRecede > 0)
        {
            _dopplerReceding = f * (v - vo) / denomRecede;
        }
        else
        {
            _dopplerReceding = 0.0;
        }

        _dopplerCalculated = true;
    }

    // ================================================================
    // Harmonics calculation
    // ================================================================

    void CalculateHarmonics()
    {
        double f1 = 0.0;

        if (_harmonicMode == "fundamental")
        {
            f1 = _fundamentalFreq;
        }
        else if (_stringLength > 0 && _stringWaveSpeed > 0)
        {
            f1 = _stringWaveSpeed / (2.0 * _stringLength);
        }

        if (f1 > 0)
        {
            double[] freqs = new double[8];
            for (int i = 0; i < 8; i++)
            {
                freqs[i] = f1 * (i + 1);
            }
            _harmonicFreqs = freqs;
            _harmonicsCalculated = true;
        }
    }

    // ================================================================
    // SVG wave visualization helpers
    // ================================================================

    string SineWavePoints
    {
        get
        {
            System.Text.StringBuilder sb = new();
            int steps = 200;
            double totalX = 440.0;
            double startX = 40.0;

            for (int i = 0; i <= steps; i++)
            {
                double t = (double)i / steps;
                double x = startX + t * totalX;
                double angle = t * 2.0 * 2.0 * Math.PI;
                double y = 100.0 - _amplitude * 70.0 * Math.Sin(angle);

                if (i > 0) sb.Append(' ');
                sb.Append(x.ToString("F1", CultureInfo.InvariantCulture));
                sb.Append(',');
                sb.Append(y.ToString("F1", CultureInfo.InvariantCulture));
            }

            return sb.ToString();
        }
    }

    string SvgWaveY(double amp)
    {
        double y = 100.0 - amp * 70.0;
        return y.ToString("F0", CultureInfo.InvariantCulture);
    }

    string WavelengthAnnotationSvg()
    {
        double lambdaPixels = 220.0;
        double x1 = 40.0;
        double x2 = x1 + lambdaPixels;
        double yLine = 185.0;

        System.Text.StringBuilder sb = new();
        sb.Append($"<line x1=\"{x1:F0}\" y1=\"{yLine:F0}\" x2=\"{x2:F0}\" y2=\"{yLine:F0}\" stroke=\"#22c55e\" stroke-width=\"1.5\"/>");
        sb.Append($"<line x1=\"{x1:F0}\" y1=\"{yLine - 4:F0}\" x2=\"{x1:F0}\" y2=\"{yLine + 4:F0}\" stroke=\"#22c55e\" stroke-width=\"1.5\"/>");
        sb.Append($"<line x1=\"{x2:F0}\" y1=\"{yLine - 4:F0}\" x2=\"{x2:F0}\" y2=\"{yLine + 4:F0}\" stroke=\"#22c55e\" stroke-width=\"1.5\"/>");

        double midX = (x1 + x2) / 2.0;
        sb.Append($"<text x=\"{midX:F0}\" y=\"{yLine - 5:F0}\" fill=\"#22c55e\" font-size=\"9\" text-anchor=\"middle\" font-weight=\"bold\">lambda</text>");

        return sb.ToString();
    }

    // ================================================================
    // EM spectrum helpers
    // ================================================================

    bool IsInBand(WaveCalculatorCore.EmBand band)
    {
        return _wavelength >= band.MinWavelength && _wavelength < band.MaxWavelength;
    }

    // ================================================================
    // Copy to clipboard
    // ================================================================

    async Task CopyWaveResults()
    {
        System.Text.StringBuilder sb = new();
        sb.AppendLine("Wave Properties:");
        sb.AppendLine($"  Velocity (v):        {FormatSI(_velocity)} m/s");
        sb.AppendLine($"  Frequency (f):       {FormatSI(_frequency)} Hz");
        sb.AppendLine($"  Wavelength (lambda):  {FormatSI(_wavelength)} m");
        sb.AppendLine($"  Period (T):          {FormatSI(CalcPeriod)} s");
        sb.AppendLine($"  Angular freq (omega): {FormatSI(CalcOmega)} rad/s");
        sb.AppendLine($"  Wave number (k):     {FormatSI(CalcWaveNumber)} rad/m");
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", sb.ToString());
    }

    async Task CopyDopplerResults()
    {
        System.Text.StringBuilder sb = new();
        sb.AppendLine("Doppler Effect:");
        sb.AppendLine($"  Source frequency:  {FormatSI(_dopplerSourceFreq)} Hz");
        sb.AppendLine($"  Medium velocity:   {F(_dopplerMediumVel)} m/s");
        sb.AppendLine($"  Observer velocity: {F(_dopplerObserverVel)} m/s");
        sb.AppendLine($"  Source velocity:   {F(_dopplerSourceVel)} m/s");
        sb.AppendLine($"  Approaching:       {FormatSI(_dopplerApproaching)} Hz");
        sb.AppendLine($"  Receding:          {FormatSI(_dopplerReceding)} Hz");
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", sb.ToString());
    }

    async Task CopyDecibelResults()
    {
        System.Text.StringBuilder sb = new();
        sb.AppendLine("Decibel Calculations:");
        sb.AppendLine($"  Power ratio {F(_powerRatio)} = {F(CalcPowerDb)} dB");
        sb.AppendLine($"  Amplitude ratio {F(_amplitudeRatio)} = {F(CalcAmplitudeDb)} dB");
        sb.AppendLine($"  {F(_dbToPowerInput)} dB = power ratio {FormatSI(CalcDbToPowerRatio)}");
        sb.AppendLine($"  {F(_dbToAmplitudeInput)} dB = amplitude ratio {FormatSI(CalcDbToAmplitudeRatio)}");
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", sb.ToString());
    }
}
