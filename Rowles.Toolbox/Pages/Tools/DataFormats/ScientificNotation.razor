@page "/tools/data/scientific"
@using System.Globalization
@using Rowles.Toolbox.Core.DataFormats
@inject IJSRuntime Js
@inject LocalStorageService Storage

<PageTitle>Scientific Notation - Rowles.Toolbox</PageTitle>

<PageHeader Title="Scientific Notation Converter" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-math-function mr-1"></i> Convert between standard and scientific notation</span>
    </Actions>
</PageHeader>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    @* -- Input -- *@
    <div>
        <label class="block text-sm font-medium mb-1">Input Number</label>
        <input type="text" class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="e.g. 6.022e23, 0.00042, 1500000"
               @bind="_input"
               @bind:event="oninput"
               @bind:after="SaveState"
               @onkeyup="Convert" />

        <div class="flex flex-wrap gap-1 mt-2">
            @foreach ((string Label, string Value) sample in _samples)
            {
                <button class="bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 px-2 py-0.5 text-[10px] rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
                        @onclick="() => SetSample(sample.Value)">
                    @sample.Label
                </button>
            }
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 p-2 rounded text-xs mt-2">
                <i class="ti ti-alert-circle mr-1"></i> @_error
            </div>
        }

        <div class="flex items-center gap-2 mt-3">
            <label class="text-xs text-gray-500">Significant figures:</label>
            <input type="number" min="1" max="20" class="w-14 p-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-xs font-mono focus:ring-2 focus:ring-blue-500"
                   @bind="_sigFigs"
                   @bind:event="oninput"
                   @bind:after="SaveState"
                   @onchange="Convert" />
        </div>

        <button class="mt-3 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-medium rounded hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors inline-flex items-center gap-1"
                @onclick="Clear">
            <i class="ti ti-trash"></i> Clear
        </button>
    </div>

    @* -- Results -- *@
    <div class="lg:col-span-2">
        @if (_hasResult)
        {
            <div class="info-grid mb-4">
                <div class="info-row">
                    <span class="info-label">Input</span>
                    <span class="info-value font-mono">@_input</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Scientific Notation</span>
                    <span class="info-value font-mono cursor-pointer hover:text-blue-500" @onclick="() => CopyToClipboard(_scientificStr)">
                        @_scientificStr
                        <i class="ti ti-copy ml-1 text-gray-400 text-[10px]"></i>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Scientific (Unicode)</span>
                    <span class="info-value font-mono cursor-pointer hover:text-blue-500" @onclick="() => CopyToClipboard(_scientificUnicode)">
                        @_scientificUnicode
                        <i class="ti ti-copy ml-1 text-gray-400 text-[10px]"></i>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Engineering Notation</span>
                    <span class="info-value font-mono cursor-pointer hover:text-blue-500" @onclick="() => CopyToClipboard(_engineeringStr)">
                        @_engineeringStr
                        <i class="ti ti-copy ml-1 text-gray-400 text-[10px]"></i>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Coefficient</span>
                    <span class="info-value font-mono">@_coefficient</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Exponent</span>
                    <span class="info-value font-mono">@_exponent</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Decimal Expansion</span>
                    <span class="info-value font-mono break-all cursor-pointer hover:text-blue-500" @onclick="() => CopyToClipboard(_decimalExpansion)">
                        @_decimalExpansion
                        <i class="ti ti-copy ml-1 text-gray-400 text-[10px]"></i>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Sign</span>
                    <span class="info-value font-mono">@(_isNegative ? "Negative (−)" : "Positive (+)")</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_siPrefix))
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded p-3">
                    <h3 class="text-xs font-semibold text-gray-500 mb-1">
                        <i class="ti ti-ruler mr-1"></i> SI Prefix
                    </h3>
                    <span class="text-sm font-mono">@_siPrefix</span>
                </div>
            }
        }
        else
        {
            <div class="text-xs text-gray-400 italic p-4 border border-dashed border-gray-300 dark:border-gray-600 rounded">
                Enter a number in standard or scientific notation to see conversions.
            </div>
        }
    </div>
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/data/scientific" OnRestore="RestoreState" />

@code {
    private string _input = string.Empty;
    private int _sigFigs = 6;
    private string? _error;
    private bool _hasResult;
    private string _scientificStr = string.Empty;
    private string _scientificUnicode = string.Empty;
    private string _engineeringStr = string.Empty;
    private string _coefficient = string.Empty;
    private string _decimalExpansion = string.Empty;
    private int _exponent;
    private bool _isNegative;
    private string? _siPrefix;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(string Input, int SigFigs);

    private static readonly (string Label, string Value)[] _samples =
    [
        ("Avogadro", "6.02214076e23"),
        ("Speed of Light", "299792458"),
        ("Planck", "6.62607015e-34"),
        ("Electron Mass", "9.1093837015e-31"),
        ("Pi Million", "3141592.653589793"),
        ("Tiny", "0.000000000042"),
    ];

    private async Task SetSample(string value)
    {
        _input = value;
        await Convert();
    }

    private async Task Convert()
    {
        _error = null;
        _hasResult = false;
        _siPrefix = null;

        if (string.IsNullOrWhiteSpace(_input)) return;

        string cleaned = _input.Trim();

        if (!double.TryParse(cleaned, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out double value))
        {
            _error = "Invalid number. Use standard or scientific notation (e.g. 1.5e10).";
            return;
        }

        if (double.IsNaN(value) || double.IsInfinity(value))
        {
            _error = "NaN and Infinity are not supported.";
            return;
        }

        _isNegative = value < 0;
        double absValue = Math.Abs(value);

        // Calculate exponent
        if (absValue == 0)
        {
            _exponent = 0;
            _coefficient = "0";
        }
        else
        {
            _exponent = (int)Math.Floor(Math.Log10(absValue));
            double coeff = absValue / Math.Pow(10, _exponent);
            // Round to sig figs
            int sigFigs = Math.Max(1, Math.Min(20, _sigFigs));
            _coefficient = FormatCoefficient(coeff, sigFigs);
        }

        string sign = _isNegative ? "-" : "";

        // Scientific notation
        _scientificStr = absValue == 0
            ? "0"
            : $"{sign}{_coefficient} × 10^{_exponent}";

        // Unicode superscript
        _scientificUnicode = absValue == 0
            ? "0"
            : $"{sign}{_coefficient} × 10{ToSuperscript(_exponent)}";

        // Engineering notation (exponent multiple of 3)
        int engExponent = _exponent >= 0
            ? _exponent - _exponent % 3
            : _exponent - ((_exponent % 3 + 3) % 3);
        double engCoeff = absValue / Math.Pow(10, engExponent);
        string engCoeffStr = FormatCoefficient(engCoeff, Math.Max(1, Math.Min(20, _sigFigs)));
        _engineeringStr = absValue == 0
            ? "0"
            : $"{sign}{engCoeffStr} × 10^{engExponent}";

        // Decimal expansion
        _decimalExpansion = FormatDecimalExpansion(value);

        // SI prefix
        _siPrefix = GetSiPrefix(_exponent);

        _hasResult = true;
        await SaveState();
        string label = $"{_input} ({_sigFigs} sig figs)";
        await Storage.AddRecentAsync("tools/data/scientific", label, new ToolState(_input, _sigFigs));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    private static string FormatCoefficient(double coeff, int sigFigs) => ScientificNotationCore.FormatCoefficient(coeff, sigFigs);
    private static string ToSuperscript(int number) => ScientificNotationCore.ToSuperscript(number);
    private static string FormatDecimalExpansion(double value) => ScientificNotationCore.FormatDecimalExpansion(value);
    private static string? GetSiPrefix(int exponent) => ScientificNotationCore.GetSiPrefix(exponent);

    private void Clear()
    {
        _input = string.Empty;
        _error = null;
        _hasResult = false;
    }

    private async Task CopyToClipboard(string text)
    {
        if (!string.IsNullOrEmpty(text))
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/data/scientific");
            if (state is not null)
            {
                _input = state.Input;
                _sigFigs = state.SigFigs;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/data/scientific", new ToolState(_input, _sigFigs));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _input = state.Input;
            _sigFigs = state.SigFigs;
            StateHasChanged();
        }
    }
}