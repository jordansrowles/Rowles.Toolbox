@page "/tools/web/fonts"
@using Rowles.Toolbox.Core.WebNetwork
@inject IJSRuntime JS
@inject LocalStorageService Storage

<PageTitle>Font Previewer - Rowles.Toolbox</PageTitle>

<PageHeader Title="Font Previewer" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-typography mr-1"></i> Preview Google Fonts and system fonts with custom sample text</span>
    </Actions>
</PageHeader>

<div class="space-y-4">
    @* Sample Text Input *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <label class="block text-sm font-medium mb-1">
            <i class="ti ti-text-size mr-1"></i> Sample Text
        </label>
        <input type="text"
               class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="Type your preview text here..."
               @bind="_sampleText"
               @bind:after="SaveState" />
    </div>

    @* Controls Row *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-adjustments mr-1"></i> Controls</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 text-xs">
            @* Font Size *@
            <div>
                <label class="text-gray-500 block mb-1">Size</label>
                <div class="flex items-center gap-2">
                    <input type="range" min="12" max="72" class="flex-1"
                           value="@_fontSize"
                           @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _fontSize = v; await SaveState(); } }" />
                    <span class="text-gray-400 w-10 text-right font-mono">@(_fontSize)px</span>
                </div>
            </div>

            @* Font Weight *@
            <div>
                <label class="text-gray-500 block mb-1">Weight</label>
                <select class="w-full px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300"
                        value="@_fontWeight"
                        @onchange="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _fontWeight = v; await SaveState(); } }">
                    <option value="100">100 Thin</option>
                    <option value="200">200 Extra Light</option>
                    <option value="300">300 Light</option>
                    <option value="400">400 Regular</option>
                    <option value="500">500 Medium</option>
                    <option value="600">600 Semi Bold</option>
                    <option value="700">700 Bold</option>
                    <option value="800">800 Extra Bold</option>
                    <option value="900">900 Black</option>
                </select>
            </div>

            @* Italic Toggle *@
            <div>
                <label class="text-gray-500 block mb-1">Style</label>
                <button type="button"
                        class="w-full px-2 py-1 rounded border cursor-pointer @(_isItalic ? "bg-blue-600 text-white border-blue-600" : "border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700")"
                        @onclick="async () => { _isItalic = !_isItalic; await SaveState(); }">
                    <i class="ti ti-italic mr-0.5"></i> @(_isItalic ? "Italic" : "Normal")
                </button>
            </div>

            @* Letter Spacing *@
            <div>
                <label class="text-gray-500 block mb-1">Letter Spacing</label>
                <div class="flex items-center gap-2">
                    <input type="range" min="-5" max="20" step="0.5" class="flex-1"
                           value="@_letterSpacing"
                           @oninput="OnLetterSpacingInput" />
                    <span class="text-gray-400 w-12 text-right font-mono">@(_letterSpacing)px</span>
                </div>
            </div>

            @* Line Height *@
            <div>
                <label class="text-gray-500 block mb-1">Line Height</label>
                <div class="flex items-center gap-2">
                    <input type="range" min="0.8" max="3.0" step="0.1" class="flex-1"
                           value="@_lineHeight"
                           @oninput="OnLineHeightInput" />
                    <span class="text-gray-400 w-10 text-right font-mono">@(_lineHeight.ToString("F1"))</span>
                </div>
            </div>
        </div>
    </div>

    @* Category Filters and Search *@
    <div class="flex flex-wrap gap-2 items-center">
        <input type="text"
               class="flex-1 min-w-[200px] p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="Search fonts..."
               @bind="_searchTerm"
               @bind:after="SaveState" />
        <div class="flex gap-1 text-xs">
            <button type="button" class="@CategoryBtnClass(null)" @onclick="async () => { _categoryFilter = null; await SaveState(); }">All</button>
            <button type="button" class="@CategoryBtnClass("Sans-Serif")" @onclick="@(async () => { _categoryFilter = "Sans-Serif"; await SaveState(); })">
                <i class="ti ti-letter-a mr-0.5"></i> Sans-Serif
            </button>
            <button type="button" class="@CategoryBtnClass("Serif")" @onclick="@(async () => { _categoryFilter = "Serif"; await SaveState(); })">
                <i class="ti ti-letter-s mr-0.5"></i> Serif
            </button>
            <button type="button" class="@CategoryBtnClass("Monospace")" @onclick="@(async () => { _categoryFilter = "Monospace"; await SaveState(); })">
                <i class="ti ti-code mr-0.5"></i> Monospace
            </button>
            <button type="button" class="@CategoryBtnClass("Display")" @onclick="@(async () => { _categoryFilter = "Display"; await SaveState(); })">
                <i class="ti ti-sparkles mr-0.5"></i> Display
            </button>
            <button type="button" class="@CategoryBtnClass("System")" @onclick="@(async () => { _categoryFilter = "System"; await SaveState(); })">
                <i class="ti ti-device-desktop mr-0.5"></i> System
            </button>
        </div>
    </div>

    @* Font Count *@
    <div class="text-xs text-gray-400">
        <i class="ti ti-list mr-0.5"></i> Showing @FilteredFonts.Count of @FontPreviewerCore.AllFonts.Count fonts
    </div>

    @* Font Cards Grid *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        @foreach (FontPreviewerCore.FontEntry font in FilteredFonts)
        {
            bool isExpanded = _expandedFont == font.Name;
            <div class="border rounded transition-all cursor-pointer @(isExpanded ? "border-blue-400 dark:border-blue-600 bg-blue-50/50 dark:bg-blue-900/10" : "border-gray-200 dark:border-gray-700 hover:border-gray-400 dark:hover:border-gray-500")"
                 @onclick="() => ToggleExpanded(font)">
                <div class="p-4">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-semibold">@font.Name</span>
                            <span class="text-[10px] px-1.5 py-0.5 rounded-full @FontPreviewerCore.CategoryBadgeClass(font.Category)">@font.Category</span>
                        </div>
                        <i class="ti @(isExpanded ? "ti-chevron-up" : "ti-chevron-down") text-gray-400 text-sm"></i>
                    </div>
                    <div class="overflow-hidden rounded bg-white dark:bg-gray-900 p-3 border border-gray-100 dark:border-gray-800"
                         style="font-family: '@font.Name', @font.Fallback; font-size: @(_fontSize)px; font-weight: @_fontWeight; font-style: @(_isItalic ? "italic" : "normal"); letter-spacing: @(_letterSpacing)px; line-height: @(_lineHeight.ToString("F1"));">
                        @_sampleText
                    </div>
                </div>

                @if (isExpanded)
                {
                    <div class="border-t border-gray-200 dark:border-gray-700 p-4 space-y-3" @onclick:stopPropagation="true">
                        @* CSS Declaration *@
                        <div>
                            <div class="flex items-center justify-between mb-1">
                                <span class="text-xs font-semibold text-gray-500">CSS Declaration</span>
                                <button type="button"
                                        class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 cursor-pointer transition-colors"
                                        @onclick="() => CopyToClipboard(FontPreviewerCore.GetCssDeclaration(font))">
                                    <i class="ti ti-copy mr-0.5"></i> Copy
                                </button>
                            </div>
                            <code class="block text-xs font-mono bg-gray-100 dark:bg-gray-800 rounded p-2 text-gray-700 dark:text-gray-300">@FontPreviewerCore.GetCssDeclaration(font)</code>
                        </div>

                        @* Available Weights Preview *@
                        @if (font.Weights.Length > 1)
                        {
                            <div>
                                <span class="text-xs font-semibold text-gray-500 mb-2 block">Available Weights</span>
                                <div class="space-y-2">
                                    @foreach (int weight in font.Weights)
                                    {
                                        <div class="flex items-center gap-3">
                                            <span class="text-[10px] font-mono text-gray-400 w-8 shrink-0">@weight</span>
                                            <span class="text-sm overflow-hidden text-ellipsis whitespace-nowrap"
                                                  style="font-family: '@font.Name', @font.Fallback; font-weight: @weight; font-style: @(_isItalic ? "italic" : "normal");">
                                                @_sampleText
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @* Google Fonts Link (for non-system fonts) *@
                        @if (!font.IsSystem)
                        {
                            <div>
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-xs font-semibold text-gray-500">Google Fonts Link</span>
                                    <button type="button"
                                            class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 cursor-pointer transition-colors"
                                            @onclick="() => CopyToClipboard(FontPreviewerCore.GetGoogleFontsUrl(font))">
                                        <i class="ti ti-copy mr-0.5"></i> Copy
                                    </button>
                                </div>
                                <code class="block text-xs font-mono bg-gray-100 dark:bg-gray-800 rounded p-2 text-gray-700 dark:text-gray-300 break-all">@FontPreviewerCore.GetGoogleFontsUrl(font)</code>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (FilteredFonts.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-12 text-gray-400">
            <i class="ti ti-typography-off text-4xl mb-2"></i>
            <span class="text-sm">No fonts match your search.</span>
        </div>
    }
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/web/fonts" OnRestore="RestoreState" />

@code {
    private RecentEntryPanel? _recentPanel;
    private string _sampleText = "The quick brown fox jumps over the lazy dog";
    private int _fontSize = 24;
    private int _fontWeight = 400;
    private bool _isItalic;
    private double _letterSpacing;
    private double _lineHeight = 1.4;
    private string _searchTerm = string.Empty;
    private string? _categoryFilter;
    private string? _expandedFont;
    private HashSet<string> _loadedFonts = new(StringComparer.Ordinal);

    sealed record ToolState(
        string SampleText,
        int FontSize,
        int FontWeight,
        bool IsItalic,
        double LetterSpacing,
        double LineHeight,
        string SearchTerm,
        string? CategoryFilter
    );

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadState();
            foreach (FontPreviewerCore.FontEntry font in FontPreviewerCore.AllFonts.Where(f => !f.IsSystem))
            {
                await LoadGoogleFont(font);
            }
        }
    }

    private async Task LoadState()
    {
        ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/web/fonts");
        if (state is not null)
        {
            _sampleText = state.SampleText;
            _fontSize = state.FontSize;
            _fontWeight = state.FontWeight;
            _isItalic = state.IsItalic;
            _letterSpacing = state.LetterSpacing;
            _lineHeight = state.LineHeight;
            _searchTerm = state.SearchTerm;
            _categoryFilter = state.CategoryFilter;
            StateHasChanged();
        }
    }

    private async Task SaveState()
    {
        ToolState state = new(_sampleText, _fontSize, _fontWeight, _isItalic, _letterSpacing, _lineHeight, _searchTerm, _categoryFilter);
        await Storage.SaveStateAsync("tools/web/fonts", state);
    }

    private async Task RestoreState(string json)
    {
        try
        {
            ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
            if (state is not null)
            {
                _sampleText = state.SampleText;
                _fontSize = state.FontSize;
                _fontWeight = state.FontWeight;
                _isItalic = state.IsItalic;
                _letterSpacing = state.LetterSpacing;
                _lineHeight = state.LineHeight;
                _searchTerm = state.SearchTerm;
                _categoryFilter = state.CategoryFilter;
                StateHasChanged();
                await SaveState();
            }
        }
        catch { /* ignore invalid JSON */ }
    }

    private async Task OnLetterSpacingInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out double v))
        {
            _letterSpacing = v;
            await SaveState();
        }
    }

    private async Task OnLineHeightInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out double v))
        {
            _lineHeight = v;
            await SaveState();
        }
    }

    private async Task LoadGoogleFont(FontPreviewerCore.FontEntry font)
    {
        if (font.IsSystem || _loadedFonts.Contains(font.Name))
            return;

        _loadedFonts.Add(font.Name);
        string url = FontPreviewerCore.GetGoogleFontsUrl(font);
        string escapedUrl = url.Replace("'", "\\'");
        string js = $"(function(){{ if(!document.querySelector('link[href=\\'{escapedUrl}\\']')){{ var l=document.createElement('link'); l.rel='stylesheet'; l.href='{escapedUrl}'; document.head.appendChild(l); }} }})()";
        await JS.InvokeVoidAsync("eval", js);
    }

    private void ToggleExpanded(FontPreviewerCore.FontEntry font)
    {
        if (_expandedFont == font.Name)
        {
            _expandedFont = null;
        }
        else
        {
            _expandedFont = font.Name;
        }
    }

    private async Task CopyToClipboard(string content)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
    }

    private List<FontPreviewerCore.FontEntry> FilteredFonts
    {
        get
        {
            IEnumerable<FontPreviewerCore.FontEntry> result = FontPreviewerCore.AllFonts;
            if (_categoryFilter is not null)
                result = result.Where(f => f.Category == _categoryFilter);
            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                string term = _searchTerm.Trim();
                result = result.Where(f =>
                    f.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    f.Category.Contains(term, StringComparison.OrdinalIgnoreCase));
            }
            return result.ToList();
        }
    }

    private string CategoryBtnClass(string? category) =>
        _categoryFilter == category
            ? "px-2 py-1 rounded bg-blue-600 text-white cursor-pointer"
            : "px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 cursor-pointer";
}
