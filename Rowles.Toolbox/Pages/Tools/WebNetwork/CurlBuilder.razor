    private async Task CopyCommand()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", GeneratedCommand);
        _copied = true;
        await Storage.AddRecentAsync("tools/web/curl-builder",
            $"{_method} {(string.IsNullOrWhiteSpace(_url) ? "(no URL)" : _url)}",
            new ToolState(_url, _method, _bodyContent, _bodyMode,
                _selectedBodyContentType, _authType, _basicUser,
                _basicPass, _bearerToken, _apiKeyHeader, _apiKeyValue,
                _flagVerbose, _flagInsecure, _flagFollowRedirects, _flagSilent,
                _flagHeadOnly, _flagCompressed, _flagHttp2, _flagHttp11,
                _flagOutputFile, _outputFilename, _flagConnectTimeout,
                _connectTimeoutSeconds, _flagMaxTime, _maxTimeSeconds,
                _multiLine, _outputMode));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        await Task.Delay(1500);
        _copied = false;
    }
