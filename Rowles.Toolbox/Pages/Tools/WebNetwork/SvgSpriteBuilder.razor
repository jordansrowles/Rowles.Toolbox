@page "/tools/web/svg-sprite"
@using Rowles.Toolbox.Core.WebNetwork
@inject IJSRuntime Js
@inject LocalStorageService Storage

<PageTitle>SVG Sprite Builder - Rowles.Toolbox</PageTitle>

<PageHeader Title="SVG Sprite Builder" BackUrl="/" BackLabel="Home">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-icons mr-1"></i> Merge SVGs into a symbol-based sprite sheet</span>
    </Actions>
</PageHeader>

<div class="space-y-4">

    @* ── Input area ── *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold text-gray-500 mb-3">
            <i class="ti ti-code-plus mr-1"></i> Add SVG Icons
        </h3>
        <textarea class="w-full h-40 p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-xs font-mono resize-y focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Paste one or more SVG elements here.&#10;Separate multiple SVGs with a blank line.&#10;&#10;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 24 24&quot;&gt;&#10;  &lt;path d=&quot;M12 2L2 22h20L12 2z&quot;/&gt;&#10;&lt;/svg&gt;"
                  @bind="_inputSvg"
                  @bind:after="SaveState"></textarea>
        <div class="mt-2 flex gap-2">
            <button type="button"
                    class="bg-blue-600 text-white px-4 py-1.5 text-xs rounded hover:bg-blue-700 cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled="@string.IsNullOrWhiteSpace(_inputSvg)"
                    @onclick="AddSvgs">
                <i class="ti ti-plus mr-0.5"></i> Add SVG
            </button>
            @if (_icons.Count > 0)
            {
                <button type="button"
                        class="border border-red-300 dark:border-red-600 text-red-600 dark:text-red-400 px-4 py-1.5 text-xs rounded hover:bg-red-50 dark:hover:bg-red-900/30 cursor-pointer"
                        @onclick="ClearAll">
                    <i class="ti ti-trash mr-0.5"></i> Clear All
                </button>
            }
        </div>
        @if (!string.IsNullOrEmpty(_parseError))
        {
            <div class="mt-2 text-xs text-red-500">
                <i class="ti ti-alert-triangle mr-0.5"></i> @_parseError
            </div>
        }
    </div>

    @* ── Icon list ── *@
    @if (_icons.Count > 0)
    {
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-gray-500">
                    <i class="ti ti-list mr-1"></i> Icons in Sprite
                </h3>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">
                    @_icons.Count icon@(_icons.Count == 1 ? "" : "s") in sprite
                </span>
            </div>
            <div class="space-y-2">
                @for (int idx = 0; idx < _icons.Count; idx++)
                {
                    int capturedIdx = idx;
                    SvgSpriteBuilderCore.SpriteIcon icon = _icons[capturedIdx];
                    <div class="flex items-center gap-3 border border-gray-200 dark:border-gray-700 rounded p-3 bg-gray-50 dark:bg-gray-800/50">
                        @* Preview *@
                        <div class="flex-shrink-0 w-12 h-12 border border-gray-200 dark:border-gray-600 rounded bg-white dark:bg-gray-900 flex items-center justify-center overflow-hidden">
                            <div style="width:48px;height:48px;display:flex;align-items:center;justify-content:center;">
                                @((MarkupString)icon.OriginalSvg)
                            </div>
                        </div>

                        @* ID input *@
                        <div class="flex-1 min-w-0">
                            <label class="block text-[10px] text-gray-400 mb-0.5">Symbol ID</label>
                            <input type="text"
                                   class="w-full max-w-xs p-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-xs font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                   value="@icon.Id"
                                   @onchange="(ChangeEventArgs e) => UpdateIconId(capturedIdx, e.Value?.ToString() ?? string.Empty)" />
                        </div>

                        @* viewBox display *@
                        <div class="hidden sm:block flex-shrink-0">
                            <span class="text-[10px] text-gray-400 block mb-0.5">viewBox</span>
                            <span class="text-xs font-mono text-gray-600 dark:text-gray-300">
                                @(string.IsNullOrEmpty(icon.ViewBox) ? "none" : icon.ViewBox)
                            </span>
                        </div>

                        @* Delete button *@
                        <button type="button"
                                class="flex-shrink-0 text-red-500 hover:text-red-700 dark:hover:text-red-400 p-1 cursor-pointer border-none bg-transparent"
                                title="Remove icon"
                                @onclick="() => RemoveIcon(capturedIdx)">
                            <i class="ti ti-x text-sm"></i>
                        </button>
                    </div>
                }
            </div>
        </div>

        @* ── Output area ── *@
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            @* Sprite sheet *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-sm font-semibold text-gray-500">
                        <i class="ti ti-file-code mr-1"></i> Sprite Sheet
                    </h3>
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="CopySpriteSheet">
                        <i class="ti ti-@(_copiedSprite ? "check" : "copy") mr-0.5"></i>
                        @(_copiedSprite ? "Copied!" : "Copy")
                    </button>
                </div>
                <pre class="w-full p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded text-xs font-mono overflow-x-auto max-h-96 whitespace-pre-wrap break-all">@GeneratedSprite</pre>
            </div>

            @* Usage examples *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-sm font-semibold text-gray-500">
                        <i class="ti ti-code mr-1"></i> Usage Examples
                    </h3>
                    <button type="button"
                            class="text-xs px-2 py-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                            @onclick="CopyUsageExamples">
                        <i class="ti ti-@(_copiedUsage ? "check" : "copy") mr-0.5"></i>
                        @(_copiedUsage ? "Copied!" : "Copy")
                    </button>
                </div>
                <div class="space-y-2">
                    <p class="text-[10px] text-gray-400 mb-2">
                        Include the sprite sheet once (hidden), then reference each symbol:
                    </p>
                    @foreach (SvgSpriteBuilderCore.SpriteIcon icon in _icons)
                    {
                        string usageLine = $"<svg class=\"icon\" width=\"24\" height=\"24\"><use href=\"#{icon.Id}\"></use></svg>";
                        <div class="flex items-center gap-2">
                            <code class="flex-1 block p-2 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded text-[11px] font-mono overflow-x-auto">@usageLine</code>
                            <button type="button"
                                    class="flex-shrink-0 text-xs p-1 rounded cursor-pointer border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300"
                                    @onclick="() => CopySingleUsage(usageLine)">
                                <i class="ti ti-copy"></i>
                            </button>
                        </div>
                    }
                    <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-700">
                        <p class="text-[10px] text-gray-400 mb-1">CSS suggestion:</p>
                        <code class="block p-2 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded text-[11px] font-mono">.icon { width: 1em; height: 1em; fill: currentColor; }</code>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/web/svg-sprite" OnRestore="RestoreState" />

@code {
    private RecentEntryPanel? _recentPanel;
    private string _inputSvg = string.Empty;
    private string _parseError = string.Empty;
    private bool _copiedSprite;
    private bool _copiedUsage;
    private int _nextId = 1;

    private List<SvgSpriteBuilderCore.SpriteIcon> _icons = new();

    sealed record ToolState(
        string InputSvg,
        int NextId,
        List<SvgSpriteBuilderCore.SpriteIcon> Icons
    );

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadState();
        }
    }

    private async Task LoadState()
    {
        ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/web/svg-sprite");
        if (state is not null)
        {
            _inputSvg = state.InputSvg;
            _nextId = state.NextId;
            _icons = new List<SvgSpriteBuilderCore.SpriteIcon>(state.Icons);
            StateHasChanged();
        }
    }

    private async Task SaveState()
    {
        ToolState state = new(_inputSvg, _nextId, new List<SvgSpriteBuilderCore.SpriteIcon>(_icons));
        await Storage.SaveStateAsync("tools/web/svg-sprite", state);
    }

    private async Task RestoreState(string json)
    {
        try
        {
            ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
            if (state is not null)
            {
                _inputSvg = state.InputSvg;
                _nextId = state.NextId;
                _icons = new List<SvgSpriteBuilderCore.SpriteIcon>(state.Icons);
                StateHasChanged();
                await SaveState();
            }
        }
        catch { /* ignore invalid JSON */ }
    }

    private string GeneratedSprite => SvgSpriteBuilderCore.BuildSpriteSheet(_icons);

    private string AllUsageExamples => SvgSpriteBuilderCore.BuildUsageExamples(_icons);

    private async Task AddSvgs()
    {
        _parseError = string.Empty;
        if (string.IsNullOrWhiteSpace(_inputSvg)) return;

        List<string> svgBlocks = SvgSpriteBuilderCore.SplitSvgBlocks(_inputSvg);
        if (svgBlocks.Count == 0)
        {
            _parseError = "No valid SVG elements found. Make sure your input contains <svg>...</svg> tags.";
            return;
        }

        int addedCount = 0;
        foreach (string block in svgBlocks)
        {
            SvgSpriteBuilderCore.SpriteIcon? parsed = SvgSpriteBuilderCore.ParseSvgBlock(block, ref _nextId);
            if (parsed is not null)
            {
                _icons.Add(parsed);
                addedCount++;
            }
        }

        if (addedCount == 0)
        {
            _parseError = "Could not parse any SVG elements. Check that your SVG markup is valid.";
        }
        else
        {
            await Storage.AddRecentAsync("tools/web/svg-sprite", $"Added {addedCount} SVG icon{(addedCount == 1 ? "" : "s")}",
                new ToolState(_inputSvg, _nextId, new List<SvgSpriteBuilderCore.SpriteIcon>(_icons)));
            _inputSvg = string.Empty;
            await SaveState();
            await _recentPanel?.RefreshAsync()!;
        }
    }

    private async Task UpdateIconId(int index, string newId)
    {
        if (index >= 0 && index < _icons.Count && !string.IsNullOrWhiteSpace(newId))
        {
            SvgSpriteBuilderCore.SpriteIcon current = _icons[index];
            _icons[index] = current with { Id = newId.Trim() };
            await SaveState();
        }
    }

    private async Task RemoveIcon(int index)
    {
        if (index >= 0 && index < _icons.Count)
        {
            _icons.RemoveAt(index);
            await SaveState();
        }
    }

    private async Task ClearAll()
    {
        _icons.Clear();
        _nextId = 1;
        _parseError = string.Empty;
        await SaveState();
    }

    private async Task CopySpriteSheet()
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", GeneratedSprite);
        _copiedSprite = true;
        StateHasChanged();
        await Task.Delay(1500);
        _copiedSprite = false;
    }

    private async Task CopyUsageExamples()
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", AllUsageExamples);
        _copiedUsage = true;
        StateHasChanged();
        await Task.Delay(1500);
        _copiedUsage = false;
    }

    private async Task CopySingleUsage(string usageLine)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", usageLine);
    }
}
