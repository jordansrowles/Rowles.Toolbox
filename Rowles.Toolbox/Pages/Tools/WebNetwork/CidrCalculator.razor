@page "/tools/web/cidr"
@using Rowles.Toolbox.Core.WebNetwork
@using System.Text.Json
@using System.Net
@inject LocalStorageService Storage

<PageTitle>CIDR Calculator - Rowles.Toolbox</PageTitle>

<PageHeader Title="CIDR / Subnet Calculator" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-network mr-1"></i> Calculate subnets, hosts, and IP ranges from CIDR notation</span>
    </Actions>
</PageHeader>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2 space-y-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <label class="block text-sm font-medium mb-1">CIDR Notation</label>
            <div class="flex gap-2">
                <input type="text"
                       class="flex-1 p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="e.g. 192.168.1.0/24"
                       @bind="_cidrInput"
                       @bind:after="SaveState" />
                <button type="button"
                        class="px-3 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700 transition-colors"
                        @onclick="Calculate">
                    <i class="ti ti-calculator mr-1"></i> Calculate
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="mt-2 text-red-500 text-sm"><i class="ti ti-alert-circle mr-1"></i>@_errorMessage</div>
            }

            <div class="mt-3 flex flex-wrap gap-1 text-xs">
                @foreach (string example in CidrCalculatorCore.Examples)
                {
                    <button type="button"
                            class="px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 font-mono transition-colors"
                            @onclick="async () => { _cidrInput = example; await Calculate(); }">
                        @example
                    </button>
                }
            </div>
        </div>

        @if (_result is not null)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-info-circle mr-1"></i> Network Details</h3>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Network Address</span><span class="font-mono font-bold">@_result.NetworkAddress</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Broadcast Address</span><span class="font-mono font-bold">@_result.BroadcastAddress</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Subnet Mask</span><span class="font-mono font-bold">@_result.SubnetMask</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Wildcard Mask</span><span class="font-mono font-bold">@_result.WildcardMask</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">CIDR Notation</span><span class="font-mono font-bold">@_result.Cidr</span></div>
                    </div>
                </div>

                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-devices mr-1"></i> Host Information</h3>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">First Usable Host</span><span class="font-mono font-bold">@_result.FirstUsableHost</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Last Usable Host</span><span class="font-mono font-bold">@_result.LastUsableHost</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Total Addresses</span><span class="font-mono font-bold">@_result.TotalAddresses.ToString("N0")</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Usable Hosts</span><span class="font-mono font-bold">@_result.UsableHosts.ToString("N0")</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">IP Class</span><span class="font-mono font-bold">@_result.IpClass</span></div>
                        <div class="flex items-center justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Type</span><span class="font-mono font-bold">@(_result.IsPrivate ? "Private" : "Public")</span></div>
                    </div>
                </div>
            </div>

            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-binary mr-1"></i> Binary Representation</h3>
                <div class="space-y-2 font-mono text-sm">
                    <div>
                        <span class="text-gray-500 text-xs block mb-0.5">IP Address</span>
                        <span class="text-blue-600 dark:text-blue-400">@_result.IpBinary</span>
                    </div>
                    <div>
                        <span class="text-gray-500 text-xs block mb-0.5">Subnet Mask</span>
                        <span class="text-green-600 dark:text-green-400">@_result.MaskBinary</span>
                    </div>
                    <div>
                        <span class="text-gray-500 text-xs block mb-0.5">Network</span>
                        <span class="text-purple-600 dark:text-purple-400">@_result.NetworkBinary</span>
                    </div>
                </div>
            </div>

            @if (_result.Subnets.Count > 0)
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                    <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-sitemap mr-1"></i> /24 Subnets (@_result.Subnets.Count)</h3>
                    <div class="max-h-64 overflow-y-auto">
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1 text-sm font-mono">
                            @foreach (string subnet in _result.Subnets)
                            {
                                <div class="px-2 py-1 bg-gray-50 dark:bg-gray-800 rounded text-gray-600 dark:text-gray-400">@subnet</div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="space-y-4">
        @if (_result is not null)
        {
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-search mr-1"></i> IP Range Checker</h3>
                <input type="text"
                       class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="e.g. 192.168.1.50"
                       @bind="_checkIp"
                       @bind:after="SaveState" />
                <button type="button"
                        class="mt-2 w-full px-3 py-1.5 bg-blue-600 text-white rounded text-sm hover:bg-blue-700 transition-colors"
                        @onclick="CheckIpInRange">
                    <i class="ti ti-check mr-1"></i> Check
                </button>
                @if (_checkResult is not null)
                {
                    <div class="mt-2 text-sm @(_checkResult.Value ? "text-green-600 dark:text-green-400" : "text-red-500")">
                        <i class="ti @(_checkResult.Value ? "ti-check" : "ti-x") mr-1"></i>
                        @_checkIp is @(_checkResult.Value ? "within" : "outside") the subnet
                    </div>
                }
            </div>
        }

        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-table mr-1"></i> CIDR Quick Reference</h3>
            <div class="space-y-1 text-xs font-mono">
                @foreach ((int prefix, string mask, long hosts) in CidrCalculatorCore.CidrReference)
                {
                    <div class="flex justify-between text-gray-600 dark:text-gray-400">
                        <span>/@prefix</span>
                        <span>@mask</span>
                        <span class="text-right w-20">@hosts.ToString("N0")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/web/cidr" OnRestore="RestoreState" />

@code {
    private RecentEntryPanel? _recentPanel;
    private string _cidrInput = string.Empty;
    private string? _errorMessage;
    private CidrCalculatorCore.CidrResult? _result;
    private string _checkIp = string.Empty;
    private bool? _checkResult;

    sealed record ToolState(string CidrInput, string CheckIp);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadState();
    }

    private async Task LoadState()
    {
        ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/web/cidr");
        if (state is not null)
        {
            _cidrInput = state.CidrInput;
            _checkIp = state.CheckIp;
            if (!string.IsNullOrWhiteSpace(_cidrInput))
            {
                (CidrCalculatorCore.CidrResult? result, string? error) = CidrCalculatorCore.Calculate(_cidrInput);
                _result = result;
                _errorMessage = error;
            }
            StateHasChanged();
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/web/cidr", new ToolState(_cidrInput, _checkIp));
    }

    private async Task RestoreState(string json)
    {
        try
        {
            ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
            if (state is not null)
            {
                _cidrInput = state.CidrInput;
                _checkIp = state.CheckIp;
                if (!string.IsNullOrWhiteSpace(_cidrInput))
                {
                    (CidrCalculatorCore.CidrResult? result, string? error) = CidrCalculatorCore.Calculate(_cidrInput);
                    _result = result;
                    _errorMessage = error;
                }
                StateHasChanged();
                await SaveState();
            }
        }
        catch { /* ignore invalid JSON */ }
    }

    private async Task Calculate()
    {
        _checkResult = null;
        (CidrCalculatorCore.CidrResult? result, string? error) = CidrCalculatorCore.Calculate(_cidrInput);
        _result = result;
        _errorMessage = error;
        await SaveState();
        if (_result is not null)
        {
            await Storage.AddRecentAsync("tools/web/cidr", $"CIDR: {_cidrInput}", new ToolState(_cidrInput, _checkIp));
            await _recentPanel?.RefreshAsync()!;
        }
    }

    private async Task CheckIpInRange()
    {
        _checkResult = null;
        if (_result is null || string.IsNullOrWhiteSpace(_checkIp)) return;
        _checkResult = CidrCalculatorCore.CheckIpInRange(_result, _checkIp);
        await SaveState();
        await Storage.AddRecentAsync("tools/web/cidr", $"Check {_checkIp} in {_cidrInput}", new ToolState(_cidrInput, _checkIp));
        await _recentPanel?.RefreshAsync()!;
    }
}

