@page "/tools/security/password"
@using System.Security.Cryptography
@using Rowles.Toolbox.Core.Security
@using System.Text.Json
@inject IJSRuntime JS
@inject LocalStorageService Storage

<PageTitle>Password Tools - Rowles.Toolbox</PageTitle>

<PageHeader Title="Password Tools" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-lock mr-1"></i> Generate &amp; analyse passwords</span>
    </Actions>
</PageHeader>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    @* -- Generator -- *@
    <section class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold mb-3"><i class="ti ti-key mr-1"></i> Password Generator</h3>

        <div class="space-y-3">
            <div>
                <label class="block text-xs font-medium mb-1">Length: <strong class="text-blue-600 dark:text-blue-400">@_length</strong></label>
                <input type="range" min="8" max="128" @bind="_length" @bind:event="oninput" @bind:after="SaveState"
                       class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700" />
                <div class="flex justify-between text-xs text-gray-400 mt-0.5">
                    <span>8</span>
                    <span>128</span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center gap-1.5 text-xs cursor-pointer">
                    <input type="checkbox" class="rounded" @bind="_includeLowercase" @bind:after="SaveState" />
                    Lowercase (a–z)
                </label>
                <label class="flex items-center gap-1.5 text-xs cursor-pointer">
                    <input type="checkbox" class="rounded" @bind="_includeUppercase" @bind:after="SaveState" />
                    Uppercase (A–Z)
                </label>
                <label class="flex items-center gap-1.5 text-xs cursor-pointer">
                    <input type="checkbox" class="rounded" @bind="_includeDigits" @bind:after="SaveState" />
                    Digits (0–9)
                </label>
                <label class="flex items-center gap-1.5 text-xs cursor-pointer">
                    <input type="checkbox" class="rounded" @bind="_includeSymbols" @bind:after="SaveState" />
                    Symbols (!&#64;#$…)
                </label>
            </div>

            <label class="flex items-center gap-1.5 text-xs cursor-pointer">
                <input type="checkbox" class="rounded" @bind="_excludeAmbiguous" @bind:after="SaveState" />
                Exclude ambiguous characters (0, O, I, l, 1, |)
            </label>

            <div class="flex gap-2">
                <button type="button" class="bg-blue-600 text-white px-3 py-1.5 text-xs rounded hover:bg-blue-700 cursor-pointer border-none"
                        @onclick="GeneratePassword">
                    <i class="ti ti-refresh mr-0.5"></i> Generate
                </button>
                <button type="button" class="px-3 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer"
                        @onclick="CopyGenerated" disabled="@string.IsNullOrEmpty(_generatedPassword)">
                    <i class="ti ti-copy mr-0.5"></i> Copy
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_generatorError))
            {
                <div class="p-2 text-xs bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 border border-red-300 dark:border-red-700 rounded">
                    <i class="ti ti-alert-triangle mr-0.5"></i> @_generatorError
                </div>
            }

            @if (!string.IsNullOrEmpty(_generatedPassword))
            {
                <div class="p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded">
                    <code class="text-sm font-mono break-all select-all">@_generatedPassword</code>
                </div>
            }
        </div>
    </section>

    @* -- Strength Analyser -- *@
    <section class="border border-gray-200 dark:border-gray-700 rounded p-4">
        <h3 class="text-sm font-semibold mb-3"><i class="ti ti-shield-check mr-1"></i> Strength Analyser</h3>

        <div class="space-y-3">
            <div>
                <label class="block text-xs font-medium mb-1">Password</label>
                <input type="text" class="w-full p-2 text-sm font-mono border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       @bind="_analyzePassword" @bind:event="oninput" @bind:after="SaveState"
                       placeholder="Enter a password to analyse…" />
            </div>

            @if (!string.IsNullOrEmpty(_analyzePassword))
            {
                @* Strength meter bar *@
                <div>
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs font-medium">Strength</span>
                        <span class="text-xs font-bold @StrengthTextColor">@StrengthLabel</span>
                    </div>
                    <div class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-300 @StrengthBarColor" style="width: @StrengthPercent%"></div>
                    </div>
                </div>

                @* Statistics *@
                <div class="space-y-1.5">
                    <div class="flex items-center justify-between text-xs">
                        <span class="text-gray-600 dark:text-gray-400">Entropy</span>
                        <span class="font-bold">@AnalysisEntropy.ToString("F1") bits</span>
                    </div>
                    <div class="flex items-center justify-between text-xs">
                        <span class="text-gray-600 dark:text-gray-400">Pool size</span>
                        <span class="font-bold">@AnalysisPoolSize characters</span>
                    </div>
                    <div class="flex items-center justify-between text-xs">
                        <span class="text-gray-600 dark:text-gray-400">Crack time (10B guesses/sec)</span>
                        <span class="font-bold">@CrackTimeEstimate</span>
                    </div>
                    <div class="flex items-center justify-between text-xs">
                        <span class="text-gray-600 dark:text-gray-400">Length</span>
                        <span class="font-bold">@_analyzePassword.Length characters</span>
                    </div>
                </div>

                @* Character set analysis *@
                <div>
                    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Character sets</span>
                    <div class="mt-1 space-y-1">
                        <div class="flex items-center gap-2 text-xs">
                            <i class="ti @(AnalysisHasLower ? "ti-check text-green-500" : "ti-x text-red-400")"></i>
                            <span class="@(AnalysisHasLower ? "text-gray-700 dark:text-gray-300" : "text-gray-400 dark:text-gray-500")">Lowercase (a–z)</span>
                            @if (AnalysisHasLower) { <span class="text-gray-400 dark:text-gray-500">(26 chars)</span> }
                        </div>
                        <div class="flex items-center gap-2 text-xs">
                            <i class="ti @(AnalysisHasUpper ? "ti-check text-green-500" : "ti-x text-red-400")"></i>
                            <span class="@(AnalysisHasUpper ? "text-gray-700 dark:text-gray-300" : "text-gray-400 dark:text-gray-500")">Uppercase (A–Z)</span>
                            @if (AnalysisHasUpper) { <span class="text-gray-400 dark:text-gray-500">(26 chars)</span> }
                        </div>
                        <div class="flex items-center gap-2 text-xs">
                            <i class="ti @(AnalysisHasDigit ? "ti-check text-green-500" : "ti-x text-red-400")"></i>
                            <span class="@(AnalysisHasDigit ? "text-gray-700 dark:text-gray-300" : "text-gray-400 dark:text-gray-500")">Digits (0–9)</span>
                            @if (AnalysisHasDigit) { <span class="text-gray-400 dark:text-gray-500">(10 chars)</span> }
                        </div>
                        <div class="flex items-center gap-2 text-xs">
                            <i class="ti @(AnalysisHasSymbol ? "ti-check text-green-500" : "ti-x text-red-400")"></i>
                            <span class="@(AnalysisHasSymbol ? "text-gray-700 dark:text-gray-300" : "text-gray-400 dark:text-gray-500")">Symbols</span>
                            @if (AnalysisHasSymbol) { <span class="text-gray-400 dark:text-gray-500">(33 chars)</span> }
                        </div>
                    </div>
                </div>

                @* Suggestions *@
                @if (GetSuggestions() is { Count: > 0 } analyzeSuggestions)
                {
                    <div>
                        <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Suggestions</span>
                        <ul class="mt-1 space-y-0.5">
                            @foreach (string suggestion in analyzeSuggestions)
                            {
                                <li class="text-xs text-yellow-700 dark:text-yellow-400 flex items-start gap-1">
                                    <i class="ti ti-bulb mt-0.5 shrink-0"></i> @suggestion
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
        </div>
    </section>
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/security/password" OnRestore="RestoreState" />

@code {
    // Generator state
    private int _length = 16;
    private bool _includeLowercase = true;
    private bool _includeUppercase = true;
    private bool _includeDigits = true;
    private bool _includeSymbols;
    private bool _excludeAmbiguous;
    private string _generatedPassword = string.Empty;
    private string? _generatorError;

    // Analyser state
    private string _analyzePassword = string.Empty;

    private RecentEntryPanel? _recentPanel;
    sealed record ToolState(int Length, bool IncludeLowercase, bool IncludeUppercase, bool IncludeDigits, bool IncludeSymbols, bool ExcludeAmbiguous, string AnalyzePassword);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/security/password");
            if (state is not null)
            {
                _length = state.Length;
                _includeLowercase = state.IncludeLowercase;
                _includeUppercase = state.IncludeUppercase;
                _includeDigits = state.IncludeDigits;
                _includeSymbols = state.IncludeSymbols;
                _excludeAmbiguous = state.ExcludeAmbiguous;
                _analyzePassword = state.AnalyzePassword;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/security/password", new ToolState(_length, _includeLowercase, _includeUppercase, _includeDigits, _includeSymbols, _excludeAmbiguous, _analyzePassword));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _length = state.Length;
            _includeLowercase = state.IncludeLowercase;
            _includeUppercase = state.IncludeUppercase;
            _includeDigits = state.IncludeDigits;
            _includeSymbols = state.IncludeSymbols;
            _excludeAmbiguous = state.ExcludeAmbiguous;
            _analyzePassword = state.AnalyzePassword;
            StateHasChanged();
        }
    }

    private async Task GeneratePassword()
    {
        _generatorError = null;
        string pool = PasswordToolsCore.BuildCharPool(_includeLowercase, _includeUppercase, _includeDigits, _includeSymbols, _excludeAmbiguous);
        if (pool.Length == 0)
        {
            _generatorError = "Select at least one character set.";
            _generatedPassword = string.Empty;
            return;
        }

        char[] passwordChars = new char[_length];
        for (int i = 0; i < _length; i++)
        {
            passwordChars[i] = pool[RandomNumberGenerator.GetInt32(pool.Length)];
        }
        _generatedPassword = new string(passwordChars);

        await Storage.AddRecentAsync("tools/security/password", $"Generated {_length}-char password", new ToolState(_length, _includeLowercase, _includeUppercase, _includeDigits, _includeSymbols, _excludeAmbiguous, _analyzePassword));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    private async Task CopyGenerated()
    {
        if (!string.IsNullOrEmpty(_generatedPassword))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _generatedPassword);
        }
    }

    private bool AnalysisHasLower => !string.IsNullOrEmpty(_analyzePassword) && _analyzePassword.Any(char.IsLower);
    private bool AnalysisHasUpper => !string.IsNullOrEmpty(_analyzePassword) && _analyzePassword.Any(char.IsUpper);
    private bool AnalysisHasDigit => !string.IsNullOrEmpty(_analyzePassword) && _analyzePassword.Any(char.IsDigit);
    private bool AnalysisHasSymbol => !string.IsNullOrEmpty(_analyzePassword) && _analyzePassword.Any(c => !char.IsLetterOrDigit(c));

    private int AnalysisPoolSize => PasswordToolsCore.GetPoolSize(AnalysisHasLower, AnalysisHasUpper, AnalysisHasDigit, AnalysisHasSymbol);
    private double AnalysisEntropy => PasswordToolsCore.CalculateEntropy(_analyzePassword?.Length ?? 0, AnalysisPoolSize);
    private string StrengthLabel => PasswordToolsCore.GetStrengthLabel(AnalysisEntropy);
    private string StrengthBarColor => PasswordToolsCore.GetStrengthBarColor(AnalysisEntropy);
    private string StrengthTextColor => PasswordToolsCore.GetStrengthTextColor(AnalysisEntropy);
    private int StrengthPercent => PasswordToolsCore.GetStrengthPercent(AnalysisEntropy);
    private string CrackTimeEstimate => PasswordToolsCore.GetCrackTimeEstimate(AnalysisEntropy);
    private List<string> GetSuggestions() => PasswordToolsCore.GetSuggestions(_analyzePassword, AnalysisHasLower, AnalysisHasUpper, AnalysisHasDigit, AnalysisHasSymbol);
}