                            <button class="px-2 py-0.5 text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer border-none bg-transparent"
                                    @onclick="() => CopyToClipboard(value)">
                                <i class="ti ti-copy mr-0.5"></i> Copy
                            </button>
                        </div>
                        <div class="p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded">
                            <code class="text-xs font-mono break-all select-all">@value</code>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/security/cipher" OnRestore="RestoreState" />

@code {
    // ── Tab definitions ─────────────────────────────────────────────────────
    private static readonly (string Id, string Icon, string Label)[] _tabs =
    [
        ("caesar", "rotate", "ROT13 / Caesar"),
        ("vigenere", "key", "Vigenère"),
        ("atbash", "arrows-exchange", "Atbash"),
        ("xor", "code", "XOR"),
        ("aesgcm", "shield-lock", "AES-GCM"),
        ("hmac", "fingerprint", "HMAC"),
        ("random", "dice", "Random Bytes"),
    ];

    private string _activeTab = "caesar";

    private RecentEntryPanel? _recentPanel;
    sealed record ToolState(string ActiveTab, string CaesarInput, int CaesarShift, bool CaesarRot47Mode,
        string VigenereInput, string VigenereKey, string AtbashInput,
        string XorInput, string XorKey, bool XorInputHex, bool XorOutputBase64,
        string AesInput, string AesKey,
        string HmacInput, string HmacKey, string HmacAlgorithm,
        int RandomByteCount, bool RandomSpaceSeparated);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/security/cipher");
            if (state is not null)
            {
                _activeTab = state.ActiveTab;
                _caesarInput = state.CaesarInput;
                _caesarShift = state.CaesarShift;
                _caesarRot47Mode = state.CaesarRot47Mode;
                _vigenereInput = state.VigenereInput;
                _vigenereKey = state.VigenereKey;
                _atbashInput = state.AtbashInput;
                _xorInput = state.XorInput;
                _xorKey = state.XorKey;
                _xorInputHex = state.XorInputHex;
                _xorOutputBase64 = state.XorOutputBase64;
                _aesInput = state.AesInput;
                _aesKey = state.AesKey;
                _hmacInput = state.HmacInput;
                _hmacKey = state.HmacKey;
                _hmacAlgorithm = state.HmacAlgorithm;
                _randomByteCount = state.RandomByteCount;
                _randomSpaceSeparated = state.RandomSpaceSeparated;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/security/cipher", new ToolState(
            _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
            _vigenereInput, _vigenereKey, _atbashInput,
            _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
            _aesInput, _aesKey,
            _hmacInput, _hmacKey, _hmacAlgorithm,
            _randomByteCount, _randomSpaceSeparated));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _activeTab = state.ActiveTab;
            _caesarInput = state.CaesarInput;
            _caesarShift = state.CaesarShift;
            _caesarRot47Mode = state.CaesarRot47Mode;
            _vigenereInput = state.VigenereInput;
            _vigenereKey = state.VigenereKey;
            _atbashInput = state.AtbashInput;
            _xorInput = state.XorInput;
            _xorKey = state.XorKey;
            _xorInputHex = state.XorInputHex;
            _xorOutputBase64 = state.XorOutputBase64;
            _aesInput = state.AesInput;
            _aesKey = state.AesKey;
            _hmacInput = state.HmacInput;
            _hmacKey = state.HmacKey;
            _hmacAlgorithm = state.HmacAlgorithm;
            _randomByteCount = state.RandomByteCount;
            _randomSpaceSeparated = state.RandomSpaceSeparated;
            StateHasChanged();
        }
    }

    private async Task SetActiveTab(string id) { _activeTab = id; await SaveState(); }
    private async Task SetXorInputHex(bool value) { _xorInputHex = value; await SaveState(); }
    private async Task SetXorOutputBase64(bool value) { _xorOutputBase64 = value; await SaveState(); }

    // ── Shared helpers ──────────────────────────────────────────────────────

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 1 — ROT13 / Caesar
    // ═════════════════════════════════════════════════════════════════════════

    private string _caesarInput = string.Empty;
    private int _caesarShift = 13;
    private string _caesarOutput = string.Empty;
    private string? _caesarError;
    private bool _caesarRot47Mode;

    private async Task CaesarSetRot47()
    {
        _caesarRot47Mode = true;
        _caesarShift = 47;
        await SaveState();
    }

    private async Task CaesarApply(bool encode)
    {
        _caesarError = null;
        _caesarOutput = string.Empty;

        if (string.IsNullOrEmpty(_caesarInput))
        {
            _caesarError = "Please enter some text.";
            return;
        }

        if (_caesarRot47Mode || _caesarShift == 47)
        {
            _caesarOutput = CipherPlaygroundCore.Rot47(_caesarInput);
            await Storage.AddRecentAsync("tools/security/cipher", "Caesar ROT47", new ToolState(
                _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
                _vigenereInput, _vigenereKey, _atbashInput,
                _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
                _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
                _randomByteCount, _randomSpaceSeparated));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
            return;
        }

        if (_caesarShift is < 1 or > 25)
        {
            _caesarError = "Shift must be between 1 and 25.";
            return;
        }

        int shift = encode ? _caesarShift : 26 - _caesarShift;
        _caesarOutput = CipherPlaygroundCore.CaesarShift(_caesarInput, shift);

        string direction = encode ? "encode" : "decode";
        await Storage.AddRecentAsync("tools/security/cipher", $"Caesar shift {_caesarShift} {direction}", new ToolState(
            _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
            _vigenereInput, _vigenereKey, _atbashInput,
            _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
            _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
            _randomByteCount, _randomSpaceSeparated));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    private static string CaesarShift(string text, int shift) => CipherPlaygroundCore.CaesarShift(text, shift);
    private static string Rot47(string text) => CipherPlaygroundCore.Rot47(text);

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 2 — Vigenère
    // ═════════════════════════════════════════════════════════════════════════

    private string _vigenereInput = string.Empty;
    private string _vigenereKey = string.Empty;
    private string _vigenereOutput = string.Empty;
    private string? _vigenereError;

    private async Task VigenereApply(bool encode)
    {
        _vigenereError = null;
        _vigenereOutput = string.Empty;

        if (string.IsNullOrEmpty(_vigenereInput))
        {
            _vigenereError = "Please enter some text.";
            return;
        }

        string keyLetters = new((_vigenereKey ?? "").Where(char.IsLetter).Select(char.ToUpper).ToArray());
        if (keyLetters.Length == 0)
        {
            _vigenereError = "Keyword must contain at least one letter.";
            return;
        }

        _vigenereOutput = CipherPlaygroundCore.VigenereApply(_vigenereInput, keyLetters, encode);

        string direction = encode ? "encode" : "decode";
        await Storage.AddRecentAsync("tools/security/cipher", $"Vigenere {direction}", new ToolState(
            _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
            _vigenereInput, _vigenereKey ?? "", _atbashInput,
            _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
            _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
            _randomByteCount, _randomSpaceSeparated));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    private string VigenereExpandKey()
    {
        if (string.IsNullOrEmpty(_vigenereKey) || string.IsNullOrEmpty(_vigenereInput))
            return string.Empty;

        string keyLetters = new((_vigenereKey).Where(char.IsLetter).Select(char.ToUpper).ToArray());
        return CipherPlaygroundCore.VigenereExpandKey(_vigenereInput, keyLetters);
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 3 — Atbash
    // ═════════════════════════════════════════════════════════════════════════

    private string _atbashInput = string.Empty;
    private string _atbashOutput = string.Empty;

    private async Task AtbashApply()
    {
        if (string.IsNullOrEmpty(_atbashInput)) return;
        _atbashOutput = CipherPlaygroundCore.Atbash(_atbashInput);

        await Storage.AddRecentAsync("tools/security/cipher", "Atbash", new ToolState(
            _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
            _vigenereInput, _vigenereKey, _atbashInput,
            _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
            _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
            _randomByteCount, _randomSpaceSeparated));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 4 — XOR
    // ═════════════════════════════════════════════════════════════════════════

    private string _xorInput = string.Empty;
    private string _xorKey = string.Empty;
    private bool _xorInputHex;
    private bool _xorOutputBase64;
    private string _xorOutput = string.Empty;
    private string? _xorError;

    private async Task XorApply()
    {
        _xorError = null;
        _xorOutput = string.Empty;

        (string? result, string? error) = CipherPlaygroundCore.XorApply(_xorInput, _xorKey, _xorInputHex, _xorOutputBase64);
        if (error is not null)
            _xorError = error;
        else if (result is not null)
        {
            _xorOutput = result;

            await Storage.AddRecentAsync("tools/security/cipher", "XOR encrypt", new ToolState(
                _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
                _vigenereInput, _vigenereKey, _atbashInput,
                _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
                _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
                _randomByteCount, _randomSpaceSeparated));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 5 — AES-GCM
    // ═════════════════════════════════════════════════════════════════════════

    private string _aesInput = string.Empty;
    private string _aesKey = string.Empty;
    private string _aesEncryptedOutput = string.Empty;
    private string _aesDecryptedOutput = string.Empty;
    private string? _aesError;

    private async Task AesGenerateRandomKey()
    {
        byte[] key = RandomNumberGenerator.GetBytes(32);
        _aesKey = Convert.ToHexString(key).ToLowerInvariant();
        await SaveState();
    }

    private byte[] DeriveAesKey(string keyText)
    {
        // If it looks like a 64-char hex string (32 bytes), use it directly
        if (keyText.Length == 64 && keyText.All(c => char.IsAsciiHexDigit(c)))
            return Convert.FromHexString(keyText);

        return SHA256.HashData(Encoding.UTF8.GetBytes(keyText));
    }

    private async Task AesEncrypt()
    {
        _aesError = null;
        _aesEncryptedOutput = string.Empty;
        _aesDecryptedOutput = string.Empty;

        if (string.IsNullOrEmpty(_aesInput))
        {
            _aesError = "Please enter text to encrypt.";
            return;
        }
        if (string.IsNullOrEmpty(_aesKey))
        {
            _aesError = "Please enter a key.";
            return;
        }

        try
        {
            byte[] key = DeriveAesKey(_aesKey);
            byte[] plaintext = Encoding.UTF8.GetBytes(_aesInput);
            byte[] nonce = RandomNumberGenerator.GetBytes(12);
            byte[] ciphertext = new byte[plaintext.Length];
            byte[] tag = new byte[16];

            using var aes = new AesGcm(key, 16);
            aes.Encrypt(nonce, plaintext, ciphertext, tag);

            // Format: nonce(12) + ciphertext(N) + tag(16)
            byte[] combined = new byte[12 + ciphertext.Length + 16];
            nonce.CopyTo(combined, 0);
            ciphertext.CopyTo(combined, 12);
            tag.CopyTo(combined, 12 + ciphertext.Length);

            _aesEncryptedOutput = Convert.ToBase64String(combined);

            await Storage.AddRecentAsync("tools/security/cipher", "AES-GCM encrypt", new ToolState(
                _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
                _vigenereInput, _vigenereKey, _atbashInput,
                _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
                _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
                _randomByteCount, _randomSpaceSeparated));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
        catch (Exception ex)
        {
            _aesError = $"Encryption failed: {ex.Message}";
        }
    }

    private async Task AesDecrypt()
    {
        _aesError = null;
        _aesDecryptedOutput = string.Empty;

        string input = !string.IsNullOrEmpty(_aesEncryptedOutput)
            ? _aesEncryptedOutput
            : _aesInput;

        if (string.IsNullOrEmpty(input))
        {
            _aesError = "Please provide encrypted Base64 text (in the plaintext field or encrypt first).";
            return;
        }
        if (string.IsNullOrEmpty(_aesKey))
        {
            _aesError = "Please enter the same key used for encryption.";
            return;
        }

        try
        {
            byte[] combined = Convert.FromBase64String(input);
            if (combined.Length < 28) // 12 nonce + 0 ciphertext + 16 tag minimum
            {
                _aesError = "Invalid ciphertext: too short.";
                return;
            }

            byte[] key = DeriveAesKey(_aesKey);
            byte[] nonce = combined[..12];
            byte[] tag = combined[^16..];
            byte[] ciphertext = combined[12..^16];
            byte[] plaintext = new byte[ciphertext.Length];

            using var aes = new AesGcm(key, 16);
            aes.Decrypt(nonce, ciphertext, tag, plaintext);

            _aesDecryptedOutput = Encoding.UTF8.GetString(plaintext);

            await Storage.AddRecentAsync("tools/security/cipher", "AES-GCM decrypt", new ToolState(
                _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
                _vigenereInput, _vigenereKey, _atbashInput,
                _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
                _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
                _randomByteCount, _randomSpaceSeparated));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
        catch (FormatException)
        {
            _aesError = "Invalid Base64 input.";
        }
        catch (CryptographicException)
        {
            _aesError = "Decryption failed — wrong key or corrupted ciphertext.";
        }
        catch (Exception ex)
        {
            _aesError = $"Decryption failed: {ex.Message}";
        }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 6 — HMAC
    // ═════════════════════════════════════════════════════════════════════════

    private string _hmacInput = string.Empty;
    private string _hmacKey = string.Empty;
    private string _hmacAlgorithm = "SHA256";
    private string _hmacOutputHex = string.Empty;
    private string? _hmacOutputBase64;
    private string? _hmacError;

    private async Task HmacGenerate()
    {
        _hmacError = null;
        _hmacOutputHex = string.Empty;
        _hmacOutputBase64 = null;

        if (string.IsNullOrEmpty(_hmacInput))
        {
            _hmacError = "Please enter a message.";
            return;
        }
        if (string.IsNullOrEmpty(_hmacKey))
        {
            _hmacError = "Please enter a secret key.";
            return;
        }

        try
        {
            byte[] keyBytes = Encoding.UTF8.GetBytes(_hmacKey);
            byte[] messageBytes = Encoding.UTF8.GetBytes(_hmacInput);

            byte[] hash = _hmacAlgorithm switch
            {
                "SHA256" => HMACSHA256.HashData(keyBytes, messageBytes),
                "SHA384" => HMACSHA384.HashData(keyBytes, messageBytes),
                "SHA512" => HMACSHA512.HashData(keyBytes, messageBytes),
                _ => HMACSHA256.HashData(keyBytes, messageBytes),
            };

            _hmacOutputHex = Convert.ToHexString(hash).ToLowerInvariant();
            _hmacOutputBase64 = Convert.ToBase64String(hash);

            await Storage.AddRecentAsync("tools/security/cipher", $"HMAC-{_hmacAlgorithm}", new ToolState(
                _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
                _vigenereInput, _vigenereKey, _atbashInput,
                _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
                _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
                _randomByteCount, _randomSpaceSeparated));
            if (_recentPanel is not null) await _recentPanel.RefreshAsync();
        }
        catch (Exception ex)
        {
            _hmacError = $"HMAC generation failed: {ex.Message}";
        }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Tab 7 — Random Bytes
    // ═════════════════════════════════════════════════════════════════════════

    private int _randomByteCount = 32;
    private bool _randomSpaceSeparated;
    private byte[]? _randomBytes;
    private string? _randomHexLower;
    private string? _randomHexUpper;
    private string? _randomBase64;
    private string? _randomCSharp;
    private string? _randomDecimal;
    private string? _randomError;

    private async Task RandomGenerate()
    {
        _randomError = null;
        _randomBytes = null;

        if (_randomByteCount is < 1 or > 1024)
        {
            _randomError = "Byte count must be between 1 and 1024.";
            return;
        }

        _randomBytes = RandomNumberGenerator.GetBytes(_randomByteCount);

        _randomHexLower = CipherPlaygroundCore.FormatHex(_randomBytes, _randomSpaceSeparated, false);
        _randomHexUpper = CipherPlaygroundCore.FormatHex(_randomBytes, _randomSpaceSeparated, true);
        _randomBase64 = Convert.ToBase64String(_randomBytes);
        _randomCSharp = CipherPlaygroundCore.FormatCSharpLiteral(_randomBytes);
        _randomDecimal = CipherPlaygroundCore.FormatDecimalArray(_randomBytes);

        await Storage.AddRecentAsync("tools/security/cipher", $"Random {_randomByteCount} bytes", new ToolState(
            _activeTab, _caesarInput, _caesarShift, _caesarRot47Mode,
            _vigenereInput, _vigenereKey, _atbashInput,
            _xorInput, _xorKey, _xorInputHex, _xorOutputBase64,
            _aesInput, _aesKey, _hmacInput, _hmacKey, _hmacAlgorithm,
            _randomByteCount, _randomSpaceSeparated));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }
}
