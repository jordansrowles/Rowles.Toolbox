@page "/tools/file/encoding"
@using Rowles.Toolbox.Core.File
@using System.Text.Json
@inject LocalStorageService Storage

<PageTitle>File Encoding Detector - Rowles.Toolbox</PageTitle>

<PageHeader Title="File Encoding Detector" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-file-text mr-1"></i> Detect encoding, BOM, and line endings</span>
    </Actions>
</PageHeader>

<div class="space-y-4">
    @* -- Upload -- *@
    <div class="border border-gray-200 dark:border-gray-700 rounded p-6">
        <label class="block text-sm font-medium mb-2">Upload File</label>
        <InputFile OnChange="HandleFileUpload"
                   class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900/30 dark:file:text-blue-400" />
    </div>

    @if (_fileData is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @* -- Detection Results -- *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-scan mr-1"></i> Detection</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Detected Encoding</span>
                        <span class="font-semibold text-blue-600 dark:text-blue-400">@_detectedEncoding</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-gray-500">BOM Present</span>
                        @if (_hasBom)
                        {
                            <span class="px-2 py-0.5 rounded text-xs bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400">
                                <i class="ti ti-check mr-0.5"></i> Yes
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-0.5 rounded text-xs bg-gray-100 dark:bg-gray-700 text-gray-500">No</span>
                        }
                    </div>
                    @if (_hasBom)
                    {
                        <div class="flex justify-between">
                            <span class="text-gray-500">BOM Bytes</span>
                            <code class="font-mono text-xs bg-gray-50 dark:bg-gray-800 px-1 rounded">@_bomHex</code>
                        </div>
                    }
                    <div class="flex justify-between">
                        <span class="text-gray-500">Confidence</span>
                        <span class="font-medium @FileEncodingDetectorCore.ConfidenceColor(_confidence)">@_confidence</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Line Endings</span>
                        <span class="font-mono text-xs">@_lineEndings</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">File Size</span>
                        <span class="font-mono text-xs">@FileEncodingDetectorCore.FormatBytes(_fileData.Length)</span>
                    </div>
                </div>
                @if (_hasBom)
                {
                    <div class="mt-3">
                        <button class="px-3 py-1.5 text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded hover:bg-amber-200 dark:hover:bg-amber-900/50"
                                @onclick="DownloadWithoutBom">
                            <i class="ti ti-download mr-1"></i> Download without BOM
                        </button>
                    </div>
                }
            </div>

            @* -- Line Ending Stats -- *@
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-line-height mr-1"></i> Line Endings</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-500">CRLF (Windows)</span>
                        <span class="font-mono">@_crlfCount</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">LF (Unix/Mac)</span>
                        <span class="font-mono">@_lfCount</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">CR (Old Mac)</span>
                        <span class="font-mono">@_crCount</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Total Lines</span>
                        <span class="font-mono font-semibold">@(_crlfCount + _lfCount + _crCount + 1)</span>
                    </div>
                </div>
            </div>
        </div>

        @* -- Hex Dump -- *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3">
                <i class="ti ti-binary mr-1"></i> Hex Dump (first @Math.Min(256, _fileData.Length) bytes)
            </h3>
            <div class="font-mono text-xs bg-gray-50 dark:bg-gray-800 p-3 rounded overflow-x-auto">
                @for (int row = 0; row < Math.Min(256, _fileData.Length); row += 16)
                {
                    int end = Math.Min(row + 16, Math.Min(256, _fileData.Length));
                    <div class="flex gap-2 leading-5">
                        <span class="text-gray-400 w-12 shrink-0">@row.ToString("X4")</span>
                        <span class="w-[26rem] shrink-0">
                            @for (int i = row; i < row + 16; i++)
                            {
                                if (i < end)
                                {
                                    bool isBom = i < _bomLength;
                                    <span class="@(isBom ? "text-blue-600 dark:text-blue-400 font-semibold" : "")">@_fileData[i].ToString("X2") </span>
                                }
                                else
                                {
                                    <span>   </span>
                                }
                            }
                        </span>
                        <span class="text-gray-400">
                            @for (int i = row; i < end; i++)
                            {
                                char c = (char)_fileData[i];
                                @(c >= 32 && c < 127 ? c : '.')
                            }
                        </span>
                    </div>
                }
            </div>
        </div>

        @* -- Byte Range Calculator -- *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-ruler-2 mr-1"></i> Byte Range Inspector</h3>
            <div class="flex flex-wrap items-end gap-3 mb-3">
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Start Offset</label>
                    <input type="number" min="0" max="@(_fileData.Length - 1)"
                           class="w-28 p-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 font-mono"
                           @bind="_rangeStart" @bind:after="SaveState" />
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">End Offset</label>
                    <input type="number" min="0" max="@(_fileData.Length - 1)"
                           class="w-28 p-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 font-mono"
                           @bind="_rangeEnd" @bind:after="SaveState" />
                </div>
                <button class="px-3 py-1.5 text-sm bg-blue-600 text-white rounded hover:bg-blue-700"
                        @onclick="InspectRange">
                    <i class="ti ti-zoom-scan mr-1"></i> Inspect
                </button>
                <span class="text-xs text-gray-400">File size: @_fileData.Length.ToString("N0") bytes (0–@((_fileData.Length - 1).ToString("N0")))</span>
            </div>

            @if (_rangeBytes is not null)
            {
                <div class="font-mono text-xs bg-gray-50 dark:bg-gray-800 p-3 rounded overflow-x-auto space-y-2">
                    <div>
                        <span class="text-gray-400">Hex:</span>
                        <span class="ml-2">@string.Join(" ", _rangeBytes.Select(b => b.ToString("X2")))</span>
                    </div>
                    <div>
                        <span class="text-gray-400">Dec:</span>
                        <span class="ml-2">@string.Join(" ", _rangeBytes.Select(b => b.ToString()))</span>
                    </div>
                    <div>
                        <span class="text-gray-400">ASCII:</span>
                        <span class="ml-2">@FileEncodingDetectorCore.BytesToAscii(_rangeBytes)</span>
                    </div>
                    <div class="text-gray-400">@_rangeBytes.Length byte@(_rangeBytes.Length == 1 ? "" : "s") (offset @_rangeStart–@_rangeEnd)</div>
                </div>
            }
        </div>
    }
</div>

<RecentEntryPanel @ref="_recentPanel" ToolKey="file-encoding-detector" OnRestore="RestoreState" />

@inject IJSRuntime JS

@code {
    private byte[]? _fileData;
    private string _fileName = string.Empty;
    private string _detectedEncoding = string.Empty;
    private bool _hasBom;
    private string _bomHex = string.Empty;
    private int _bomLength;
    private string _confidence = string.Empty;
    private string _lineEndings = string.Empty;
    private int _crlfCount;
    private int _lfCount;
    private int _crCount;
    private int _rangeStart;
    private int _rangeEnd = 15;
    private byte[]? _rangeBytes;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(int RangeStart, int RangeEnd);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("file-encoding-detector");
            if (state is not null)
            {
                _rangeStart = state.RangeStart;
                _rangeEnd = state.RangeEnd;
                StateHasChanged();
            }
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        IBrowserFile file = e.File;
        _fileName = file.Name;

        using Stream stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
        using MemoryStream ms = new();
        await stream.CopyToAsync(ms);
        _fileData = ms.ToArray();
        _rangeBytes = null;

        DetectEncoding();
        CountLineEndings();
        
        await Storage.AddRecentAsync("file-encoding-detector",
            $"{_fileName} → {_detectedEncoding}",
            new ToolState(_rangeStart, _rangeEnd));
    }

    private void DetectEncoding()
    {
        if (_fileData is null || _fileData.Length == 0)
        {
            _detectedEncoding = "Empty file"; _confidence = "N/A"; return;
        }
        (_detectedEncoding, _hasBom, _bomHex, _bomLength, _confidence) =
            FileEncodingDetectorCore.DetectEncoding(_fileData);
    }

    private void CountLineEndings()
    {
        if (_fileData is null) return;
        (_crlfCount, _lfCount, _crCount, _lineEndings) =
            FileEncodingDetectorCore.CountLineEndings(_fileData);
    }

    private void InspectRange()
    {
        if (_fileData is null) return;
        int start = Math.Clamp(_rangeStart, 0, _fileData.Length - 1);
        int end = Math.Clamp(_rangeEnd, start, _fileData.Length - 1);
        _rangeStart = start;
        _rangeEnd = end;
        _rangeBytes = FileEncodingDetectorCore.InspectRange(_fileData, _rangeStart, _rangeEnd);
        _ = SaveState(); // Fire and forget
    }

    private async Task DownloadWithoutBom()
    {
        if (_fileData is null || _bomLength == 0) return;

        byte[] stripped = _fileData[_bomLength..];
        string base64 = Convert.ToBase64String(stripped);
        string dataUrl = $"data:application/octet-stream;base64,{base64}";

        string js = "(function() { var a = document.createElement('a'); a.href = '" + dataUrl + "'; a.download = '" + _fileName + "'; document.body.appendChild(a); a.click(); document.body.removeChild(a); })()";
        await JS.InvokeVoidAsync("eval", js);
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("file-encoding-detector", new ToolState(_rangeStart, _rangeEnd));
    }

    private async Task RestoreState(string json)
    {
        try
        {
            ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
            if (state is not null)
            {
                _rangeStart = state.RangeStart;
                _rangeEnd = state.RangeEnd;
                StateHasChanged();
                await _recentPanel?.RefreshAsync()!;
            }
        }
        catch { /* ignore invalid state */ }
    }

}