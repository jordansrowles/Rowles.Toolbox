@page "/tools/file/checksum"
@using System.Security.Cryptography
@using System.Text.Json
@using Rowles.Toolbox.Core.File
@inject LocalStorageService Storage

<PageTitle>Checksum Verifier - Rowles.Toolbox</PageTitle>

<PageHeader Title="Checksum Verifier" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-fingerprint mr-1"></i> Calculate &amp; verify file checksums</span>
    </Actions>
</PageHeader>

<div class="space-y-4">
    @* -- Mode Tabs -- *@
    <div class="flex gap-1 border-b border-gray-200 dark:border-gray-700">
        <button class="px-4 py-2 text-sm font-medium @(_mode == ChecksumVerifierCore.Mode.File ? "border-b-2 border-blue-500 text-blue-600 dark:text-blue-400" : "text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")"
                @onclick='() => SetMode(ChecksumVerifierCore.Mode.File)'>
            <i class="ti ti-file mr-1"></i> File
        </button>
        <button class="px-4 py-2 text-sm font-medium @(_mode == ChecksumVerifierCore.Mode.Text ? "border-b-2 border-blue-500 text-blue-600 dark:text-blue-400" : "text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")"
                @onclick='() => SetMode(ChecksumVerifierCore.Mode.Text)'>
            <i class="ti ti-typography mr-1"></i> Text
        </button>
    </div>

    @if (_mode == ChecksumVerifierCore.Mode.File)
    {
        @* -- File Upload -- *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-6">
            <label class="block text-sm font-medium mb-2">Upload File</label>
            <InputFile OnChange="HandleFileUpload"
                       class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900/30 dark:file:text-blue-400" />
            @if (_isProcessing)
            {
                <div class="mt-2 text-sm text-blue-600 dark:text-blue-400">
                    <i class="ti ti-loader-2 animate-spin mr-1"></i> Computing checksums…
                </div>
            }
        </div>
    }
    else
    {
        @* -- Text Input -- *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-6">
            <label class="block text-sm font-medium mb-2">Input Text</label>
            <textarea class="w-full h-32 p-3 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-sm font-mono resize-y focus:ring-2 focus:ring-blue-500"
                      placeholder="Type or paste text to hash…"
                      @bind="_textInput" @bind:after="SaveState"></textarea>
            <div class="mt-2 flex items-center gap-3">
                <button class="px-3 py-1.5 text-sm bg-blue-600 text-white rounded hover:bg-blue-700"
                        @onclick="HashText">
                    <i class="ti ti-hash mr-1"></i> Compute Hashes
                </button>
                <select class="p-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800"
                        @bind="_textEncoding" @bind:after="SaveState">
                    <option value="utf8">UTF-8</option>
                    <option value="ascii">ASCII</option>
                </select>
            </div>
        </div>
    }

    @if (_hashes.Count > 0)
    {
        @* -- File Info -- *@
        @if (_mode == ChecksumVerifierCore.Mode.File)
        {
            <div class="flex flex-wrap gap-4 text-sm text-gray-500">
                <span><i class="ti ti-file mr-1"></i> @_fileName</span>
                <span><i class="ti ti-ruler-2 mr-1"></i> @ChecksumVerifierCore.FormatBytes(_fileSize)</span>
            </div>
        }

        @* -- Hashes -- *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-hash mr-1"></i> Checksums</h3>
            <div class="space-y-3">
                @foreach (KeyValuePair<string, string> kv in _hashes)
                {
                    <div class="flex items-center gap-2">
                        <span class="w-16 text-xs font-semibold text-gray-500 shrink-0">@kv.Key</span>
                        <code class="flex-1 text-xs bg-gray-50 dark:bg-gray-800 p-2 rounded font-mono break-all select-all">@kv.Value</code>
                        <button class="shrink-0 px-2 py-1 text-xs bg-gray-200 dark:bg-gray-700 rounded hover:bg-gray-300 dark:hover:bg-gray-600"
                                @onclick="() => CopyToClipboard(kv.Value)" title="Copy">
                            <i class="ti ti-copy"></i>
                        </button>
                    </div>
                }
            </div>
        </div>

        @* -- Verification -- *@
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
            <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-shield-check mr-1"></i> Verify Hash</h3>
            <div class="flex flex-wrap items-end gap-3">
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-xs text-gray-500 mb-1">Expected Hash</label>
                    <input type="text"
                           class="w-full p-2 text-sm border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 font-mono"
                           placeholder="Paste expected hash value…"
                           @bind="_expectedHash" @bind:event="oninput" @bind:after="SaveState" />
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">Algorithm</label>
                    <select class="p-2 text-sm border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800"
                            @bind="_verifyAlgorithm" @bind:after="SaveState">
                        <option value="auto">Auto-detect</option>
                        <option value="MD5">MD5</option>
                        <option value="SHA-1">SHA-1</option>
                        <option value="SHA-256">SHA-256</option>
                        <option value="SHA-512">SHA-512</option>
                        <option value="CRC32">CRC32</option>
                    </select>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_expectedHash))
            {
                string detectedAlgo = _verifyAlgorithm == "auto" ? ChecksumVerifierCore.DetectAlgorithm(_expectedHash) : _verifyAlgorithm;
                bool matches = _hashes.TryGetValue(detectedAlgo, out string? computed) &&
                               string.Equals(computed, _expectedHash.Trim(), StringComparison.OrdinalIgnoreCase);

                <div class="mt-3 p-3 rounded text-sm @(matches
                    ? "bg-green-50 dark:bg-green-900/20 border border-green-300 dark:border-green-700 text-green-700 dark:text-green-400"
                    : "bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 text-red-700 dark:text-red-400")">
                    @if (matches)
                    {
                        <i class="ti ti-shield-check mr-1"></i>
                        <strong>Match!</strong>
                        <span> — @detectedAlgo hash matches the expected value.</span>
                    }
                    else
                    {
                        <i class="ti ti-shield-x mr-1"></i>
                        <strong>Mismatch</strong>
                        <span> — @detectedAlgo hash does NOT match.</span>
                        @if (computed is not null)
                        {
                            <div class="mt-1 text-xs font-mono">
                                <div>Expected: @_expectedHash.Trim()</div>
                                <div>Got:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; @computed</div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    }

    @if (_copiedHash is not null)
    {
        <div class="fixed bottom-4 right-4 px-3 py-2 rounded text-xs bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-400 shadow-lg">
            <i class="ti ti-check mr-1"></i> Copied to clipboard
        </div>
    }
</div>

@inject IJSRuntime JS

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/file/checksum" OnRestore="RestoreState" />

@code {
    private ChecksumVerifierCore.Mode _mode = ChecksumVerifierCore.Mode.File;
    private Dictionary<string, string> _hashes = new();
    private string _fileName = string.Empty;
    private long _fileSize;
    private bool _isProcessing;
    private string _textInput = string.Empty;
    private string _textEncoding = "utf8";
    private string _expectedHash = string.Empty;
    private string _verifyAlgorithm = "auto";
    private string? _copiedHash;
    private RecentEntryPanel? _recentPanel;

    sealed record ToolState(ChecksumVerifierCore.Mode Mode, string TextInput, string TextEncoding, string ExpectedHash, string VerifyAlgorithm);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("checksum-verifier");
            if (state is not null)
            {
                _mode = state.Mode;
                _textInput = state.TextInput;
                _textEncoding = state.TextEncoding;
                _expectedHash = state.ExpectedHash;
                _verifyAlgorithm = state.VerifyAlgorithm;
                StateHasChanged();
            }
        }
    }

    private async Task SetMode(ChecksumVerifierCore.Mode mode)
    {
        _mode = mode;
        await SaveState();
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isProcessing = true;
        _hashes.Clear();
        StateHasChanged();

        try
        {
            IBrowserFile file = e.File;
            _fileName = file.Name;
            _fileSize = file.Size;

            using Stream stream = file.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            using MemoryStream ms = new();
            await stream.CopyToAsync(ms);
            byte[] data = ms.ToArray();

            _hashes = ChecksumVerifierCore.ComputeHashes(data);
            
            if (_hashes.Count > 0)
                await Storage.AddRecentAsync("checksum-verifier", 
                    $"File: {_fileName} ({ChecksumVerifierCore.FormatBytes(_fileSize)})",
                    new ToolState(_mode, _textInput, _textEncoding, _expectedHash, _verifyAlgorithm));
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task HashText()
    {
        _hashes.Clear();
        if (string.IsNullOrEmpty(_textInput)) return;

        System.Text.Encoding encoding = _textEncoding == "ascii"
            ? System.Text.Encoding.ASCII
            : System.Text.Encoding.UTF8;

        byte[] data = encoding.GetBytes(_textInput);
        _fileSize = data.Length;
        _fileName = "(text input)";
        _hashes = ChecksumVerifierCore.ComputeHashes(data);
        
        if (_hashes.Count > 0)
            await Storage.AddRecentAsync("checksum-verifier",
                $"Text: {_textInput.Length} chars ({_textEncoding})",
                new ToolState(_mode, _textInput, _textEncoding, _expectedHash, _verifyAlgorithm));
    }

    private async Task CopyToClipboard(string value)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
        _copiedHash = value;
        StateHasChanged();

        await Task.Delay(2000);
        _copiedHash = null;
        StateHasChanged();
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("checksum-verifier", 
            new ToolState(_mode, _textInput, _textEncoding, _expectedHash, _verifyAlgorithm));
    }

    private async Task RestoreState(string json)
    {
        try
        {
            ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
            if (state is not null)
            {
                _mode = state.Mode;
                _textInput = state.TextInput;
                _textEncoding = state.TextEncoding;
                _expectedHash = state.ExpectedHash;
                _verifyAlgorithm = state.VerifyAlgorithm;
                StateHasChanged();
                await _recentPanel?.RefreshAsync()!;
            }
        }
        catch { /* ignore invalid state */ }
    }

}