    // ── localStorage persistence ──
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreState();
        }
    }

    async Task SaveState()
    {
        ToolState state = new(_animName, _duration, _delay, _iterations, _infiniteLoop,
            _direction, _fillMode, _previewPlaying, _previewShape, _keyframes);
        await Storage.SaveStateAsync(TOOL_KEY, state);
    }

    async Task RestoreState(ToolState? state = null)
    {
        state ??= await Storage.LoadStateAsync<ToolState>(TOOL_KEY);
        if (state is not null)
        {
            _animName = state.AnimName;
            _duration = state.Duration;
            _delay = state.Delay;
            _iterations = state.Iterations;
            _infiniteLoop = state.InfiniteLoop;
            _direction = state.Direction;
            _fillMode = state.FillMode;
            _previewPlaying = state.PreviewPlaying;
            _previewShape = state.PreviewShape;
            _keyframes = state.Keyframes;
            _selectedKeyframe = _keyframes.FirstOrDefault();
            StateHasChanged();
        }
    }

    async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        await RestoreState(state);
    }
}
