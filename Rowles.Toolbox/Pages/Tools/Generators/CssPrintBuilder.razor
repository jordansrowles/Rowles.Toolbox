    private async Task ApplyMinimal()
    {
        await ResetAll();
        SetHidden("nav", true);
        SetHidden("button", true);
        
        await SaveState();
    }

    private async Task ResetAll()
    {
        _pageSize = "A4";
        _landscape = false;
        _customWidthMm = 210;
        _customHeightMm = 297;
        _sameAllMargins = true;
        _marginTop = 20;
        _marginRight = 15;
        _marginBottom = 20;
        _marginLeft = 15;

        _breakRules = new List<CssPrintBuilderCore.BreakRule>
        {
            new() { Selector = "h1", Before = "auto", Inside = "avoid", After = "auto" },
            new() { Selector = "h2", Before = "auto", Inside = "avoid", After = "auto" },
            new() { Selector = "h3", Before = "auto", Inside = "avoid", After = "auto" },
            new() { Selector = "h4", Before = "auto", Inside = "avoid", After = "auto" },
            new() { Selector = "table", Before = "auto", Inside = "avoid", After = "auto" },
            new() { Selector = "figure", Before = "auto", Inside = "avoid", After = "auto" },
            new() { Selector = "blockquote", Before = "auto", Inside = "avoid", After = "auto" },
        };
        _newBreakSelector = string.Empty;

        _hideSelectors = new List<CssPrintBuilderCore.HideEntry>
        {
            new() { Selector = "nav", Hidden = false },
            new() { Selector = ".sidebar", Hidden = false },
            new() { Selector = ".no-print", Hidden = false },
            new() { Selector = "footer", Hidden = false },
            new() { Selector = ".ads", Hidden = false },
            new() { Selector = "button", Hidden = false },
            new() { Selector = ".modal", Hidden = false },
            new() { Selector = "video", Hidden = false },
            new() { Selector = "audio", Hidden = false },
        };
        _newHideSelector = string.Empty;
        _enablePrintOnly = false;

        _bodyFontSize = 12;
        _fontSizeUnit = "pt";
        _bodyLineHeight = 1.5;
        _showUrls = false;
        _forceBlackText = false;
        _removeBackgrounds = false;
        
        await SaveState();
    }

    private void SetHidden(string selector, bool hidden)
    {
        CssPrintBuilderCore.HideEntry? entry = _hideSelectors.FirstOrDefault(h => h.Selector == selector);
        if (entry is not null)
            entry.Hidden = hidden;
    }

    private void EnsureBreakRule(string selector, string before, string inside, string after)
    {
        CssPrintBuilderCore.BreakRule? existing = _breakRules.FirstOrDefault(r => r.Selector == selector);
        if (existing is not null)
        {
            existing.Before = before;
            existing.Inside = inside;
            existing.After = after;
        }
        else
        {
            _breakRules.Add(new CssPrintBuilderCore.BreakRule { Selector = selector, Before = before, Inside = inside, After = after });
        }
    }

    // ── Helper methods for UI actions ──
    private async Task SetActiveTab(string tab)
    {
        _activeTab = tab;
        await SaveState();
    }

    private async Task SetLandscape(bool value)
    {
        _landscape = value;
        await SaveState();
    }

    // ── Copy ──
    private async Task CopyOutput()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", OptimisedCss);
        _statusMessage = "CSS copied!";
        StateHasChanged();
        await Task.Delay(1500);
        _statusMessage = null;
        
        // Add recent entry when CSS is copied
        await Storage.AddRecentAsync("tools/generators/css-print", $"CSS for {PageSizeName} ({MarginsDescription})", new ToolState(
            _activeTab, _pageSize, _landscape, _customWidthMm, _customHeightMm,
            _sameAllMargins, _marginTop, _marginRight, _marginBottom, _marginLeft,
            _breakRules, _newBreakSelector, _hideSelectors, _newHideSelector, _enablePrintOnly,
            _bodyFontSize, _fontSizeUnit, _bodyLineHeight, _showUrls, _forceBlackText, _removeBackgrounds
        ));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }

    // ── localStorage persistence ──
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/generators/css-print");
            if (state is not null)
            {
                _activeTab = state.ActiveTab;
                _pageSize = state.PageSize;
                _landscape = state.Landscape;
                _customWidthMm = state.CustomWidthMm;
                _customHeightMm = state.CustomHeightMm;
                _sameAllMargins = state.SameAllMargins;
                _marginTop = state.MarginTop;
                _marginRight = state.MarginRight;
                _marginBottom = state.MarginBottom;
                _marginLeft = state.MarginLeft;
                _breakRules = state.BreakRules;
                _newBreakSelector = state.NewBreakSelector;
                _hideSelectors = state.HideSelectors;
                _newHideSelector = state.NewHideSelector;
                _enablePrintOnly = state.EnablePrintOnly;
                _bodyFontSize = state.BodyFontSize;
                _fontSizeUnit = state.FontSizeUnit;
                _bodyLineHeight = state.BodyLineHeight;
                _showUrls = state.ShowUrls;
                _forceBlackText = state.ForceBlackText;
                _removeBackgrounds = state.RemoveBackgrounds;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/generators/css-print", new ToolState(
            _activeTab, _pageSize, _landscape, _customWidthMm, _customHeightMm,
            _sameAllMargins, _marginTop, _marginRight, _marginBottom, _marginLeft,
            _breakRules, _newBreakSelector, _hideSelectors, _newHideSelector, _enablePrintOnly,
            _bodyFontSize, _fontSizeUnit, _bodyLineHeight, _showUrls, _forceBlackText, _removeBackgrounds
        ));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _activeTab = state.ActiveTab;
            _pageSize = state.PageSize;
            _landscape = state.Landscape;
            _customWidthMm = state.CustomWidthMm;
            _customHeightMm = state.CustomHeightMm;
            _sameAllMargins = state.SameAllMargins;
            _marginTop = state.MarginTop;
            _marginRight = state.MarginRight;
            _marginBottom = state.MarginBottom;
            _marginLeft = state.MarginLeft;
            _breakRules = state.BreakRules;
            _newBreakSelector = state.NewBreakSelector;
            _hideSelectors = state.HideSelectors;
            _newHideSelector = state.NewHideSelector;
            _enablePrintOnly = state.EnablePrintOnly;
            _bodyFontSize = state.BodyFontSize;
            _fontSizeUnit = state.FontSizeUnit;
            _bodyLineHeight = state.BodyLineHeight;
            _showUrls = state.ShowUrls;
            _forceBlackText = state.ForceBlackText;
            _removeBackgrounds = state.RemoveBackgrounds;
            StateHasChanged();
        }
    }
}
