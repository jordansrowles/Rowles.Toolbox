@page "/tools/generators/css"
@inject IJSRuntime JS
@inject LocalStorageService Storage
@using Rowles.Toolbox.Core.Generators

<PageTitle>CSS Generators - Rowles.Toolbox</PageTitle>

<PageHeader Title="CSS Generators" BackUrl="/tools" BackLabel="Tools">
    <Actions>
        <span class="text-xs text-gray-400"><i class="ti ti-brush mr-1"></i> Box shadow, border &amp; gradient generators with live preview</span>
    </Actions>
</PageHeader>

<div class="flex gap-2 mb-4">
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "shadow" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "shadow"; await SaveState(); }'>
        <i class="ti ti-shadow mr-0.5"></i> Box Shadow
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "border" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "border"; await SaveState(); }'>
        <i class="ti ti-border-style mr-0.5"></i> Border
    </button>
    <button class="px-3 py-1.5 text-xs rounded cursor-pointer border-none @(_activeTab == "gradient" ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600")"
            @onclick='async () => { _activeTab = "gradient"; await SaveState(); }'>
        <i class="ti ti-color-swatch mr-0.5"></i> Gradient
    </button>
</div>

@* ----─ Box Shadow ----─ *@
@if (_activeTab == "shadow")
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 space-y-3">
            <h3 class="text-sm font-semibold text-gray-500"><i class="ti ti-adjustments mr-1"></i> Shadow Settings</h3>

            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Offset X</label>
                <input type="range" min="-50" max="50" class="flex-1" value="@_shadowX"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _shadowX = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_shadowX)px</span>
            </div>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Offset Y</label>
                <input type="range" min="-50" max="50" class="flex-1" value="@_shadowY"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _shadowY = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_shadowY)px</span>
            </div>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Blur</label>
                <input type="range" min="0" max="100" class="flex-1" value="@_shadowBlur"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _shadowBlur = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_shadowBlur)px</span>
            </div>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Spread</label>
                <input type="range" min="-50" max="50" class="flex-1" value="@_shadowSpread"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _shadowSpread = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_shadowSpread)px</span>
            </div>

            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Colour</label>
                <input type="color" class="w-8 h-8 rounded cursor-pointer border border-gray-300 dark:border-gray-600"
                       value="@_shadowColour" @onchange="async (e) => { _shadowColour = e.Value?.ToString() ?? string.Empty; await SaveState(); }" />
                <input type="text" class="w-24 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 rounded px-2 py-1 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-blue-500"
                       @bind="_shadowColour" @bind:event="oninput" @bind:after="SaveState" />
            </div>

            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Opacity</label>
                <input type="range" min="0" max="100" class="flex-1" value="@_shadowOpacity"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _shadowOpacity = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_shadowOpacity)%</span>
            </div>

            <label class="flex items-center gap-2 text-xs">
                <input type="checkbox" class="rounded" @bind="_shadowInset" @bind:after="SaveState" />
                Inset shadow
            </label>
        </div>

        <div class="space-y-3">
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-eye mr-1"></i> Preview</h3>
                <div class="flex items-center justify-center h-48 bg-gray-50 dark:bg-gray-900/30 rounded">
                    <div style="width:120px;height:120px;background:#fff;border-radius:8px;@ShadowCss"></div>
                </div>
            </div>
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-sm font-semibold text-gray-500"><i class="ti ti-code mr-1"></i> Box Shadow CSS</h3>
                    <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline cursor-pointer border-none bg-transparent"
                            @onclick="() => CopyCss(ShadowCss)">
                        <i class="ti ti-copy mr-0.5"></i> Copy
                    </button>
                </div>
                <code class="block p-2 bg-gray-50 dark:bg-gray-900/30 rounded text-xs font-mono text-gray-900 dark:text-gray-100 select-all whitespace-pre-wrap break-all">@ShadowCss</code>
            </div>
        </div>
    </div>
}

@* ----─ Border ----─ *@
@if (_activeTab == "border")
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 space-y-3">
            <h3 class="text-sm font-semibold text-gray-500"><i class="ti ti-adjustments mr-1"></i> Border Settings</h3>

            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Width</label>
                <input type="range" min="0" max="20" class="flex-1" value="@_borderWidth"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _borderWidth = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_borderWidth)px</span>
            </div>

            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Style</label>
                <select class="flex-1 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 rounded px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-blue-500"
                        @bind="_borderStyle" @bind:after="SaveState">
                    <option value="solid">solid</option>
                    <option value="dashed">dashed</option>
                    <option value="dotted">dotted</option>
                    <option value="double">double</option>
                    <option value="groove">groove</option>
                    <option value="ridge">ridge</option>
                </select>
            </div>

            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Colour</label>
                <input type="color" class="w-8 h-8 rounded cursor-pointer border border-gray-300 dark:border-gray-600"
                       value="@_borderColour" @onchange="async (e) => { _borderColour = e.Value?.ToString() ?? string.Empty; await SaveState(); }" />
                <input type="text" class="w-24 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 rounded px-2 py-1 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-blue-500"
                       @bind="_borderColour" @bind:event="oninput" @bind:after="SaveState" />
            </div>

            <h4 class="text-xs font-semibold text-gray-500 mt-2">Border Radius</h4>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Top Left</label>
                <input type="range" min="0" max="100" class="flex-1" value="@_radiusTL"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _radiusTL = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_radiusTL)px</span>
            </div>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Top Right</label>
                <input type="range" min="0" max="100" class="flex-1" value="@_radiusTR"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _radiusTR = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_radiusTR)px</span>
            </div>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Bottom Right</label>
                <input type="range" min="0" max="100" class="flex-1" value="@_radiusBR"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _radiusBR = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_radiusBR)px</span>
            </div>
            <div class="flex items-center gap-3">
                <label class="text-xs font-medium w-20 shrink-0">Bottom Left</label>
                <input type="range" min="0" max="100" class="flex-1" value="@_radiusBL"
                       @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _radiusBL = v; await SaveState(); } }" />
                <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_radiusBL)px</span>
            </div>
        </div>

        <div class="space-y-3">
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-eye mr-1"></i> Preview</h3>
                <div class="flex items-center justify-center h-48 bg-gray-50 dark:bg-gray-900/30 rounded">
                    <div style="width:120px;height:120px;background:#fff;@BorderCss"></div>
                </div>
            </div>
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-sm font-semibold text-gray-500"><i class="ti ti-code mr-1"></i> Border CSS</h3>
                    <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline cursor-pointer border-none bg-transparent"
                            @onclick="() => CopyCss(BorderCss)">
                        <i class="ti ti-copy mr-0.5"></i> Copy
                    </button>
                </div>
                <code class="block p-2 bg-gray-50 dark:bg-gray-900/30 rounded text-xs font-mono text-gray-900 dark:text-gray-100 select-all whitespace-pre-wrap break-all">@BorderCss</code>
            </div>
        </div>
    </div>
}

@* ----─ Gradient ----─ *@
@if (_activeTab == "gradient")
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded p-4 space-y-3">
            <h3 class="text-sm font-semibold text-gray-500"><i class="ti ti-adjustments mr-1"></i> Gradient Settings</h3>

            <div class="flex gap-2 mb-2">
                <button class="px-3 py-1 text-xs rounded cursor-pointer border-none @(!_gradRadial ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300")"
                        @onclick="async () => { _gradRadial = false; await SaveState(); }">
                    Linear
                </button>
                <button class="px-3 py-1 text-xs rounded cursor-pointer border-none @(_gradRadial ? "bg-blue-600 text-white" : "bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300")"
                        @onclick="async () => { _gradRadial = true; await SaveState(); }">
                    Radial
                </button>
            </div>

            @if (!_gradRadial)
            {
                <div class="flex items-center gap-3">
                    <label class="text-xs font-medium w-20 shrink-0">Angle</label>
                    <input type="range" min="0" max="360" class="flex-1" value="@_gradAngle"
                           @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _gradAngle = v; await SaveState(); } }" />
                    <span class="text-xs text-gray-400 w-14 text-right font-mono">@(_gradAngle)°</span>
                </div>
            }

            <div class="flex items-center justify-between">
                <h4 class="text-xs font-semibold text-gray-500">Colour Stops</h4>
                <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline cursor-pointer border-none bg-transparent"
                        @onclick="AddGradientStopAsync" disabled="@(_gradStops.Count >= 8)">
                    <i class="ti ti-plus mr-0.5"></i> Add
                </button>
            </div>

            <div class="space-y-2">
                @for (int i = 0; i < _gradStops.Count; i++)
                {
                    int idx = i;
                    <div class="flex items-center gap-2">
                        <input type="color" class="w-8 h-8 rounded cursor-pointer border border-gray-300 dark:border-gray-600"
                               value="@_gradStops[idx].Colour"
                               @onchange="(e) => UpdateGradStopColourAsync(idx, e)" />
                        <input type="text" class="w-20 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 rounded px-2 py-1 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-blue-500"
                               value="@_gradStops[idx].Colour"
                               @onchange="(e) => UpdateGradStopColourAsync(idx, e)" />
                        <input type="range" min="0" max="100" class="flex-1"
                               value="@_gradStops[idx].Position"
                               @oninput="async (e) => { if (int.TryParse(e.Value?.ToString(), out int v)) { _gradStops[idx].Position = v; await SaveState(); } }" />
                        <span class="text-xs text-gray-400 w-10 text-right">@(_gradStops[idx].Position)%</span>
                        @if (_gradStops.Count > 2)
                        {
                            <button class="text-red-400 hover:text-red-600 cursor-pointer border-none bg-transparent"
                                    @onclick="() => RemoveGradStopAsync(idx)">
                                <i class="ti ti-x text-xs"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="space-y-3">
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <h3 class="text-sm font-semibold text-gray-500 mb-3"><i class="ti ti-eye mr-1"></i> Preview</h3>
                <div class="flex items-center justify-center h-48 bg-gray-50 dark:bg-gray-900/30 rounded">
                    <div style="width:200px;height:120px;border-radius:8px;@GradientCss"></div>
                </div>
            </div>
            <div class="border border-gray-200 dark:border-gray-700 rounded p-4">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-sm font-semibold text-gray-500"><i class="ti ti-code mr-1"></i> Gradient CSS</h3>
                    <button class="text-xs text-blue-600 dark:text-blue-400 hover:underline cursor-pointer border-none bg-transparent"
                            @onclick="() => CopyCss(GradientCss)">
                        <i class="ti ti-copy mr-0.5"></i> Copy
                    </button>
                </div>
                <code class="block p-2 bg-gray-50 dark:bg-gray-900/30 rounded text-xs font-mono text-gray-900 dark:text-gray-100 select-all whitespace-pre-wrap break-all">@GradientCss</code>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <div class="fixed bottom-4 right-4 bg-green-600 text-white text-xs px-3 py-1.5 rounded shadow-lg z-50">
        <i class="ti ti-check mr-1"></i> @_statusMessage
    </div>
}

<RecentEntryPanel @ref="_recentPanel" ToolKey="tools/generators/css" OnRestore="RestoreState" />

@code {
    private RecentEntryPanel? _recentPanel;
    private string _activeTab = "shadow";
    private string? _statusMessage;

    // -- Box Shadow --
    private int _shadowX = 4, _shadowY = 4, _shadowBlur = 10, _shadowSpread;
    private string _shadowColour = "#000000";
    private int _shadowOpacity = 30;
    private bool _shadowInset;

    private string ShadowCss =>
        CssGeneratorsCore.BuildShadowCss(_shadowX, _shadowY, _shadowBlur, _shadowSpread, _shadowColour, _shadowOpacity, _shadowInset);

    // -- Border --
    private int _borderWidth = 2;
    private string _borderStyle = "solid";
    private string _borderColour = "#3b82f6";
    private int _radiusTL = 8, _radiusTR = 8, _radiusBR = 8, _radiusBL = 8;

    private string BorderCss =>
        CssGeneratorsCore.BuildBorderCss(_borderWidth, _borderStyle, _borderColour, _radiusTL, _radiusTR, _radiusBR, _radiusBL);

    // -- Gradient --
    private bool _gradRadial;
    private int _gradAngle = 135;
    private List<CssGeneratorsCore.GradStop> _gradStops =
    [
        new() { Colour = "#667eea", Position = 0 },
        new() { Colour = "#764ba2", Position = 100 }
    ];

    sealed record ToolState(
        string ActiveTab,
        int ShadowX, int ShadowY, int ShadowBlur, int ShadowSpread, string ShadowColour, int ShadowOpacity, bool ShadowInset,
        int BorderWidth, string BorderStyle, string BorderColour, int RadiusTL, int RadiusTR, int RadiusBR, int RadiusBL,
        bool GradRadial, int GradAngle, List<CssGeneratorsCore.GradStop> GradStops
    );

    private string GradientCss =>
        CssGeneratorsCore.BuildGradientCss(_gradRadial, _gradAngle, _gradStops);

    private async Task UpdateGradStopColourAsync(int index, ChangeEventArgs e)
    {
        if (index >= 0 && index < _gradStops.Count)
        {
            _gradStops[index].Colour = e.Value?.ToString() ?? "#000000";
            await SaveState();
        }
    }

    private async Task AddGradientStopAsync()
    {
        if (_gradStops.Count >= 8) return;
        int pos = _gradStops.Count > 0 ? Math.Min(_gradStops[^1].Position + 10, 100) : 50;
        _gradStops.Add(new CssGeneratorsCore.GradStop { Colour = "#888888", Position = pos });
        await SaveState();
    }

    private async Task RemoveGradStopAsync(int index)
    {
        if (_gradStops.Count > 2 && index >= 0 && index < _gradStops.Count)
        {
            _gradStops.RemoveAt(index);
            await SaveState();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ToolState? state = await Storage.LoadStateAsync<ToolState>("tools/generators/css");
            if (state is not null)
            {
                _activeTab = state.ActiveTab;
                _shadowX = state.ShadowX;
                _shadowY = state.ShadowY;
                _shadowBlur = state.ShadowBlur;
                _shadowSpread = state.ShadowSpread;
                _shadowColour = state.ShadowColour;
                _shadowOpacity = state.ShadowOpacity;
                _shadowInset = state.ShadowInset;
                _borderWidth = state.BorderWidth;
                _borderStyle = state.BorderStyle;
                _borderColour = state.BorderColour;
                _radiusTL = state.RadiusTL;
                _radiusTR = state.RadiusTR;
                _radiusBR = state.RadiusBR;
                _radiusBL = state.RadiusBL;
                _gradRadial = state.GradRadial;
                _gradAngle = state.GradAngle;
                _gradStops = state.GradStops;
                StateHasChanged();
            }
        }
    }

    private async Task SaveState()
    {
        await Storage.SaveStateAsync("tools/generators/css", new ToolState(
            _activeTab,
            _shadowX, _shadowY, _shadowBlur, _shadowSpread, _shadowColour, _shadowOpacity, _shadowInset,
            _borderWidth, _borderStyle, _borderColour, _radiusTL, _radiusTR, _radiusBR, _radiusBL,
            _gradRadial, _gradAngle, _gradStops
        ));
    }

    private async Task RestoreState(string json)
    {
        ToolState? state = JsonSerializer.Deserialize<ToolState>(json);
        if (state is not null)
        {
            _activeTab = state.ActiveTab;
            _shadowX = state.ShadowX;
            _shadowY = state.ShadowY;
            _shadowBlur = state.ShadowBlur;
            _shadowSpread = state.ShadowSpread;
            _shadowColour = state.ShadowColour;
            _shadowOpacity = state.ShadowOpacity;
            _shadowInset = state.ShadowInset;
            _borderWidth = state.BorderWidth;
            _borderStyle = state.BorderStyle;
            _borderColour = state.BorderColour;
            _radiusTL = state.RadiusTL;
            _radiusTR = state.RadiusTR;
            _radiusBR = state.RadiusBR;
            _radiusBL = state.RadiusBL;
            _gradRadial = state.GradRadial;
            _gradAngle = state.GradAngle;
            _gradStops = state.GradStops;
            StateHasChanged();
        }
    }

    private async Task CopyCss(string css)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", css);
        _statusMessage = "CSS copied!";
        StateHasChanged();
        await Task.Delay(1500);
        _statusMessage = null;
        
        string label = _activeTab switch
        {
            "shadow" => $"Shadow: {_shadowX}px {_shadowY}px {_shadowBlur}px",
            "border" => $"Border: {_borderWidth}px {_borderStyle}",
            "gradient" => $"Gradient: {(_gradRadial ? "radial" : "linear")} {_gradStops.Count} stops",
            _ => "CSS copied"
        };
        await Storage.AddRecentAsync("tools/generators/css", label, new ToolState(
            _activeTab,
            _shadowX, _shadowY, _shadowBlur, _shadowSpread, _shadowColour, _shadowOpacity, _shadowInset,
            _borderWidth, _borderStyle, _borderColour, _radiusTL, _radiusTR, _radiusBR, _radiusBL,
            _gradRadial, _gradAngle, _gradStops
        ));
        if (_recentPanel is not null) await _recentPanel.RefreshAsync();
    }
}