@page "/not-found"

<PageTitle>Not Found — Rowles.Toolbox</PageTitle>

<div class="flex flex-col items-center justify-center py-16 text-center">
    <div class="p-3 rounded-full bg-gray-100 dark:bg-gray-800 mb-3">
        <i class="ti ti-error-404 text-gray-500 dark:text-gray-400 text-2xl"></i>
    </div>
    <h2 class="mb-1">Page not found</h2>
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">The page you are looking for does not exist.</p>
    <a href="/" class="px-4 py-1.5 text-xs rounded bg-blue-600 text-white hover:bg-blue-700 no-underline">
        <i class="ti ti-home mr-1"></i> Home
    </a>
</div>
