@page "/"
@page "/tools"
@inject ToolSearchService Search
@implements IDisposable

<PageTitle>Rowles.Toolbox</PageTitle>

<div class="mb-4">
    <h1 class="text-base font-bold text-gray-900 dark:text-gray-100">Rowles.Toolbox</h1>
    <p class="text-[11px] text-gray-500 dark:text-gray-400">
        @ToolRegistry.ActiveToolCount client-side tools &mdash; no data leaves your browser.
    </p>
</div>

<div class="columns-1 md:columns-2 xl:columns-3 gap-x-6">

    @foreach (ToolSection sec in ToolRegistry.Sections)
    {
        <div class="break-inside-avoid mb-5">
            <div class="flex items-center gap-1 mb-1.5">
                <i class="ti @sec.Icon @sec.IconColorClass text-sm"></i>
                <span class="text-xs font-semibold text-gray-800 dark:text-gray-200">@sec.Name</span>
            </div>
            <div class="pl-3 border-l-2 border-gray-100 dark:border-gray-800 space-y-2">
                @foreach (ToolGroup grp in sec.Groups)
                {
                    @if (grp.IsPlanned)
                    {
                        <div>
                            <div class="text-[9px] font-semibold uppercase tracking-wider text-gray-300 dark:text-gray-700">
                                @grp.Name <span class="normal-case font-normal tracking-normal">(coming soon)</span>
                            </div>
                            @if (grp.Tools.Count > 0)
                            {
                                <ul class="space-y-0.5 text-[11px] text-gray-300 dark:text-gray-700">
                                    @foreach (ToolItem tool in grp.Tools)
                                    {
                                        <li>@tool.Name</li>
                                    }
                                </ul>
                            }
                        </div>
                    }
                    else
                    {
                        <div>
                            <div class="text-[9px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-0.5">@grp.Name</div>
                            <ul class="space-y-0.5 text-[11px]">
                                @foreach (ToolItem tool in grp.Tools)
                                {
                                    @if (tool.IsPlanned)
                                    {
                                        <li class="text-gray-400 dark:text-gray-600">
                                            @tool.Name
                                            @if (tool.Description is not null)
                                            {
                                                <span class="text-gray-300 dark:text-gray-700"> &mdash; @tool.Description (coming soon)</span>
                                            }
                                            else
                                            {
                                                <span class="text-gray-300 dark:text-gray-700"> (coming soon)</span>
                                            }
                                        </li>
                                    }
                                    else
                                    {
                                        bool isMatch = Search.IsMatch(tool.Route);
                                        <li class="@(isMatch ? "home-search-match" : "")">
                                            <a href="@tool.Route"
                                               class="text-gray-700 dark:text-gray-300 @sec.HoverColorClass no-underline @(isMatch ? "font-semibold" : "")">@tool.Name</a>@if (tool.Description is not null)
                                            {<span class="text-gray-400 dark:text-gray-600"> &mdash; @tool.Description</span>}
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>
    }

</div>

@code {
    protected override void OnInitialized()
    {
        Search.OnSearchChanged += OnSearchChanged;
    }

    private void OnSearchChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Search.OnSearchChanged -= OnSearchChanged;
    }
}